---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

const titre = `L'atelier — ${client.nom}, ${client.metier.nom} à ${client.adresse.ville}`;
const description = `Découvrez l'atelier de ${client.artisan.prenom} ${client.artisan.nom}, ${client.metier.nom.toLowerCase()} installé à ${client.adresse.ville} depuis ${client.anneeFondation}. Méthode de travail, garanties et savoir-faire.`;

const anciennete = new Date().getFullYear() - client.anneeFondation;
---

<Layout title={titre} description={description}>
  <section class="page-tete">
    <div class="conteneur tete-grille">
      <div>
        <p class="etiquette">L'atelier</p>
        <h1 class="titre-section">
          {client.artisan.prenom},<br /><em>{client.metier.nom.toLowerCase()}</em>
        </h1>
        <p class="tete-texte">
          {client.artisan.titre}. Installé à {client.adresse.ville} depuis
          {" " + client.anneeFondation}, je conçois, fabrique et pose chaque ouvrage
          moi-même — sans sous-traitance, sans catalogue. Chaque projet commence par
          une feuille blanche et une conversation.
        </p>
        <div class="chiffres">
          <div class="chiffre">
            <span class="chiffre-valeur">{anciennete}</span>
            <span class="chiffre-label">ans de métier</span>
          </div>
          <div class="chiffre">
            <span class="chiffre-valeur">{client.realisations.length * 40}+</span>
            <span class="chiffre-label">ouvrages livrés</span>
          </div>
          <div class="chiffre">
            <span class="chiffre-valeur">30 km</span>
            <span class="chiffre-label">déplacement gratuit</span>
          </div>
        </div>
      </div>
      <div class="tete-image">
        <img
          src="https://images.unsplash.com/photo-1567361808960-dec9cb578182?q=80&w=1400&auto=format&fit=crop"
          alt={`${client.artisan.prenom} ${client.artisan.nom} dans son atelier de ${client.adresse.ville}`}
        />
        <!-- <img src="/images/portrait.jpg" alt={`${client.artisan.prenom} ${client.artisan.nom} dans son atelier de ${client.adresse.ville}`} /> -->
      </div>
    </div>
  </section>

  <!-- Le processus est une vraie séquence : la numérotation porte du sens -->
  <section class="processus clair">
    <div class="conteneur">
      <p class="etiquette reveler">La méthode</p>
      <h2 class="titre-section reveler">Du croquis <em>à la pose</em></h2>
      <ol class="etapes">
        {
          client.processus.map((etape, i) => (
            <li class="etape reveler" style={`transition-delay:${i * 0.08}s`}>
              <span class="etape-num">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3 class="etape-titre">{etape.titre}</h3>
                <p class="etape-desc">{etape.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="garanties">
    <div class="conteneur garanties-grille">
      <div>
        <p class="etiquette reveler">Garanties</p>
        <h2 class="titre-section reveler">Un travail <em>assuré</em></h2>
      </div>
      <ul class="garanties-liste">
        <li class="reveler">
          <h3>Assurance décennale</h3>
          <p>Tous les ouvrages posés sont couverts pendant 10 ans. Attestation fournie avec chaque devis.</p>
        </li>
        <li class="reveler">
          <h3>Devis détaillé & gratuit</h3>
          <p>Chaque poste est chiffré ligne par ligne. Pas de surprise, pas de supplément caché.</p>
        </li>
        <li class="reveler">
          <h3>Fabrication locale</h3>
          <p>Tout est fabriqué dans notre atelier de {client.adresse.ville} — circuit court, délais maîtrisés.</p>
        </li>
        <li class="reveler">
          <h3>Normes en vigueur</h3>
          <p>Garde-corps, escaliers et installations conformes aux normes françaises applicables.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="cta-bas clair">
    <div class="conteneur">
      <h2 class="cta-titre reveler">Venez voir l'atelier,<br /><em>on parle mieux devant les machines.</em></h2>
      <a href="/contact" class="btn btn-plein reveler">Prendre rendez-vous</a>
    </div>
  </section>
</Layout>

<style>
  .page-tete { padding: 11rem 0 6rem; }
  .tete-grille {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4.5rem;
    align-items: center;
  }
  .tete-texte {
    color: var(--acier);
    max-width: 54ch;
    margin-bottom: 2.6rem;
  }
  .tete-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .tete-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.85);
  }
  .chiffres {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .chiffre { display: flex; flex-direction: column; }
  .chiffre-valeur {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--braise);
    line-height: 1.1;
  }
  .chiffre-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--acier);
  }

  .processus { padding-block: 7rem; }
  .etapes {
    list-style: none;
    margin-top: 3rem;
    border-top: 1px solid var(--ligne-claire);
  }
  .etape {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 2rem;
    padding-block: 2.4rem;
    border-bottom: 1px solid var(--ligne-claire);
  }
  .etape-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 2.6rem;
    color: var(--braise);
    line-height: 1;
  }
  .etape-titre {
    font-size: 1.5rem;
    margin-bottom: 0.6rem;
  }
  .etape-desc {
    color: rgba(22, 19, 16, 0.65);
    max-width: 64ch;
  }

  .garanties { padding-block: 7.5rem; }
  .garanties-grille {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 4rem;
  }
  .garanties-liste {
    list-style: none;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--ligne);
  }
  .garanties-liste li {
    padding-block: 1.8rem;
    border-bottom: 1px solid var(--ligne);
  }
  .garanties-liste h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .garanties-liste p {
    color: var(--acier);
    font-size: 0.92rem;
  }

  .cta-bas {
    padding-block: 7.5rem;
    text-align: center;
  }
  .cta-titre {
    font-size: clamp(2rem, 5vw, 3.6rem);
    margin-bottom: 2.4rem;
  }
  .cta-titre em { color: var(--braise); }

  @media (max-width: 900px) {
    .tete-grille, .garanties-grille { grid-template-columns: 1fr; gap: 2.5rem; }
    .etape { grid-template-columns: 4rem 1fr; gap: 1.2rem; }
  }
</style>
