---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

const titre = `Contact & devis gratuit — ${client.metier.nom} à ${client.adresse.ville} | ${client.nom}`;
const description = `Contactez ${client.nom} pour un devis gratuit de ${client.metier.activite.toLowerCase()} à ${client.adresse.ville} et dans les ${client.adresse.departement}. Réponse sous 48h.`;

const web3formsKey = client.web3formsKey;
const geo = client.geo;
const nomAtelier = client.nom;
---

<Layout title={titre} description={description}>
  <section class="page-tete">
    <div class="conteneur">
      <p class="etiquette">Contact</p>
      <h1 class="titre-section">Parlons de <em>votre projet</em></h1>
      <p class="page-intro">
        Décrivez votre projet en quelques lignes : nous vous rappelons sous 48h
        pour en discuter, et le devis est toujours gratuit.
      </p>
    </div>
  </section>

  <section class="contact clair">
    <div class="conteneur contact-grille">
      <!-- ---- Formulaire ---- -->
      <form id="formulaire" class="formulaire" novalidate>
        <div class="champ-duo">
          <div class="champ">
            <label for="nom">Nom *</label>
            <input type="text" id="nom" name="nom" required autocomplete="name" />
          </div>
          <div class="champ">
            <label for="telephone">Téléphone *</label>
            <input type="tel" id="telephone" name="telephone" required autocomplete="tel" />
          </div>
        </div>
        <div class="champ">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="champ">
          <label for="commune">Commune du chantier</label>
          <input type="text" id="commune" name="commune" placeholder="Ex. Perpignan, Canet…" />
        </div>
        <div class="champ">
          <label for="message">Votre projet *</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            placeholder="Type d'ouvrage, dimensions approximatives, délais souhaités…"
          ></textarea>
        </div>
        <button type="submit" class="btn btn-plein">Envoyer ma demande</button>
        <p class="form-statut" id="form-statut" role="status" aria-live="polite"></p>
      </form>

      <!-- ---- Coordonnées ---- -->
      <aside class="infos">
        <div class="infos-bloc">
          <h2>L'atelier</h2>
          <address>
            {client.adresse.rue}<br />
            {client.adresse.codePostal} {client.adresse.ville}<br />
            {client.adresse.departement} — {client.adresse.region}
          </address>
          <a class="infos-lien" href={`tel:${client.telephoneLien}`}>{client.telephone}</a>
          <a class="infos-lien" href={`mailto:${client.email}`}>{client.email}</a>
        </div>

        <div class="infos-bloc">
          <h2>Horaires</h2>
          <ul class="horaires">
            {
              client.horaires.map((h) => (
                <li>
                  <span>{h.jour}</span>
                  <span>{h.horaire}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="infos-bloc">
          <h2>Zone d'intervention</h2>
          <p class="infos-zone">{client.zoneIntervention.join(" · ")}</p>
        </div>
      </aside>
    </div>
  </section>

  <!-- ---- Carte ---- -->
  <section class="carte-section">
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
    <div id="carte" aria-label={`Localisation de l'atelier à ${client.adresse.ville}`}></div>
  </section>
</Layout>

<style>
  .page-tete { padding: 11rem 0 5rem; }
  .page-intro { max-width: 56ch; color: var(--acier); }

  .contact { padding-block: 6rem; }
  .contact-grille {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 5rem;
  }

  .formulaire { display: grid; gap: 1.6rem; }
  .champ-duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.6rem;
  }
  .champ { display: grid; gap: 0.5rem; }
  .champ label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(22, 19, 16, 0.6);
  }
  .champ input,
  .champ textarea {
    font-family: var(--font-texte);
    font-size: 0.95rem;
    padding: 0.9rem 1rem;
    background: transparent;
    border: 1px solid var(--ligne-claire);
    color: var(--noir);
    transition: border-color 0.25s ease;
  }
  .champ input:focus,
  .champ textarea:focus {
    outline: none;
    border-color: var(--braise);
  }
  .form-statut {
    font-size: 0.88rem;
    min-height: 1.4em;
  }
  .form-statut.ok { color: #2f7d32; }
  .form-statut.erreur { color: #b3261e; }

  .infos { display: grid; gap: 2.6rem; align-content: start; }
  .infos-bloc h2 {
    font-size: 1.35rem;
    margin-bottom: 0.9rem;
  }
  .infos-bloc address {
    font-style: normal;
    color: rgba(22, 19, 16, 0.7);
    margin-bottom: 0.8rem;
  }
  .infos-lien {
    display: block;
    font-weight: 500;
    margin-bottom: 0.4rem;
    transition: color 0.25s ease;
  }
  .infos-lien:hover { color: var(--braise); }
  .horaires {
    list-style: none;
    border-top: 1px solid var(--ligne-claire);
  }
  .horaires li {
    display: flex;
    justify-content: space-between;
    padding-block: 0.5rem;
    border-bottom: 1px solid var(--ligne-claire);
    font-size: 0.88rem;
  }
  .horaires li span:first-child { color: rgba(22, 19, 16, 0.6); }
  .infos-zone {
    font-size: 0.88rem;
    color: rgba(22, 19, 16, 0.7);
    line-height: 2;
  }

  .carte-section { position: relative; }
  #carte {
    height: 440px;
    width: 100%;
    filter: grayscale(0.3) contrast(1.05);
    z-index: 1;
  }

  @media (max-width: 900px) {
    .contact-grille { grid-template-columns: 1fr; gap: 3.5rem; }
    .champ-duo { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ web3formsKey, geo, nomAtelier }}>
  // ---- Envoi du formulaire via Web3Forms ----
  const formulaire = document.getElementById("formulaire");
  const statut = document.getElementById("form-statut");

  formulaire?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!formulaire.reportValidity()) return;

    statut.textContent = "Envoi en cours…";
    statut.className = "form-statut";

    const donnees = new FormData(formulaire);
    donnees.append("access_key", web3formsKey);
    donnees.append("subject", `Nouvelle demande de devis — ${nomAtelier}`);

    try {
      const reponse = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: donnees,
      });
      const resultat = await reponse.json();
      if (resultat.success) {
        statut.textContent = "Message envoyé. Nous vous rappelons sous 48h.";
        statut.className = "form-statut ok";
        formulaire.reset();
      } else {
        throw new Error(resultat.message);
      }
    } catch {
      statut.textContent =
        "L'envoi a échoué. Appelez-nous directement ou réessayez dans un instant.";
      statut.className = "form-statut erreur";
    }
  });

  // ---- Carte Leaflet (tuiles CARTO) ----
  const scriptLeaflet = document.createElement("script");
  scriptLeaflet.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
  scriptLeaflet.integrity = "sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=";
  scriptLeaflet.crossOrigin = "";
  scriptLeaflet.onload = () => {
    const carte = L.map("carte", { scrollWheelZoom: false }).setView(
      [geo.lat, geo.lng],
      13
    );
    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
        maxZoom: 19,
      }
    ).addTo(carte);
    L.marker([geo.lat, geo.lng]).addTo(carte).bindPopup(nomAtelier);
  };
  document.body.appendChild(scriptLeaflet);
</script>
