---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

const titre = `Réalisations — ${client.metier.nom} à ${client.adresse.ville} | ${client.nom}`;
const description = `Portails, garde-corps, escaliers, verrières : découvrez les réalisations de ${client.nom}, ${client.metier.activite.toLowerCase()} à ${client.adresse.ville} et dans les ${client.adresse.departement}.`;

const categories = ["Tout", ...new Set(client.realisations.map((r) => r.categorie))];
---

<Layout title={titre} description={description}>
  <section class="page-tete">
    <div class="conteneur">
      <p class="etiquette">Réalisations</p>
      <h1 class="titre-section">
        Les fiches <em>d'atelier</em>
      </h1>
      <p class="page-intro">
        Chaque ouvrage est documenté comme à l'atelier : la matière, la commune,
        l'année. Toutes les pièces sont fabriquées et posées par nos soins dans les
        {" " + client.adresse.departement}.
      </p>
    </div>
  </section>

  <section class="galerie clair">
    <div class="conteneur">
      <div class="filtres" role="group" aria-label="Filtrer par catégorie">
        {
          categories.map((cat, i) => (
            <button class:list={["filtre", { actif: i === 0 }]} data-categorie={cat}>
              {cat}
            </button>
          ))
        }
      </div>

      <div class="fiches">
        {
          client.realisations.map((r) => (
            <article class="fiche reveler" data-categorie={r.categorie}>
              <div class="fiche-image">
                <img src={r.image} alt={`${r.titre} — ${r.categorie} à ${r.lieu}`} loading="lazy" />
                {/* <img src={r.imageLocale} alt={`${r.titre} — ${r.categorie} à ${r.lieu}`} loading="lazy" /> */}
              </div>
              <div class="fiche-meta">
                <p class="fiche-cat">{r.categorie}</p>
                <h2 class="fiche-titre">{r.titre}</h2>
                <dl class="fiche-table">
                  <div><dt>Matière</dt><dd>{r.matiere}</dd></div>
                  <div><dt>Commune</dt><dd>{r.lieu}</dd></div>
                  <div><dt>Année</dt><dd>{r.annee}</dd></div>
                </dl>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-bas">
    <div class="conteneur cta-inner">
      <h2 class="cta-titre">Votre projet mérite <em>sa fiche d'atelier.</em></h2>
      <a href="/contact" class="btn btn-plein">Demander un devis gratuit</a>
    </div>
  </section>
</Layout>

<style>
  .page-tete {
    padding: 11rem 0 5rem;
  }
  .page-intro {
    max-width: 58ch;
    color: var(--acier);
  }

  .galerie { padding-block: 5.5rem; }
  .filtres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 3.5rem;
  }
  .filtre {
    font-family: var(--font-texte);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: transparent;
    border: 1px solid var(--ligne-claire);
    color: var(--noir);
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  .filtre:hover { border-color: var(--braise); color: var(--braise); }
  .filtre.actif {
    background: var(--braise);
    border-color: var(--braise);
    color: var(--creme);
  }

  .fiches {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.2rem;
  }
  .fiche.cachee { display: none; }
  .fiche-image {
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  .fiche-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .fiche:hover .fiche-image img { transform: scale(1.05); }
  .fiche-cat {
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--braise);
    margin-top: 1.2rem;
  }
  .fiche-titre {
    font-size: 1.4rem;
    margin: 0.4rem 0 0.9rem;
  }
  .fiche-table { border-top: 1px solid var(--ligne-claire); }
  .fiche-table div {
    display: flex;
    justify-content: space-between;
    padding-block: 0.5rem;
    border-bottom: 1px solid var(--ligne-claire);
    font-size: 0.82rem;
  }
  .fiche-table dt {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: rgba(22, 19, 16, 0.55);
    align-self: center;
  }
  .fiche-table dd { font-weight: 500; }

  .cta-bas {
    padding-block: 7rem;
    text-align: center;
  }
  .cta-titre {
    font-size: clamp(2rem, 5vw, 3.4rem);
    margin-bottom: 2.2rem;
  }
  .cta-titre em { color: var(--braise); }

  @media (max-width: 980px) { .fiches { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { .fiches { grid-template-columns: 1fr; } }
</style>

<script>
  const filtres = document.querySelectorAll<HTMLButtonElement>(".filtre");
  const fiches = document.querySelectorAll<HTMLElement>(".fiche[data-categorie]");

  filtres.forEach((bouton) => {
    bouton.addEventListener("click", () => {
      filtres.forEach((b) => b.classList.remove("actif"));
      bouton.classList.add("actif");
      const cat = bouton.dataset.categorie;
      fiches.forEach((f) => {
        const visible = cat === "Tout" || f.dataset.categorie === cat;
        f.classList.toggle("cachee", !visible);
      });
    });
  });
</script>
