---
import { client } from "@data/client";

const liens = [
  { href: "/", label: "Accueil" },
  { href: "/realisations", label: "Réalisations" },
  { href: "/a-propos", label: "L'atelier" },
  { href: "/contact", label: "Contact" },
];
const cheminActuel = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="entete">
  <div class="conteneur entete-inner">
    <a href="/" class="logo">
      <span class="logo-nom">{client.nom}</span>
      <span class="logo-sous">{client.metier.activite} — {client.adresse.ville}</span>
    </a>

    <nav class="nav" id="nav">
      {
        liens.map((l) => (
          <a
            href={l.href}
            class:list={["nav-lien", { actif: cheminActuel === l.href }]}
          >
            {l.label}
          </a>
        ))
      }
      <a href={`tel:${client.telephoneLien}`} class="nav-tel">{client.telephone}</a>
    </nav>

    <button class="burger" id="burger" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .entete {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: linear-gradient(to bottom, rgba(22, 19, 16, 0.92), rgba(22, 19, 16, 0.75));
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ligne);
  }
  .entete-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1rem;
  }
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .logo-nom {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.01em;
  }
  .logo-sous {
    font-size: 0.62rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--acier);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 2.2rem;
  }
  .nav-lien {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--creme);
    opacity: 0.75;
    transition: opacity 0.25s ease, color 0.25s ease;
  }
  .nav-lien:hover,
  .nav-lien.actif {
    opacity: 1;
    color: var(--braise);
  }
  .nav-tel {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    padding: 0.55rem 1.2rem;
    border: 1px solid var(--braise);
    color: var(--braise);
    transition: background 0.25s ease, color 0.25s ease;
  }
  .nav-tel:hover {
    background: var(--braise);
    color: var(--noir);
  }
  .burger {
    display: none;
    flex-direction: column;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .burger span {
    width: 26px;
    height: 1.5px;
    background: var(--creme);
    transition: transform 0.3s ease;
  }

  @media (max-width: 860px) {
    .burger { display: flex; }
    .nav {
      position: fixed;
      inset: 0;
      top: 64px;
      flex-direction: column;
      justify-content: center;
      gap: 2.4rem;
      background: var(--noir);
      transform: translateX(100%);
      transition: transform 0.35s ease;
    }
    .nav.ouvert { transform: none; }
    .nav-lien { font-size: 1.05rem; }
    .burger[aria-expanded="true"] span:first-child {
      transform: translateY(4.5px) rotate(45deg);
    }
    .burger[aria-expanded="true"] span:last-child {
      transform: translateY(-4px) rotate(-45deg);
    }
  }
</style>

<script>
  const burger = document.getElementById("burger");
  const nav = document.getElementById("nav");
  burger?.addEventListener("click", () => {
    const ouvert = nav?.classList.toggle("ouvert");
    burger.setAttribute("aria-expanded", String(!!ouvert));
  });
</script>
