---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---
<Layout title={`Contact — ${client.nomComplet}`} description={`Contactez Phoenix Event & Fire Security — ${client.adresse}. Urgences 24h/7j : ${client.telephoneUrgent}.`}>
<nav class="navbar" id="navbar"><div class="nav-wrap">
  <a href="/" class="nav-logo"><div class="nav-logo-main">PHOENIX<span> SECURITY</span></div><div class="nav-logo-sub">Event & Fire Security</div></a>
  <ul class="nav-links"><li class="nav-item"><a href="/">Accueil</a></li><li class="nav-item"><a href="/services">Services</a></li><li class="nav-item"><a href="/a-propos">À Propos</a></li><li class="nav-item"><a href="/recrutement">Recrutement</a></li><li class="nav-item"><a href="/clients">Clients</a></li><li class="nav-item"><a href="/contact" class="active">Contact</a></li></ul>
  <div class="nav-cta"><a href="/devis" class="btn btn-rouge">Demander un devis</a></div>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><nav class="mob-nav"><a href="/">Accueil</a><a href="/services">Services</a><a href="/a-propos">À Propos</a><a href="/recrutement">Recrutement</a><a href="/clients">Clients</a><a href="/contact" class="active">Contact</a></nav><div class="mob-cta-wrap"><a href="/devis" class="btn btn-rouge" style="width:100%;justify-content:center">Demander un devis →</a></div><div class="mob-footer"><a href={client.telephoneLink} class="mob-tel">{client.telephone}</a></div></div></nav>

<section class="contact-wrap">
  <div class="wrap contact-lay">
    <div data-r="l">
      <span class="label-tac">Nous contacter</span>
      <h1 style="font-family:var(--font-disp);font-size:clamp(3rem,6vw,6rem);text-transform:uppercase;color:var(--blanc);line-height:.92;margin:10px 0">CONTACT<br><span style="color:var(--rouge)">& URGENCES</span></h1>
      <div class="rouge-line"></div>
      <div class="contact-infos">
        <div class="ci-item"><span class="ci-lbl">Téléphone</span><a href={client.telephoneLink} class="ci-val">{client.telephone}</a></div>
        <div class="ci-item"><span class="ci-lbl">Email</span><a href={`mailto:${client.email}`} class="ci-val">{client.email}</a></div>
        <div class="ci-item"><span class="ci-lbl">Siège</span><span class="ci-val">{client.adresse}</span></div>
        <div class="ci-item ci-urgence"><span class="ci-lbl" style="color:var(--rouge)">🚨 Urgence 24/7</span><a href={client.telephoneLink} class="ci-val" style="color:var(--rouge);font-size:1.6rem">{client.telephoneUrgent}</a></div>
      </div>
      <div class="contact-horaires">
        {client.horaires.map(h => (
          <div class="ch-row"><span class="disp" style="font-size:.82rem;color:var(--fumee-d)">{h.jour}</span><span style="font-size:.82rem;color:var(--blanc)">{h.horaire}</span></div>
        ))}
      </div>
    </div>
    <div data-r="r">
      <div class="form-card" id="cForm">
        <h2 class="disp" style="font-size:1.5rem;color:var(--blanc);margin-bottom:1.5rem">ENVOYER UN MESSAGE</h2>
        <div class="fields">
          <div class="frow"><div class="fg"><label>Nom *</label><input id="cNom" type="text" required/></div><div class="fg"><label>Téléphone</label><input id="cTel" type="tel"/></div></div>
          <div class="fg"><label>Email *</label><input id="cEmail" type="email" required/></div>
          <div class="fg"><label>Objet</label><input id="cObj" type="text" placeholder="Demande d'information, partenariat…"/></div>
          <div class="fg"><label>Message *</label><textarea id="cMsg" rows="5" required></textarea></div>
          <button type="button" id="cBtn" class="btn btn-rouge btn-xl" style="width:100%;justify-content:center">ENVOYER →</button>
        </div>
      </div>
      <div id="cOk" style="display:none" class="form-ok"><span class="disp fo-title">MESSAGE REÇU.</span><p>Notre équipe vous répond sous 24h.</p><a href="/" class="btn btn-ghost" style="margin-top:1.5rem">← Accueil</a></div>
    </div>
  </div>
  {client.googleMapsEmbed && <div class="map-s"><iframe src={client.googleMapsEmbed} width="100%" height="380" style="border:0;filter:grayscale(1) contrast(1.1) brightness(0.4)" allowfullscreen loading="lazy" title="Phoenix Security Paris"/></div>}
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<script define:vars={{ web3Key, emailTo: client.email }}>
  document.getElementById('cBtn')?.addEventListener('click', async () => {
    const n=document.getElementById('cNom')?.value||'',t=document.getElementById('cTel')?.value||'';
    const e=document.getElementById('cEmail')?.value||'',o=document.getElementById('cObj')?.value||'';
    const m=document.getElementById('cMsg')?.value||'';
    if (!n||!e||!m){alert('Champs * obligatoires');return}
    const btn=document.getElementById('cBtn');btn.textContent='Envoi…';btn.disabled=true;
    if (web3Key){try{const r=await fetch('https://api.web3forms.com/submit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({access_key:web3Key,subject:`Contact Phoenix — ${o||'Message'} — ${n}`,from_name:n,telephone:t,email:e,objet:o,message:m})});if((await r.json()).success){document.getElementById('cForm').style.display='none';document.getElementById('cOk').style.display='flex';return}}catch{}}
    window.location.href=`mailto:${emailTo}?subject=${o||'Contact'} — ${n}&body=${m}`;
  });
</script>
<style>
.contact-wrap{padding:calc(var(--total-h)+4rem) 0 0;min-height:100vh;background:var(--noir)}
.contact-lay{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;padding-bottom:4rem}
.contact-infos{display:flex;flex-direction:column;border:1px solid var(--border-w);margin-top:1.5rem}
.ci-item{display:flex;flex-direction:column;gap:3px;padding:14px 18px;border-bottom:1px solid var(--border-w)}.ci-item:last-child{border-bottom:none}
.ci-lbl{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--fumee-d)}
.ci-val{font-size:.9rem;color:var(--blanc);letter-spacing:.04em}.ci-val:hover{color:var(--rouge)}
.ci-urgence{background:var(--rouge-g)}
.contact-horaires{display:flex;flex-direction:column;border:1px solid var(--border-w);margin-top:3px}
.ch-row{display:flex;justify-content:space-between;padding:10px 18px;border-bottom:1px solid var(--border-w)}.ch-row:last-child{border-bottom:none}
.form-card{background:var(--noir-1);border:1px solid var(--border-w);padding:2.5rem}
.fields{display:flex;flex-direction:column;gap:14px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.fg{display:flex;flex-direction:column;gap:5px}
.fg label{font-size:9px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(240,240,238,.3)}
.fg input,.fg textarea{padding:12px 14px;border:1px solid var(--border-w);background:rgba(240,240,238,.03);font-family:var(--font-body);font-size:.85rem;color:var(--blanc);letter-spacing:.04em}
.fg input:focus,.fg textarea:focus{outline:none;border-color:var(--rouge)}
.fg textarea{resize:vertical;min-height:150px}
.form-ok{background:var(--rouge-g);border:1px solid var(--border);padding:48px 36px;flex-direction:column;align-items:center;text-align:center;gap:10px}
.fo-title{font-size:3rem;color:var(--rouge)}
.form-ok p{font-size:.84rem;color:var(--fumee);line-height:1.8}
.map-s{height:380px}.map-s iframe{display:block}
@media(max-width:1024px){.contact-lay{grid-template-columns:1fr}}
@media(max-width:640px){.frow{grid-template-columns:1fr}.form-card{padding:1.5rem}}
</style>
