---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../data/client';
---
<Layout title={`Services — ${client.nomComplet}`} description={`Gardiennage, sécurité événementielle et protection incendie SSIAP — les 3 spécialités de Phoenix Security à Paris et Île-de-France.`}>
<nav class="navbar" id="navbar"><div class="nav-wrap">
  <a href="/" class="nav-logo"><div class="nav-logo-main">PHOENIX<span> SECURITY</span></div><div class="nav-logo-sub">Event & Fire Security</div></a>
  <ul class="nav-links"><li class="nav-item"><a href="/">Accueil</a></li><li class="nav-item"><a href="/services" class="active">Services</a></li><li class="nav-item"><a href="/a-propos">À Propos</a></li><li class="nav-item"><a href="/recrutement">Recrutement</a></li><li class="nav-item"><a href="/clients">Clients</a></li><li class="nav-item"><a href="/contact">Contact</a></li></ul>
  <div class="nav-cta"><a href="/devis" class="btn btn-rouge">Demander un devis</a></div>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><nav class="mob-nav"><a href="/">Accueil</a><a href="/services" class="active">Services</a><a href="/a-propos">À Propos</a><a href="/recrutement">Recrutement</a><a href="/clients">Clients</a><a href="/contact">Contact</a></nav><div class="mob-cta-wrap"><a href="/devis" class="btn btn-rouge" style="width:100%;justify-content:center">Demander un devis →</a></div><div class="mob-footer"><a href={client.telephoneLink} class="mob-tel">{client.telephone}</a></div></div></nav>

<div class="ph"><div class="wrap">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Services</span></nav>
  <span class="label-tac">Nos Spécialités</span>
  <h1 style="font-family:var(--font-disp);font-size:clamp(3rem,7vw,7rem);text-transform:uppercase;color:var(--blanc);line-height:.9;margin-top:10px">SOLUTIONS<br><span style="color:var(--rouge)">DE SÉCURITÉ</span></h1>
  <p class="lead" style="margin-top:1rem">Des solutions intégrées pour chaque scénario de risque.</p>
</div></div>

{client.services.map((s, i) => (
  <section class={`sec${i%2===1?'-1':''}`}>
    <div class="wrap svc-row" style={i%2===1?'direction:rtl':''}>
      <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
           PHOTO SERVICE — depuis client.ts (champ image)
           Pour remplacer : dans client.ts, commentez la ligne
           `image: "https://..."` et décommentez le chemin local
           ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
      <div class="sr-img" style={i%2===1?'direction:ltr':''}>
        <img src={s.image} alt={s.titre} loading="lazy"/>
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(220,26,42,.06) 0%,transparent 100%)"></div>
        <span class="sr-num disp">{String(i+1).padStart(2,'0')}</span>
      </div>
      <div class="sr-body" style={i%2===1?'direction:ltr':''}>
        <span class="label-tac">{s.titreCourt}</span>
        <h2 class="h2" style="margin-top:8px">{s.titre.toUpperCase()}</h2>
        <div class="rouge-line"></div>
        <p class="lead">{s.descriptionLongue}</p>
        <ul class="sr-points">
          {s.points.map(p => <li><span class="rouge">▸</span>{p}</li>)}
        </ul>
        <a href="/devis" class="btn btn-rouge" style="margin-top:2rem">Demander un devis →</a>
      </div>
    </div>
  </section>
))}

<section class="sec-rouge-cta"><div class="wrap cta-inner">
  <div data-r><h2 class="h2" style="color:#fff">VOTRE MISSION,<br><span style="color:rgba(255,255,255,.5)">NOTRE PRIORITÉ.</span></h2></div>
  <a href="/devis" class="btn btn-rouge btn-xl" data-r="r">Demander un devis →</a>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.svc-row{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:520px}
.sr-img{position:relative;overflow:hidden;min-height:400px}.sr-img img{width:100%;height:100%;object-fit:cover;filter:grayscale(.25)}
.sr-num{position:absolute;top:16px;right:20px;font-size:5rem;color:rgba(240,240,238,.07);line-height:1}
.sr-body{padding:clamp(2.5rem,5vw,5rem);display:flex;flex-direction:column;justify-content:center}
.sr-points{list-style:none;display:flex;flex-direction:column;gap:8px;margin-top:1.2rem}
.sr-points li{display:flex;align-items:baseline;gap:10px;font-size:.82rem;color:var(--fumee);letter-spacing:.04em}
.sr-points .rouge{font-size:.65rem;flex-shrink:0}
.sec-rouge-cta{background:var(--noir-1);border-top:3px solid var(--rouge);border-bottom:3px solid var(--rouge);padding:clamp(4rem,7vw,7rem) 0}
.cta-inner{display:flex;justify-content:space-between;align-items:center;gap:3rem;flex-wrap:wrap}
@media(max-width:1024px){.svc-row{grid-template-columns:1fr;direction:ltr!important}.sr-img{min-height:280px}.cta-inner{flex-direction:column}}
</style>
