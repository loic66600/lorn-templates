---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`À Propos — ${client.nomComplet}`} description={`Phoenix Event & Fire Security depuis ${client.apropos.fondation} — histoire, certifications, équipe de ${client.apropos.equipe} agents professionnels en Île-de-France.`}>
<nav class="navbar" id="navbar"><div class="nav-wrap">
  <a href="/" class="nav-logo"><div class="nav-logo-main">PHOENIX<span> SECURITY</span></div><div class="nav-logo-sub">Event & Fire Security</div></a>
  <ul class="nav-links"><li class="nav-item"><a href="/">Accueil</a></li><li class="nav-item"><a href="/services">Services</a></li><li class="nav-item"><a href="/a-propos" class="active">À Propos</a></li><li class="nav-item"><a href="/recrutement">Recrutement</a></li><li class="nav-item"><a href="/clients">Clients</a></li><li class="nav-item"><a href="/contact">Contact</a></li></ul>
  <div class="nav-cta"><a href="/devis" class="btn btn-rouge">Demander un devis</a></div>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><nav class="mob-nav"><a href="/">Accueil</a><a href="/services">Services</a><a href="/a-propos" class="active">À Propos</a><a href="/recrutement">Recrutement</a><a href="/clients">Clients</a><a href="/contact">Contact</a></nav><div class="mob-cta-wrap"><a href="/devis" class="btn btn-rouge" style="width:100%;justify-content:center">Demander un devis →</a></div><div class="mob-footer"><a href={client.telephoneLink} class="mob-tel">{client.telephone}</a></div></div></nav>

<div class="ph"><div class="wrap">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>À Propos</span></nav>
  <span class="label-tac">Notre histoire</span>
  <h1 style="font-family:var(--font-disp);font-size:clamp(3rem,7vw,7rem);text-transform:uppercase;color:var(--blanc);line-height:.9;margin-top:10px">PHOENIX<br><span style="color:var(--rouge)">SECURITY</span><br>DEPUIS {client.apropos.fondation}.</h1>
</div></div>

<section class="sec-1">
  <div class="wrap story-lay">
    <div data-r="l">
      <span class="label-tac">Notre philosophie</span>
      <h2 class="h2" style="margin-top:8px">ZÉRO COMPROMIS.<br><span class="rouge">ZÉRO SOUS-TRAITANCE.</span></h2>
      <div class="rouge-line"></div>
      <p class="lead">{client.apropos.p1}</p>
      <p class="lead" style="margin-top:.6rem">{client.apropos.p2}</p>
      <p class="lead" style="margin-top:.6rem">{client.apropos.p3}</p>
      <div class="story-stats">
        {client.stats.slice(0,2).map(s => (
          <div class="ss-item">
            <strong class="disp rouge" style="font-size:2.2rem;display:block"><span class="ctr" data-target={s.chiffre} data-suffix={s.suffix}>0</span></strong>
            <span style="font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--fumee)">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
    <div data-r="r">
      <div style="height:520px;overflow:hidden;position:relative">
        <img src={client.apropos.photoEquipe} alt="Équipe Phoenix Security" loading="lazy" style="width:100%;height:100%;object-fit:cover;filter:grayscale(.2)"/>
        <!-- <img src="/images/equipe.jpg" alt="Équipe Phoenix Security" loading="lazy" style="width:100%;height:100%;object-fit:cover"/> -->
        <div style="position:absolute;bottom:16px;left:16px"><span class="dot-live">Équipe Phoenix active</span></div>
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(220,26,42,.06) 0%,transparent 100%)"></div>
      </div>
    </div>
  </div>
</section>

<section class="sec">
  <div class="wrap">
    <span class="label-tac" data-r>Certifications & Agréments</span>
    <h2 class="h2" data-r style="transition-delay:.1s;margin-top:8px;margin-bottom:2.5rem">NOS<br><span class="rouge">QUALIFICATIONS</span></h2>
    <div class="cert-grid">
      {client.certifications.map((c, i) => (
        <div class="cert-item" data-r style={`transition-delay:${i*.08}s`}>
          <span style="color:var(--rouge);font-size:.7rem">✦</span>
          <span>{c}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="sec-rouge-cta"><div class="wrap cta-inner">
  <div data-r><h2 class="h2" style="color:#fff">OPÉRATIONS EN COURS<br><span style="color:rgba(255,255,255,.5)">REJOIGNEZ L'ÉLITE.</span></h2></div>
  <div class="cta-acts" data-r="r"><a href="/devis" class="btn btn-rouge btn-xl">Demander un devis →</a><a href="/recrutement" class="btn btn-ghost btn-xl">Nous rejoindre</a></div>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.story-lay{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.story-stats{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border-w);margin-top:2rem}
.ss-item{padding:16px 20px;border-right:1px solid var(--border-w)}.ss-item:last-child{border-right:none}
.cert-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border:1px solid var(--border-w)}
.cert-item{display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid var(--border-w);font-size:.84rem;color:var(--fumee);letter-spacing:.04em}
.cert-item:nth-child(2n-1){border-right:1px solid var(--border-w)}
.cert-item:nth-child(5),.cert-item:nth-child(6){border-bottom:none}
.cert-item:hover{background:var(--rouge-g);color:var(--blanc)}
.sec-rouge-cta{background:var(--noir-1);border-top:3px solid var(--rouge);border-bottom:3px solid var(--rouge);padding:clamp(4rem,7vw,7rem) 0}
.cta-inner{display:flex;justify-content:space-between;align-items:center;gap:3rem;flex-wrap:wrap}
.cta-acts{display:flex;flex-direction:column;gap:12px}
@media(max-width:1024px){.story-lay{grid-template-columns:1fr}}
@media(max-width:768px){.cert-grid{grid-template-columns:1fr}.cert-item{border-right:none!important}.cta-inner{flex-direction:column}}
</style>
