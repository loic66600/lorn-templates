---
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
interface Props { title?: string; description?: string; noIndex?: boolean; }
const { title = client.titreSEO, description = client.descriptionSEO, noIndex = false } = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": client.nom,
  "description": client.descriptionSEO,
  "telephone": client.telephoneLink.replace("tel:", ""),
  "email": client.email,
  "url": client.canonicalUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": client.adresse.split(",")[0],
    "addressLocality": client.ville,
    "postalCode": client.codePostal,
    "addressCountry": "FR"
  },
  "areaServed": client.zones.map(z => ({ "@type": "City", "name": z })),
  "priceRange": "€€",
  "image": client.heroImage,
  "sameAs": Object.values(client.reseaux).filter(Boolean),
};
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={client.motsCles.join(', ')} />
  <meta name="robots" content={noIndex ? "noindex,nofollow" : "index,follow"} />
  <link rel="canonical" href={client.canonicalUrl + Astro.url.pathname} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={client.ogImage} />
  <meta property="og:url" content={client.canonicalUrl + Astro.url.pathname} />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tenor+Sans&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
</head>
<body>
  <slot />

  {client.cookieConsent && (
    <div class="cookie-bar" id="cookieBar">
      <div class="cookie-inner">
        <p>Ce site utilise des cookies techniques. <a href={`${base}/mentions-legales`}>En savoir plus</a></p>
        <div class="cookie-btns">
          <button id="ckAccept">Accepter</button>
          <button id="ckRefuse" class="ghost">Refuser</button>
        </div>
      </div>
    </div>
  )}

  <style is:global>
    /* ══ RESET ══ */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-padding-top: 80px; }
    body {
      font-family: 'Jost', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    ::selection { background: rgba(184,150,78,.18); }

    /* ══ VARIABLES ══ */
    :root {
      --black:      #111111;
      --black-90:   rgba(17,17,17,.92);
      --gold:       #B8964E;
      --gold-light: #CDB070;
      --gold-pale:  #F5EFE1;
      --gold-line:  rgba(184,150,78,.35);

      --bg:         #FAFAF8;  /* blanc minéral */
      --bg-alt:     #F3F1EE;
      --bg-dark:    #111111;
      --bg-card:    #FFFFFF;

      --border:       rgba(17,17,17,.08);
      --border-strong:rgba(17,17,17,.16);
      --border-gold:  rgba(184,150,78,.3);

      --text:       #111111;
      --text-muted: #6B6560;
      --text-light: rgba(107,101,96,.5);

      --font-display: 'Tenor Sans', Georgia, serif;
      --font-body:    'Jost', system-ui, sans-serif;

      --r:     0px;    /* menuisier = angles droits, zéro arrondi par défaut */
      --r-sm:  2px;
      --r-md:  4px;
      --shadow:    0 2px 12px rgba(17,17,17,.06);
      --shadow-md: 0 4px 32px rgba(17,17,17,.10);
      --shadow-lg: 0 8px 56px rgba(17,17,17,.14);
      --nav-h:  80px;
      --wrap:   1280px;
    }

    /* ══ LAYOUT ══ */
    .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 clamp(1.25rem, 3.5vw, 3rem); }
    .sec      { padding: clamp(5rem, 8vw, 8rem) 0; }
    .sec-alt  { padding: clamp(5rem, 8vw, 8rem) 0; background: var(--bg-alt); }
    .sec-dark { padding: clamp(5rem, 8vw, 8rem) 0; background: var(--bg-dark); }
    .sec-gold { padding: clamp(4rem, 6vw, 5rem) 0; background: var(--gold); }

    /* ══ TYPOGRAPHY ══ */
    .display { font-family: var(--font-display); }

    /* Eyebrow — minimaliste, ligne or gauche */
    .eyebrow {
      display: inline-flex; align-items: center; gap: 14px;
      font-family: var(--font-body); font-size: 10px; font-weight: 500;
      letter-spacing: .3em; text-transform: uppercase; color: var(--gold);
      margin-bottom: 16px;
    }
    .eyebrow::before {
      content: ''; width: 32px; height: 1px;
      background: var(--gold); flex-shrink: 0;
    }
    .eyebrow-white { color: rgba(255,255,255,.45); }
    .eyebrow-white::before { background: rgba(255,255,255,.3); }
    .eyebrow-dark { color: var(--text-muted); }
    .eyebrow-dark::before { background: var(--border-strong); }

    .h2 {
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 3.5vw, 3rem);
      font-weight: 400; line-height: 1.15; letter-spacing: .01em;
      color: var(--text);
    }
    .h2-white { color: #fff; }
    .lead {
      font-size: .93rem; color: var(--text-muted);
      line-height: 1.85; max-width: 520px; font-weight: 300;
    }

    /* Ligne or décorative */
    .gold-rule { display: block; width: 48px; height: 1px; background: var(--gold); margin: 20px 0; }

    /* ══ BOUTONS — angles droits, sérieux ══ */
    .btn {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: var(--font-body); font-size: 12px; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase;
      padding: 14px 28px; border: 1.5px solid transparent;
      cursor: pointer;
    }
    .btn-black {
      background: var(--black); color: #fff; border-color: var(--black);
    }
    .btn-black:hover { background: #2a2a2a; }
    .btn-gold {
      background: var(--gold); color: #fff; border-color: var(--gold);
    }
    .btn-gold:hover { background: var(--gold-light); border-color: var(--gold-light); }
    .btn-outline {
      background: transparent; color: var(--text); border-color: var(--border-strong);
    }
    .btn-outline:hover { border-color: var(--black); }
    .btn-outline-white {
      background: transparent; color: #fff; border-color: rgba(255,255,255,.35);
    }
    .btn-outline-white:hover { border-color: rgba(255,255,255,.8); }
    .btn-lg { padding: 17px 36px; font-size: 12.5px; }

    /* ══ SOCIAL ══ */
    .soc-links { display: flex; gap: 8px; }
    .soc-link {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px;
      background: var(--bg-alt); border: 1px solid var(--border);
      color: var(--text-muted);
    }
    .soc-link:hover { background: var(--gold); border-color: var(--gold); color: #fff; }
    .soc-link svg { width: 15px; height: 15px; }
    .soc-dark { background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.1); color: rgba(255,255,255,.4); }
    .soc-dark:hover { background: var(--gold); border-color: var(--gold); color: #fff; }

    /* ══ TAGS ══ */
    .tag {
      background: var(--bg-alt); border: 1px solid var(--border);
      padding: 4px 12px; font-size: 10.5px; font-weight: 400;
      color: var(--text-muted); letter-spacing: .08em; text-transform: uppercase;
    }
    .tag-gold { background: var(--gold-pale); border-color: var(--border-gold); color: var(--gold); }

    /* ══ NAVBAR ══ */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: var(--nav-h);
      background: rgba(250,250,248,.97);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    }
    .navbar.transparent {
      background: transparent;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .navbar:not(.transparent) .nav-logo-mark.wh { border-color: var(--gold); }
    .navbar:not(.transparent) .nav-logo-name.wh { color: var(--text); }
    .navbar:not(.transparent) .nav-logo-sub.wh { color: var(--text-muted); }
    .navbar:not(.transparent) .nav-links a.wh { color: var(--text-muted); }
    .navbar:not(.transparent) .nav-links a.wh:hover,
    .navbar:not(.transparent) .nav-links a.wh.active { color: var(--text); }
    .navbar:not(.transparent) .nav-tel.wh { color: var(--text-muted); }
    .navbar:not(.transparent) .burger.wh span { background: var(--text); }
    .nav-wrap {
      display: flex; align-items: center; justify-content: space-between;
      height: 100%; padding: 0 clamp(1.25rem, 3.5vw, 3rem);
      max-width: var(--wrap); margin: 0 auto;
    }

    /* Logo — typographique */
    .nav-logo { display: flex; align-items: center; gap: 14px; }
    .nav-logo-mark {
      width: 36px; height: 36px; border: 1.5px solid var(--gold);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .nav-logo-mark svg { width: 20px; height: 20px; }
    .nav-logo-mark.wh { border-color: rgba(255,255,255,.4); }
    .nav-logo-text { display: flex; flex-direction: column; }
    .nav-logo-name {
      font-family: var(--font-display); font-size: 16px;
      color: var(--text); line-height: 1; letter-spacing: .04em;
    }
    .nav-logo-name.wh { color: #fff; }
    .nav-logo-sub {
      font-size: 9.5px; font-weight: 400; letter-spacing: .2em;
      text-transform: uppercase; color: var(--text-muted); line-height: 1.4;
    }
    .nav-logo-sub.wh { color: rgba(255,255,255,.38); }

    .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
    .nav-links a {
      font-family: var(--font-body); font-size: 11.5px; font-weight: 400;
      letter-spacing: .12em; text-transform: uppercase; color: var(--text-muted);
      position: relative; padding-bottom: 2px;
    }
    .nav-links a.wh { color: rgba(255,255,255,.55); }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -2px; left: 0;
      width: 0; height: 1px; background: var(--gold);
    }
    .nav-links a:hover, .nav-links a.active { color: var(--text); }
    .nav-links a.wh:hover, .nav-links a.wh.active { color: #fff; }
    .nav-links a:hover::after, .nav-links a.active::after { width: 100%; }

    .nav-cta { display: flex; align-items: center; gap: 16px; }
    .nav-tel {
      font-family: var(--font-body); font-size: 13px; font-weight: 500;
      color: var(--text-muted); letter-spacing: .04em;
    }
    .nav-tel:hover { color: var(--gold); }
    .nav-tel.wh { color: rgba(255,255,255,.5); }

    .burger { display: none; flex-direction: column; gap: 5px; padding: 8px; border: none; background: none; cursor: pointer; }
    .burger span { display: block; width: 22px; height: 1px; background: var(--text); }
    .burger.wh span { background: #fff; }
    .burger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .burger.open span:nth-child(2) { opacity: 0; }
    .burger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    .mob-menu {
      display: none; position: fixed; top: var(--nav-h); left: 0; right: 0; bottom: 0;
      background: var(--bg); padding: 48px 32px;
      flex-direction: column; z-index: 999;
    }
    .mob-menu.open { display: flex; }
    .mob-menu a {
      font-family: var(--font-display); font-size: 1.8rem;
      color: var(--text-muted); padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }
    .mob-menu a:hover { color: var(--text); }
    .mob-cta {
      margin-top: 28px; padding: 16px 24px;
      background: var(--black); color: #fff !important;
      font-family: var(--font-body) !important; font-size: 12px !important;
      letter-spacing: .14em; text-transform: uppercase;
      border-bottom: none !important; text-align: center;
    }

    /* ══ PAGE HEADER ══ */
    .ph {
      padding: calc(var(--nav-h) + 4rem) 0 5rem;
      background: var(--black); position: relative;
    }
    .ph-bc {
      display: flex; gap: 10px; font-size: 10.5px; color: rgba(255,255,255,.22);
      margin-bottom: 20px; align-items: center; letter-spacing: .1em; text-transform: uppercase;
    }
    .ph-bc a { color: rgba(255,255,255,.22); }
    .ph-bc a:hover { color: var(--gold); }
    .ph-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.8rem);
      font-weight: 400; letter-spacing: .02em; line-height: 1.12;
      color: #fff; margin: 0 0 16px;
    }
    .ph-title em { font-style: normal; color: var(--gold); }
    .ph-sub {
      font-size: .9rem; color: rgba(255,255,255,.4);
      max-width: 500px; line-height: 1.8; font-weight: 300;
    }
    /* Trait or bas de header */
    .ph::after {
      content: ''; position: absolute;
      bottom: 0; left: clamp(1.25rem, 3.5vw, 3rem); right: clamp(1.25rem, 3.5vw, 3rem);
      height: 1px; background: var(--border-gold);
    }

    /* ══ SECTION LABEL ══ */
    .sc { margin-bottom: 4rem; }
    .sc .eyebrow { display: flex; }
    .sc-center { text-align: center; }
    .sc-center .eyebrow { justify-content: center; }
    .sc-center .eyebrow::before { display: none; }

    /* ══ FOOTER ══ */
    .footer {
      background: var(--black); color: rgba(255,255,255,.45);
      padding: 64px 0 28px;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }

    .f-logo-row { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
    .f-logo-mark {
      width: 34px; height: 34px; border: 1px solid rgba(184,150,78,.4);
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .f-logo-mark svg { width: 18px; height: 18px; }
    .f-logo-name { font-family: var(--font-display); font-size: .95rem; color: #fff; letter-spacing: .04em; }
    .f-brand p { font-size: 12.5px; line-height: 1.85; color: rgba(255,255,255,.28); margin-bottom: 20px; }

    .f-col h4 {
      font-size: 9.5px; font-weight: 500; letter-spacing: .25em;
      text-transform: uppercase; color: rgba(255,255,255,.2); margin-bottom: 16px;
    }
    .f-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .f-col ul li a { font-size: 12.5px; color: rgba(255,255,255,.38); }
    .f-col ul li a:hover { color: var(--gold); }
    .f-bottom {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 24px; border-top: 1px solid rgba(255,255,255,.06);
      flex-wrap: wrap; gap: 12px;
    }
    .f-bottom p { font-size: 11.5px; color: rgba(255,255,255,.18); }
    .lorn-badge {
      font-size: 11px; color: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.08); padding: 5px 14px;
    }
    .lorn-badge:hover { color: var(--gold); border-color: rgba(184,150,78,.3); }

    /* ══ COOKIE ══ */
    .cookie-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      background: var(--black); border-top: 1px solid rgba(255,255,255,.08);
    }
    .cookie-bar.hidden { display: none; }
    .cookie-inner {
      max-width: var(--wrap); margin: 0 auto;
      padding: 14px clamp(1.25rem, 3.5vw, 3rem);
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
    }
    .cookie-inner p { font-size: 12.5px; color: rgba(255,255,255,.45); flex: 1; min-width: 200px; }
    .cookie-inner a { color: var(--gold); }
    .cookie-btns { display: flex; gap: 8px; }
    .cookie-btns button {
      padding: 9px 20px; font-family: var(--font-body); font-size: 11.5px;
      font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
      cursor: pointer; border: none;
    }
    .cookie-btns button:first-child { background: var(--gold); color: #fff; }
    .cookie-btns button.ghost { background: transparent; border: 1px solid rgba(255,255,255,.18); color: rgba(255,255,255,.38); }

    /* ══ RESPONSIVE ══ */
    @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; } }
    @media (max-width: 768px) {
      .nav-links, .nav-tel { display: none !important; }
      .burger { display: flex !important; }
      .footer-grid { grid-template-columns: 1fr; gap: 24px; }
      .f-bottom { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <script>
    // Navbar transparente sur hero uniquement si présente
    const nav = document.getElementById('navbar');
    if (nav?.classList.contains('transparent-init')) {
      const update = () => nav.classList.toggle('transparent', window.scrollY < 60);
      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    // Burger
    const burger = document.getElementById('burger');
    const mob = document.getElementById('mob-menu');
    burger?.addEventListener('click', () => {
      burger.classList.toggle('open');
      mob?.classList.toggle('open');
      document.body.style.overflow = mob?.classList.contains('open') ? 'hidden' : '';
    });
    mob?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      burger?.classList.remove('open'); mob?.classList.remove('open');
      document.body.style.overflow = '';
    }));

    // Cookie
    const cb = document.getElementById('cookieBar');
    if (cb && localStorage.getItem('cookies-choice')) cb.classList.add('hidden');
    document.getElementById('ckAccept')?.addEventListener('click', () => {
      localStorage.setItem('cookies-choice', 'accepted'); cb?.classList.add('hidden');
    });
    document.getElementById('ckRefuse')?.addEventListener('click', () => {
      localStorage.setItem('cookies-choice', 'refused'); cb?.classList.add('hidden');
    });

    // Counters (légers, sans animation CSS)
    const cobs = new IntersectionObserver(entries => {
      entries.forEach(el => {
        if (!el.isIntersecting || el.target.classList.contains('done')) return;
        el.target.classList.add('done');
        const tgt = parseFloat((el.target as HTMLElement).dataset.target || '0');
        const sfx = (el.target as HTMLElement).dataset.suffix || '';
        const dur = 1200; const t0 = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - t0) / dur, 1);
          el.target.textContent = Math.round(tgt * p) + sfx;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: .5 });
    document.querySelectorAll('.ctr').forEach(el => cobs.observe(el));
  </script>
</body>
</html>
