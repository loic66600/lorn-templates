---
import { client } from "@data/client";

const liens = [
  { href: "/", label: "Accueil" },
  { href: "/prestations", label: "Prestations" },
  { href: "/a-propos", label: "L'agence" },
  { href: "/contact", label: "Contact" },
];
const cheminActuel = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="entete">
  <div class="conteneur entete-inner">
    <a href="/" class="logo">
      <svg class="logo-icone" viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 4l9 4v8c0 6-4 10-9 12-5-2-9-6-9-12V8z" fill="none" stroke="currentColor" stroke-width="2"/>
        <circle cx="16" cy="15" r="3" fill="currentColor"/>
      </svg>
      <span class="logo-bloc">
        <span class="logo-nom">{client.nom}</span>
        <span class="logo-sous">Sécurité privée · Incendie</span>
      </span>
    </a>

    <nav class="nav" id="nav">
      {
        liens.map((l) => (
          <a href={l.href} class:list={["nav-lien", { actif: cheminActuel === l.href }]}>
            {l.label}
          </a>
        ))
      }
      <a href={`tel:${client.urgenceLien}`} class="nav-urgence">
        <span class="nav-urgence-label">Urgence 24/7</span>
        <span class="nav-urgence-tel">{client.urgence}</span>
      </a>
    </nav>

    <button class="burger" id="burger" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .entete {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(7, 11, 18, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ligne);
  }
  .entete-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.9rem;
  }
  .logo { display: flex; align-items: center; gap: 0.8rem; }
  .logo-icone { width: 34px; height: 34px; color: var(--alerte); }
  .logo-bloc { display: flex; flex-direction: column; line-height: 1.25; }
  .logo-nom {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .logo-sous {
    font-family: var(--font-data);
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gris);
  }
  .nav { display: flex; align-items: center; gap: 2.1rem; }
  .nav-lien {
    font-family: var(--font-display);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blanc);
    opacity: 0.7;
    transition: opacity 0.25s ease, color 0.25s ease;
  }
  .nav-lien:hover, .nav-lien.actif { opacity: 1; color: var(--alerte); }
  .nav-urgence {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.3;
    padding: 0.45rem 1.1rem;
    border: 1px solid var(--alerte);
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    transition: background 0.25s ease;
  }
  .nav-urgence:hover { background: rgba(232, 57, 44, 0.14); }
  .nav-urgence-label {
    font-family: var(--font-data);
    font-size: 0.56rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--alerte);
  }
  .nav-urgence-tel {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.88rem;
    letter-spacing: 0.06em;
  }
  .burger {
    display: none;
    flex-direction: column;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .burger span {
    width: 26px; height: 1.5px;
    background: var(--blanc);
    transition: transform 0.3s ease;
  }

  @media (max-width: 920px) {
    .burger { display: flex; }
    .nav {
      position: fixed;
      inset: 0;
      top: 60px;
      flex-direction: column;
      justify-content: center;
      gap: 2.4rem;
      background: var(--nuit);
      transform: translateX(100%);
      transition: transform 0.35s ease;
    }
    .nav.ouvert { transform: none; }
    .nav-lien { font-size: 1rem; }
    .burger[aria-expanded="true"] span:first-child { transform: translateY(4.5px) rotate(45deg); }
    .burger[aria-expanded="true"] span:last-child { transform: translateY(-4px) rotate(-45deg); }
  }
</style>

<script>
  const burger = document.getElementById("burger");
  const nav = document.getElementById("nav");
  burger?.addEventListener("click", () => {
    const ouvert = nav?.classList.toggle("ouvert");
    burger.setAttribute("aria-expanded", String(!!ouvert));
  });
</script>
