---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`Mentions légales — ${client.nomComplet}`} description={`Mentions légales ${client.nomComplet}`} noIndex={true}>
<nav class="navbar" id="navbar"><div class="nav-inner">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span>ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div><div class="mob-menu" id="mob-menu"><nav><a href="/">Accueil</a><a href="/contact">Réserver</a></nav></div>
</nav>
<section class="legal-wrap"><div class="wrap legal-container">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Mentions légales</span></nav>
  <h1 class="disp l-title">MENTIONS<br>LÉGALES</h1>
  <p class="mono l-date">Mis à jour le {new Date().toLocaleDateString('fr-FR',{year:'numeric',month:'long',day:'numeric'})}</p>
  <div class="l-content">
    <div class="lb"><h2 class="disp">01 — Éditeur</h2><p class="mono"><strong>{client.responsable}</strong><br/>SIRET : {client.siret}<br/>Adresse : {client.adresse}<br/>Tél : <a href={client.telephoneLink}>{client.telephone}</a><br/>Email : <a href={`mailto:${client.email}`}>{client.email}</a></p></div>
    <div class="lb"><h2 class="disp">02 — Hébergement</h2><p class="mono">{client.hebergeur}</p></div>
    <div class="lb"><h2 class="disp">03 — Conception</h2><p class="mono">Site réalisé par <strong>LORN Digital Studio</strong> — <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener">vitemonsite-artisan.fr</a></p></div>
    <div class="lb"><h2 class="disp">04 — Propriété intellectuelle</h2><p class="mono">L'ensemble du contenu (textes, photos de tatouages, design, code) est la propriété de {client.nomComplet} et de ses artistes. Toute reproduction non autorisée est interdite (CPI art. L.335-2). Les photos de tatouages sont des œuvres appartenant aux artistes concernés.</p></div>
    <div class="lb"><h2 class="disp">05 — Données personnelles (RGPD)</h2>
      <p class="mono"><strong>Données collectées :</strong> Via le formulaire — nom, téléphone, email, description du projet. Utilisées uniquement pour traiter votre demande de réservation.</p>
      <p class="mono" style="margin-top:.5rem"><strong>Base légale :</strong> Consentement (RGPD art. 6.1.a) et intérêt légitime (art. 6.1.f).</p>
      <p class="mono" style="margin-top:.5rem"><strong>Vos droits :</strong> Accès, rectification, suppression — <a href={`mailto:${client.email}`}>{client.email}</a>. Recours : <a href="https://www.cnil.fr" target="_blank" rel="noopener">cnil.fr</a></p>
      <p class="mono" style="margin-top:.5rem"><strong>Sous-traitant formulaire :</strong> Web3Forms (web3forms.com) — conforme RGPD, aucune revente de données.</p>
    </div>
    <div class="lb"><h2 class="disp">06 — Cookies</h2><p class="mono">Cookies techniques uniquement (localStorage pour mémorisation du consentement). Aucun traceur publicitaire, aucun cookie tiers.</p></div>
    <div class="lb"><h2 class="disp">07 — Droit applicable</h2><p class="mono">Droit français — tribunaux compétents de Perpignan.</p></div>
  </div>
  <a href="/" class="btn btn-ghost" style="margin-top:2.5rem">← Retour à l'accueil</a>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} · SIRET {client.siret}</p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.legal-wrap { padding:calc(var(--nav-h)+4.5rem) 0 5rem; }
.legal-container { max-width:680px; }
.l-title { font-size:clamp(2rem,5vw,5rem); font-style:italic; color:var(--peau); margin-bottom:8px; }
.l-date { font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted); margin-bottom:3rem; }
.l-content { display:flex; flex-direction:column; }
.lb { padding:1.5rem 0; border-bottom:1px solid var(--border-w); }
.lb:last-child { border-bottom:none; }
.lb h2 { font-size:.78rem; letter-spacing:.18em; color:var(--acid); margin-bottom:.9rem; font-style:italic; }
.lb p { font-size:.78rem; color:var(--muted); line-height:2.0; letter-spacing:.03em; }
.lb a { color:var(--acid); }
.lb strong { color:var(--peau); font-weight:500; }
</style>
