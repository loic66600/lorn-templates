---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../data/client';

export function getStaticPaths() {
  return client.artistes.map(a => ({
    params: { slug: a.slug },
    props: { artiste: a },
  }));
}

interface Props { artiste: typeof client.artistes[0]; }
const { artiste: a } = Astro.props;
const idx = client.artistes.findIndex(x => x.slug === a.slug);
const next = client.artistes[(idx+1) % client.artistes.length];
---
<Layout
  title={`${a.pseudo} — ${a.style} | ${client.nomComplet} Perpignan`}
  description={`${a.pseudo}, tatoueur spécialisé en ${a.style} au ${client.nomComplet} Perpignan. ${a.experience} d'expérience. ${a.disponibilite}. Réservez en ligne.`}
>
<nav class="navbar" id="navbar"><div class="nav-inner">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span>ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/artistes" class="active">Artistes</a></li><li><a href="/a-propos">Le Studio</a></li><li><a href="/hygiene">Hygiène</a></li><li><a href="/videos">Vidéos</a></li><li><a href="/tarifs">Tarifs</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-menu" id="mob-menu"><nav><a href="/">Accueil</a><a href="/artistes" class="active">Artistes</a><a href="/a-propos">Le Studio</a><a href="/hygiene">Hygiène</a><a href="/videos">Vidéos</a><a href="/tarifs">Tarifs</a><a href="/contact" class="reserve-mob">Réserver →</a></nav><div class="mob-bottom"><a href={client.telephoneLink}>{client.telephone}</a></div></div>
</nav>

<!-- HERO ARTISTE — plein écran avec photo -->
<section class="art-hero">
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       PHOTO ARTISTE — depuis client.ts (champ photo)
       Pour remplacer :
         Dans client.ts, dans l'artiste concerné :
         - Commentez :   photo: "https://..."
         - Décommentez : // photo: "/images/artistes/NOM.jpg"
       ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <div class="ah-bg">
    <img src={a.photo} alt={a.pseudo} loading="eager"/>
    <div class="ah-grad"></div>
    <div class="ah-grad-bottom" style={`background:linear-gradient(to top, var(--noir) 0%, transparent 50%)`}></div>
  </div>
  <div class="ah-content">
    <div class="wrap">
      <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><a href="/artistes">Artistes</a><span>›</span><span>{a.pseudo}</span></nav>
      <span class="label">{a.style}</span>
      <h1 class="art-h1 disp" data-glitch>{a.pseudo}</h1>
      <div class="art-meta mono">
        <span class="am-item">{a.experience} d'expérience</span>
        <span class="am-sep">·</span>
        <span class="am-item" style={`color:${a.couleur}`}>{a.disponibilite}</span>
      </div>
    </div>
  </div>
  <div class="ah-bar" style={`background:${a.couleur}`}></div>
</section>

<!-- BIOGRAPHIE + PORTFOLIO -->
<section class="sec sec-1">
  <div class="wrap art-layout">
    <div class="art-bio" data-reveal>
      <span class="label">À propos</span>
      <p class="lead" style="margin-top:1rem">{a.description}</p>
      <p class="lead" style="margin-top:.75rem">{a.biographie}</p>
      <div class="bio-tags">
        {a.specialites.map(s => <span class="tag" style={`color:${a.couleur};border-color:${a.couleur};background:${a.couleur}15`}>{s}</span>)}
      </div>
      <div class="bio-cta">
        <a href="/contact" class="btn btn-acid">Réserver avec {a.prenom} →</a>
        {a.instagram && <a href={a.instagram} target="_blank" rel="noopener" class="btn btn-ghost">Instagram</a>}
      </div>
    </div>
    <div class="art-port">
      <span class="label" data-reveal>Portfolio</span>
      <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
           PHOTOS PORTFOLIO — depuis client.ts (champ portfolio[])
           Pour remplacer : dans client.ts, pour chaque artiste,
           commentez les URL Unsplash et décommentez les chemins locaux.
           ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
      <div class="port-grid">
        {a.portfolio.map((img, i) => (
          <div class="pg-item" data-reveal style={`transition-delay:${(i%3)*.08}s`}>
            <img src={img} alt={`${a.pseudo} — tatouage ${i+1}`} loading="lazy"/>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- NEXT ARTIST -->
<a href={`/artistes/${next.slug}`} class="next-artist">
  <div class="na-inner">
    <div>
      <span class="mono na-label">Artiste suivant</span>
      <div class="disp na-name" data-glitch>{next.pseudo}</div>
      <span class="mono na-style">{next.styleShort}</span>
    </div>
    <span class="disp na-arrow">→</span>
  </div>
  <div class="na-bg"><img src={next.photo} alt={next.pseudo} loading="lazy"/><div class="na-grad"></div></div>
</a>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>

<style>
.art-hero { position:relative; height:80vh; min-height:500px; display:flex; flex-direction:column; justify-content:flex-end; overflow:hidden; }
.ah-bg { position:absolute; inset:0; }.ah-bg img { width:100%; height:100%; object-fit:cover; object-position:center 20%; }
.ah-grad { position:absolute; inset:0; background:linear-gradient(160deg,rgba(17,16,8,.85) 0%,rgba(17,16,8,.3) 100%); }
.ah-grad-bottom { position:absolute; inset:0; }
.ah-content { position:relative; z-index:1; padding-bottom:4rem; }
.art-h1 { font-size:clamp(3rem,10vw,9rem); font-weight:900; font-style:italic; text-transform:uppercase; color:var(--peau); line-height:.9; margin:12px 0 10px; }
.art-meta { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
.am-item { font-size:10px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted); }
.am-sep { color:var(--border-w); }
.ah-bar { height:4px; position:relative; z-index:1; }

.art-layout { display:grid; grid-template-columns:360px 1fr; gap:4rem; align-items:start; }
.art-bio { position:sticky; top:calc(var(--nav-h)+2rem); }
.bio-tags { display:flex; flex-wrap:wrap; gap:7px; margin:1.5rem 0; }
.bio-cta { display:flex; flex-direction:column; gap:10px; margin-top:1.5rem; }

.port-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:3px; margin-top:1rem; }
.pg-item { aspect-ratio:3/4; overflow:hidden; }
.pg-item img { width:100%; height:100%; object-fit:cover; transition:transform .5s ease; }
.pg-item:hover img { transform:scale(1.05); }
.pg-item:nth-child(3n+1) { aspect-ratio:auto; grid-column:span 2; aspect-ratio:16/7; }

.next-artist { display:block; position:relative; height:280px; overflow:hidden; }
.na-bg { position:absolute; inset:0; }.na-bg img { width:100%; height:100%; object-fit:cover; transition:transform .5s ease; }
.next-artist:hover .na-bg img { transform:scale(1.05); }
.na-grad { position:absolute; inset:0; background:rgba(17,16,8,.75); }
.na-inner { position:relative; z-index:1; height:100%; display:flex; align-items:center; justify-content:space-between; padding:0 clamp(1rem,3vw,3rem); max-width:var(--wrap); margin:0 auto; }
.na-label { font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:var(--muted); display:block; margin-bottom:6px; }
.na-name { font-size:clamp(2rem,5vw,4.5rem); font-weight:900; font-style:italic; text-transform:uppercase; color:var(--peau); line-height:1; }
.na-style { font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:var(--muted); display:block; margin-top:4px; }
.na-arrow { font-size:3rem; color:var(--acid); }
.next-artist:hover .na-arrow { transform:translateX(8px); }

@media(max-width:1024px) { .art-layout { grid-template-columns:1fr; } .art-bio { position:static; } }
@media(max-width:640px) { .port-grid { grid-template-columns:1fr; } .pg-item:nth-child(3n+1) { grid-column:auto; aspect-ratio:3/4; } }
</style>
