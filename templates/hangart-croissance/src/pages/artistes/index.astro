---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../data/client';
---
<Layout title={`Artistes — ${client.nomComplet}`} description={`6 artistes tatoueurs au ${client.nomComplet} Perpignan — THYTTOO, CECE, CORT, DCTATTTOO, LAB RAT, VINS FURY. Styles variés, hygiène certifiée.`}>
<nav class="navbar" id="navbar"><div class="nav-inner">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span>ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/artistes" class="active">Artistes</a></li><li><a href="/a-propos">Le Studio</a></li><li><a href="/hygiene">Hygiène</a></li><li><a href="/videos">Vidéos</a></li><li><a href="/tarifs">Tarifs</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-menu" id="mob-menu"><nav><a href="/">Accueil</a><a href="/artistes" class="active">Artistes</a><a href="/a-propos">Le Studio</a><a href="/hygiene">Hygiène</a><a href="/videos">Vidéos</a><a href="/tarifs">Tarifs</a><a href="/contact" class="reserve-mob">Réserver →</a></nav><div class="mob-bottom"><a href={client.telephoneLink}>{client.telephone}</a></div></div>
</nav>

<div class="ph"><div class="wrap">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Artistes</span></nav>
  <span class="label">L'équipe</span>
  <h1 class="ph-title disp">NOS<br><em style="color:var(--acid)">6 ARTISTES</em></h1>
  <p class="ph-sub mono">6 styles. 6 univers. Une seule exigence : que votre tatouage soit exceptionnel.</p>
</div></div>

<section class="sec">
  <div class="wrap">
    <!-- ARTISTE LISTING — alternés -->
    {client.artistes.map((a, i) => (
      <article class={`artist-full ${i%2===1?'rev':''}`} id={a.slug}>
        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             PHOTO ARTISTE — depuis client.ts
             Remplacez photo: dans client.ts pour changer
             ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <div class="af-img">
          <img src={a.photo} alt={`${a.pseudo} — ${a.style}`} loading="lazy"/>
          <div class="af-accent" style={`background:${a.couleur}`}></div>
          <span class="af-num disp">{String(i+1).padStart(2,'0')}</span>
        </div>
        <div class="af-body">
          <div class="af-head">
            <span class="label">{a.style}</span>
            <span class="mono af-exp">— {a.experience} d'expérience</span>
          </div>
          <h2 class="h2 af-name" data-glitch style={`color:var(--peau)`}>{a.pseudo}</h2>
          <div class="acid-line" style={`background:${a.couleur}`}></div>
          <p class="lead">{a.description}</p>
          <p class="lead" style="margin-top:.6rem">{a.biographie}</p>
          <div class="af-tags">
            {a.specialites.map(s => <span class="tag" style={`color:${a.couleur};border-color:${a.couleur};background:${a.couleur}15`}>{s}</span>)}
          </div>
          <div class="af-meta mono">
            <div><span>Disponibilité</span><strong style={`color:${a.couleur}`}>{a.disponibilite}</strong></div>
          </div>
          <div class="af-btns">
            <a href={`/artistes/${a.slug}`} class="btn btn-acid">Voir le portfolio complet →</a>
            {a.instagram && <a href={a.instagram} target="_blank" rel="noopener" class="btn btn-ghost">Instagram</a>}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<section class="cta-final"><div class="wrap cta-inner">
  <div><span class="label">Votre projet</span><h2 class="h2" style="margin-top:8px">Choisissez<br><span style="color:var(--acid)">votre artiste.</span></h2></div>
  <div class="cta-actions"><a href="/contact" class="btn btn-acid btn-lg">Réserver →</a><a href={client.telephoneLink} class="btn btn-ghost btn-lg">{client.telephone}</a></div>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>

<style>
.artist-full { display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid var(--border-w); min-height:580px; }
.artist-full:last-child { border-bottom:none; }
.artist-full.rev { direction:rtl; } .artist-full.rev>* { direction:ltr; }
.af-img { position:relative; overflow:hidden; }
.af-img img { width:100%; height:100%; object-fit:cover; min-height:440px; }
.af-accent { position:absolute; bottom:0; left:0; right:0; height:4px; }
.af-num { position:absolute; top:16px; right:20px; font-size:5rem; font-weight:900; color:rgba(240,237,232,.08); line-height:1; }
.af-body { padding:clamp(2.5rem,5vw,5rem); display:flex; flex-direction:column; justify-content:center; background:var(--bg-1); }
.af-head { display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap; margin-bottom:12px; }
.af-exp { font-size:10px; letter-spacing:.14em; color:var(--muted); text-transform:uppercase; }
.af-name { font-size:clamp(2rem,4vw,4rem); margin:8px 0; }
.af-tags { display:flex; flex-wrap:wrap; gap:7px; margin:1.2rem 0; }
.af-meta { display:flex; gap:0; border:1px solid var(--border-w); margin:1rem 0; }
.af-meta div { padding:12px 16px; border-right:1px solid var(--border-w); }
.af-meta div:last-child { border-right:none; }
.af-meta span { display:block; font-size:9px; letter-spacing:.16em; text-transform:uppercase; color:var(--muted); margin-bottom:4px; }
.af-meta strong { font-size:.85rem; }
.af-btns { display:flex; gap:10px; flex-wrap:wrap; margin-top:1.5rem; }
.cta-final { background:var(--bg-1); border-top:2px solid var(--acid); padding:clamp(4rem,7vw,8rem) 0; }
.cta-inner { display:flex; justify-content:space-between; align-items:center; gap:3rem; flex-wrap:wrap; }
.cta-actions { display:flex; flex-direction:column; gap:12px; }
@media(max-width:1024px) { .artist-full { grid-template-columns:1fr; direction:ltr!important; } .af-img { min-height:320px; } .af-img img { min-height:320px; } }
</style>
