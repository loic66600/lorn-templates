---
---
<div class="cookies" id="cookies" hidden>
  <p>
    Kapass Variétés utilise uniquement des cookies techniques nécessaires au
    bon fonctionnement du site. Aucune donnée n'est exploitée à des fins
    publicitaires.
  </p>
  <div class="cookies-actions">
    <button class="cookies-btn cookies-ok" id="cookies-ok">Accepter</button>
    <button class="cookies-btn cookies-non" id="cookies-non">Refuser</button>
  </div>
</div>

<style>
  .cookies {
    position: fixed;
    bottom: 1rem; left: 1rem; right: 1rem;
    z-index: 200;
    max-width: 420px;
    background: var(--noir-2);
    border: 1px solid var(--ligne);
    border-radius: var(--rayon);
    padding: 1.3rem 1.5rem;
    font-size: 0.85rem;
    color: var(--blanc);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
  }
  .cookies-actions { display: flex; gap: 0.8rem; margin-top: 1rem; }
  .cookies-btn {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    border-radius: 100px;
    cursor: pointer;
    border: 1.5px solid var(--ligne);
    background: transparent;
    color: var(--blanc);
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .cookies-ok { background: var(--or); border-color: var(--or); color: #1a1408; }
  .cookies-non:hover { border-color: var(--violet); color: var(--violet-clair); }

  @media (min-width: 560px) { .cookies { left: 1.4rem; right: auto; } }
</style>

<script>
  const banniere = document.getElementById("cookies");
  if (banniere && !localStorage.getItem("cookies-choice")) banniere.hidden = false;
  document.getElementById("cookies-ok")?.addEventListener("click", () => {
    localStorage.setItem("cookies-choice", "accepted");
    if (banniere) banniere.hidden = true;
  });
  document.getElementById("cookies-non")?.addEventListener("click", () => {
    localStorage.setItem("cookies-choice", "refused");
    if (banniere) banniere.hidden = true;
  });
</script>
