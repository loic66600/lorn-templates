---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
const socials = Object.entries(client.reseaux).filter(([_,v]) => v);
const socialIcons: Record<string,string> = {
  facebook: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>',
  instagram:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>',
  tiktok:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52V6.83a4.84 4.84 0 01-1-.14z"/></svg>',
  linkedin: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>',
  youtube:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>',
  twitter: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
};

const featuredServices = client.services.filter(s => s.featured);
const extraServices    = client.services.filter(s => !s.featured);
---

<Layout>

  <!-- ═══ NAVBAR ═══ -->
  <nav class="navbar" id="navbar">
    <div class="nav-wrap">
      <a href="/" class="nav-logo">
        <div class="nav-logo-mark">✂</div>
        <div class="nav-logo-text">
          <span class="nav-logo-name">{client.nom}</span>
          <span class="nav-logo-sub">Coiffure femme · Perpignan</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="active">Accueil</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/realisations">Réalisations</a></li>
        <li><a href="/tarifs">Tarifs</a></li>
        <li><a href="/a-propos">À Propos</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
        <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-rose">Réserver</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mob-menu" id="mob-menu">
      <a href="/">Accueil</a>
      <a href="/services">Services</a>
      <a href="/realisations">Réalisations</a>
      <a href="/tarifs">Tarifs</a>
      <a href="/a-propos">À Propos</a>
      <a href="/contact">Contact</a>
      <a href={client.reservationUrl} target="_blank" class="mob-cta">Réserver en ligne →</a>
    </div>
  </nav>

  <!-- ═══ HERO — Split asymétrique ═══ -->
  <section class="hero">
    <!-- Gauche — texte -->
    <div class="hero-left">
      <div class="hero-left-inner">

        <p class="hero-eyebrow silk">
          <span class="he-line"></span>
          {client.slogan}
        </p>

        <h1 class="hero-h1 serif silk d1">
          L'art de<br>
          <em>sublimer</em><br>
          vos cheveux.
        </h1>

        <p class="hero-sub silk d2">
          Salon de coiffure femme au cœur de Perpignan. Coloration, balayage,
          coupes tendance et soins capillaires premium depuis 2012.
        </p>

        <div class="hero-actions silk d3">
          <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-velvet btn-lg">
            Réserver en ligne
          </a>
          <a href="/services" class="btn btn-outline btn-lg">Nos prestations</a>
        </div>

        <!-- Signature confiance -->
        <div class="hero-trust silk d4">
          <div class="ht-stars">★★★★★</div>
          <div class="ht-txt">
            <strong class="serif">{client.stats[1].chiffre}+ clientes</strong>
            <span>· {client.stats[2].chiffre}% de satisfaction</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Droite — image avec cadre décalé -->
    <div class="hero-right">
      <div class="hero-img-frame">
        <div class="hif-inner iz">
          <img src={client.heroImage} alt={client.heroImageAlt} loading="eager" />
        </div>
        <!-- Cadre décoratif décalé -->
        <div class="hif-border"></div>
      </div>
      <!-- Badge flottant -->
      <div class="hero-badge serif silk d3">
        <span class="hb-num">{client.stats[0].chiffre}{client.stats[0].suffix}</span>
        <span class="hb-lbl">{client.stats[0].label}</span>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="sec" id="services">
    <div class="wrap">
      <div class="svc-head">
        <div>
          <div class="eyebrow silk">Nos prestations</div>
          <h2 class="h2 serif silk d1">
            Tout pour<br>
            <em style="font-style:italic">vos cheveux</em>
          </h2>
          <p class="lead silk d2" style="margin-top:.75rem">
            De la coupe quotidienne au balayage de rêve — chaque prestation
            est réalisée avec soin et précision par notre équipe certifiée.
          </p>
        </div>
        <a href="/services" class="btn btn-outline silk d1">Voir toutes nos prestations →</a>
      </div>

      <!-- 3 featured -->
      <div class="svc-grid">
        {featuredServices.map((s, i) => (
          <article class={`svc-card lift silk d${i+1}`}>
            <div class="svc-img iz">
              <img src={s.image} alt={s.titre} loading="lazy" />
              <div class="svc-overlay">
                <span class="svc-icon">{s.icone}</span>
              </div>
            </div>
            <div class="svc-body">
              <h3 class="serif svc-title">{s.titre}</h3>
              <p class="svc-desc">{s.description}</p>
              <div class="svc-tags">
                {s.tags.map(t => <span class="tag">{t}</span>)}
              </div>
              <a href="/services" class="svc-link serif">En savoir plus →</a>
            </div>
          </article>
        ))}
      </div>

      <!-- Prestations complémentaires -->
      <div class="extra-grid">
        {extraServices.map((s, i) => (
          <a href="/services" class={`extra-item silk d${i+1}`}>
            <span class="extra-icon">{s.icone}</span>
            <div>
              <strong class="serif">{s.titre}</strong>
              <p>{s.tags.join(' · ')}</p>
            </div>
            <span class="extra-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="sec-rose stats-sec">
    <div class="wrap stats-grid">
      {client.stats.map((s, i) => (
        <div class={`stat-item silk d${i+1}`}>
          <div class="stat-num serif">
            <span class="ctr" data-target={s.chiffre} data-suffix={s.suffix}>0</span>
          </div>
          <div class="stat-lbl">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ GALERIE APERÇU ═══ -->
  <section class="sec-alt" id="galerie">
    <div class="wrap">
      <div class="gal-head">
        <div>
          <div class="eyebrow silk">Notre galerie</div>
          <h2 class="h2 serif silk d1">
            Quelques<br>
            <em style="font-style:italic">réalisations récentes</em>
          </h2>
        </div>
        <a href="/realisations" class="btn btn-outline silk">Voir toute la galerie →</a>
      </div>
      <div class="gal-mosaic">
        {client.realisations.slice(0,4).map((r, i) => (
          <article class={`gal-card lift silk d${(i%2)+1}`} data-size={i===0?'big':'small'}>
            <div class="gal-img iz">
              <img src={r.image} alt={r.titre} loading="lazy" />
              <div class="gal-label">
                <span class="gl-cat">{r.categorie}</span>
              </div>
            </div>
            <div class="gal-body">
              <span class="gal-tech serif">{r.technique}</span>
              <h3 class="serif gal-title">{r.titre}</h3>
              <p>{r.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ENGAGEMENTS ═══ -->
  <section class="sec" id="engagements">
    <div class="wrap">
      <div class="sc">
        <div class="eyebrow silk">Notre promesse</div>
        <h2 class="h2 serif silk d1">
          Ce que nous vous<br>
          <em style="font-style:italic">garantissons</em>
        </h2>
      </div>
      <div class="eng-grid">
        {client.engagements.map((e, i) => (
          <div class={`eng-card silk d${i+1}`}>
            <div class="eng-icon">{e.icon}</div>
            <h3 class="serif eng-title">{e.titre}</h3>
            <p class="eng-desc">{e.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TÉMOIGNAGES ═══ -->
  <section class="sec-dark" id="temoignages">
    <div class="wrap">
      <div class="sc">
        <div class="eyebrow eyebrow-rose">Avis clientes</div>
        <h2 class="h2 h2-white serif silk d1">
          Elles nous font<br>
          <em style="font-style:italic;color:var(--rose-light)">confiance</em>
        </h2>
      </div>
      <div class="test-grid">
        {client.temoignages.map((t, i) => (
          <article class={`test-card silk d${i+1}`}>
            <div class="test-stars">★★★★★</div>
            <blockquote class="serif test-quote">"{t.texte}"</blockquote>
            <div class="test-footer">
              <div class="test-avatar serif">{t.nom.charAt(0)}</div>
              <div>
                <div class="test-nom serif">{t.nom}</div>
                <div class="test-type">{t.type}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA RÉSERVATION ═══ -->
  <section class="cta-sec">
    <div class="wrap cta-inner">
      <div class="silk">
        <div class="eyebrow">Prenez soin de vous</div>
        <h2 class="h2 serif">
          Votre prochain rendez-vous<br>
          <em style="font-style:italic">vous attend</em>
        </h2>
        <p class="lead" style="margin-top:.75rem">{client.horairesResume}</p>
      </div>
      <div class="cta-btns silk d2">
        <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-velvet btn-lg">
          Réserver en ligne →
        </a>
        <a href={client.telephoneLink} class="btn btn-outline btn-lg">
          📞 {client.telephone}
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="wrap">
      <div class="footer-grid">
        <div class="f-brand">
          <div class="f-logo-row">
            <div class="f-logo-mark">✂</div>
            <span class="f-logo-name serif">{client.nom}</span>
          </div>
          <p>{client.specialite}.<br/>{client.adresse}.</p>
          {socials.length > 0 && (
            <div class="soc-links">
              {socials.map(([k,v]) => (
                <a href={v} target="_blank" rel="noopener"
                   class="soc-link soc-dark" title={k}
                   set:html={socialIcons[k] || k} />
              ))}
            </div>
          )}
        </div>
        <div class="f-col">
          <h4>Navigation</h4>
          <ul>
            <li><a href="/">Accueil</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/realisations">Réalisations</a></li>
            <li><a href="/tarifs">Tarifs</a></li>
            <li><a href="/a-propos">À Propos</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="f-col">
          <h4>Prestations</h4>
          <ul>
            {client.services.map(s => <li><a href="/services">{s.titre}</a></li>)}
          </ul>
        </div>
        <div class="f-col">
          <h4>Contact</h4>
          <ul>
            <li><a href={client.telephoneLink}>{client.telephone}</a></li>
            <li><a href={`mailto:${client.email}`}>{client.email}</a></li>
            <li><span style="color:rgba(255,255,255,.2);font-size:12px">{client.adresse}</span></li>
            <li><a href={client.reservationUrl} target="_blank" rel="noopener" style="color:var(--rose-light)">Réserver en ligne</a></li>
          </ul>
        </div>
      </div>
      <div class="f-bottom">
        <p>© {new Date().getFullYear()} {client.nom} — {client.ville} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">
          Site par <strong>LORN Digital Studio</strong>
        </a>
      </div>
    </div>
  </footer>

</Layout>

<style>
/* ═══ HERO ═══ */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
  background: var(--bg-dark);
}

/* Gauche */
.hero-left {
  display: flex; align-items: center;
  padding: calc(var(--nav-h) + 4rem) clamp(2rem,5vw,5rem) 5rem;
}
.hero-left-inner { max-width: 500px; }

.hero-eyebrow {
  display: flex; align-items: center; gap: 14px;
  font-size: 11px; font-weight: 400; letter-spacing: .2em;
  text-transform: uppercase; color: rgba(255,255,255,.4);
  margin-bottom: 32px;
}
.he-line {
  display: block; width: 32px; height: 1px;
  background: var(--rose); flex-shrink: 0;
}

.hero-h1 {
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 600; line-height: 1.0;
  letter-spacing: -.02em; color: #fff;
  margin-bottom: 28px;
}
.hero-h1 em { font-style: italic; color: var(--rose-light); }

.hero-sub {
  font-size: .97rem; line-height: 1.85;
  color: rgba(255,255,255,.5); max-width: 420px;
  font-weight: 300; margin-bottom: 36px;
}
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }

.hero-trust { display: flex; align-items: center; gap: 14px; padding-top: 28px; border-top: 1px solid rgba(255,255,255,.07); }
.ht-stars { color: var(--blush); font-size: .9rem; letter-spacing: 2px; }
.ht-txt { font-size: 13px; color: rgba(255,255,255,.45); }
.ht-txt strong { color: rgba(255,255,255,.75); font-family: var(--font-serif); font-size: 1rem; }

/* Droite */
.hero-right {
  position: relative; display: flex;
  align-items: center; justify-content: center;
  padding: calc(var(--nav-h) + 2rem) 3rem 3rem;
}
.hero-img-frame { position: relative; width: 100%; max-width: 480px; }
.hif-inner {
  border-radius: var(--r-md); overflow: hidden;
  height: 580px; position: relative; z-index: 1;
}
.hif-inner img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
.hif-border {
  position: absolute; inset: 20px -20px -20px 20px;
  border: 1px solid rgba(212,165,165,.25);
  border-radius: var(--r-md); z-index: 0;
}

.hero-badge {
  position: absolute; bottom: 48px; left: 12px; z-index: 2;
  background: rgba(250,247,245,.97); backdrop-filter: blur(12px);
  border: 1px solid var(--border-warm);
  border-radius: var(--r-md); padding: 16px 22px;
  display: flex; flex-direction: column; gap: 2px;
  box-shadow: var(--shadow-md);
}
.hb-num { font-size: 1.8rem; font-weight: 600; color: var(--velvet); line-height: 1; }
.hb-lbl { font-size: 11px; color: var(--text-muted); letter-spacing: .06em; }

/* ═══ SERVICES ═══ */
.svc-head {
  display: flex; justify-content: space-between;
  align-items: flex-end; gap: 2rem; margin-bottom: 3rem; flex-wrap: wrap;
}
.svc-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 22px; margin-bottom: 16px;
}
.svc-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--r-md); overflow: hidden;
}
.svc-img { position: relative; height: 240px; }
.svc-img img { width: 100%; height: 100%; object-fit: cover; }
.svc-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(44,26,26,.55) 0%, transparent 55%);
  display: flex; align-items: flex-end; padding: 16px;
}
.svc-icon { font-size: 1.5rem; }
.svc-body { padding: 22px; }
.svc-title { font-size: 1.15rem; font-weight: 600; margin-bottom: 10px; letter-spacing: -.01em; }
.svc-desc { font-size: .85rem; color: var(--text-muted); line-height: 1.8; font-weight: 300; margin-bottom: 14px; }
.svc-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
.svc-link { font-family: var(--font-serif); font-size: .9rem; color: var(--blush); font-style: italic; transition: color .3s; }
.svc-link:hover { color: var(--velvet); }

.extra-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 1px; background: var(--border); border: 1px solid var(--border);
  border-radius: var(--r-md); overflow: hidden;
}
.extra-item {
  display: flex; align-items: center; gap: 14px;
  padding: 15px 18px; background: var(--bg-card);
  transition: background .3s; cursor: pointer;
}
.extra-item:hover { background: var(--rose-pale); }
.extra-icon { font-size: 1.3rem; flex-shrink: 0; }
.extra-item strong { display: block; font-family: var(--font-serif); font-size: .9rem; font-weight: 600; margin-bottom: 2px; }
.extra-item p { font-size: 11px; color: var(--text-muted); }
.extra-arrow { margin-left: auto; color: var(--text-soft); font-size: .9rem; transition: all .3s; flex-shrink: 0; }
.extra-item:hover .extra-arrow { color: var(--rose); transform: translateX(4px); }

/* ═══ STATS ═══ */
.stats-sec {}
.stats-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 0; border: 1px solid var(--border-warm);
  border-radius: var(--r-md); overflow: hidden;
}
.stat-item {
  text-align: center; padding: 3rem 2rem;
  border-right: 1px solid var(--border-warm);
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-size: 2.8rem; font-weight: 600; color: var(--velvet);
  line-height: 1; margin-bottom: 8px; letter-spacing: -.02em;
}
.stat-lbl { font-size: 12px; color: var(--text-muted); letter-spacing: .06em; font-weight: 400; }

/* ═══ GALERIE ═══ */
.gal-head {
  display: flex; justify-content: space-between;
  align-items: flex-end; gap: 2rem; margin-bottom: 2.5rem; flex-wrap: wrap;
}
.gal-mosaic {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 18px;
}
.gal-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--r-md); overflow: hidden;
}
.gal-card[data-size="big"] { grid-row: span 2; }
.gal-img { position: relative; height: 260px; }
.gal-card[data-size="big"] .gal-img { height: 100%; min-height: 400px; }
.gal-img img { width: 100%; height: 100%; object-fit: cover; }
.gal-label {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(44,26,26,.5) 0%, transparent 50%);
  display: flex; align-items: flex-end; padding: 14px;
}
.gl-cat {
  background: rgba(212,165,165,.9); color: var(--velvet);
  padding: 3px 11px; border-radius: var(--r-pill);
  font-size: 10px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
}
.gal-body { padding: 18px; }
.gal-tech { font-size: 11px; font-weight: 400; color: var(--blush); letter-spacing: .1em; text-transform: uppercase; display: block; margin-bottom: 6px; font-style: italic; }
.gal-title { font-size: .95rem; font-weight: 600; margin-bottom: 6px; }
.gal-body p { font-size: .82rem; color: var(--text-muted); line-height: 1.65; font-weight: 300; }

/* ═══ ENGAGEMENTS ═══ */
.eng-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-top: 3rem; }
.eng-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--r-md); padding: 28px 24px;
  border-top: 2px solid var(--rose-pale);
  transition: border-top-color .35s;
}
.eng-card:hover { border-top-color: var(--rose); }
.eng-icon { font-size: 1.6rem; margin-bottom: 14px; }
.eng-title { font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
