---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout
  title={`Réalisations — ${client.nom}`}
  description={`Galerie photos de colorations, balayages, coupes et soins réalisés au salon ${client.nom} à Perpignan (66).`}
>

<nav class="navbar solid" id="navbar">
  <div class="nav-wrap">
    <a href="/" class="nav-logo">
      <div class="nav-logo-mark">✂</div>
      <div class="nav-logo-text">
        <span class="nav-logo-name">{client.nom}</span>
        <span class="nav-logo-sub">Coiffure femme · Perpignan</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href="/">Accueil</a></li><li><a href="/services">Services</a></li>
      <li><a href="/realisations" class="active">Réalisations</a></li><li><a href="/tarifs">Tarifs</a></li>
      <li><a href="/a-propos">À Propos</a></li><li><a href="/contact">Contact</a></li>
    </ul>
    <div class="nav-cta">
      <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
      <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-rose">Réserver</a>
    </div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href="/">Accueil</a><a href="/services">Services</a><a href="/realisations">Réalisations</a>
    <a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a><a href="/contact">Contact</a>
    <a href={client.reservationUrl} target="_blank" class="mob-cta">Réserver en ligne →</a>
  </div>
</nav>

<div class="ph">
  <div class="wrap">
    <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Réalisations</span></nav>
    <div class="eyebrow eyebrow-white">Notre galerie</div>
    <h1 class="ph-title">
      Des cheveux<br>
      <em>transformés avec amour</em>
    </h1>
    <p class="ph-sub">Colorations, balayages, coupes, soins et coiffures événement — chaque photo est une vraie cliente du salon.</p>
  </div>
</div>

<section class="sec">
  <div class="wrap">

    <!-- Filtres -->
    <div class="filters silk">
      {client.realisationsCategories.map(cat => (
        <button class={`fbtn ${cat.id === 'all' ? 'active' : ''}`} data-filter={cat.id}>
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Grille -->
    <div class="real-grid" id="realGrid">
      {client.realisations.map((r, i) => (
        <article class={`real-card lift silk d${(i % 3) + 1}`} data-cat={r.categorie}>
          <div class="real-img iz">
            <img src={r.image} alt={r.titre} loading="lazy" />
            <div class="real-badge-wrap">
              <span class="real-cat">{r.categorie}</span>
            </div>
          </div>
          <div class="real-body">
            <span class="real-tech serif">{r.technique}</span>
            <h3 class="serif real-title">{r.titre}</h3>
            <p>{r.description}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Appel à l'action Instagram -->
    <div class="insta-cta silk">
      <div class="ic-left">
        <span class="ic-icon">📸</span>
        <div>
          <strong class="serif">Suivez nos créations sur Instagram</strong>
          <p>De nouvelles réalisations chaque semaine — couleurs, balayages, coupes tendance.</p>
        </div>
      </div>
      {client.reseaux.instagram && (
        <a href={client.reseaux.instagram} target="_blank" rel="noopener" class="btn btn-velvet">
          Nous suivre →
        </a>
      )}
    </div>
  </div>
</section>

<section class="sec-dark">
  <div class="wrap cta-dk">
    <div class="silk">
      <div class="eyebrow eyebrow-rose">Votre tour</div>
      <h2 class="h2 h2-white serif">
        Prête pour votre<br>
        <em style="font-style:italic;color:var(--rose-light)">nouvelle tête ?</em>
      </h2>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap" class="silk d2">
      <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-rose btn-lg">Réserver en ligne →</a>
      <a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="wrap">
    <div class="f-bottom" style="border-top:none;padding-top:0">
      <p>© {new Date().getFullYear()} {client.nom} — <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
      <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
    </div>
  </div>
</footer>
</Layout>

<script>
  document.querySelectorAll('.fbtn').forEach(btn => btn.addEventListener('click', () => {
    document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = (btn as HTMLElement).dataset.filter || 'all';
    document.querySelectorAll('[data-cat]').forEach(c => {
      (c as HTMLElement).style.display =
        f === 'all' || (c as HTMLElement).dataset.cat === f ? '' : 'none';
    });
  }));
</script>

<style>
.filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 2.5rem; }
.fbtn {
  padding: 9px 20px; border-radius: var(--r-pill);
  font-family: var(--font-body); font-size: 12px; font-weight: 400;
  border: 1.5px solid var(--border-warm); background: transparent;
  color: var(--text-muted); cursor: pointer; transition: all .3s;
  letter-spacing: .06em;
}
.fbtn:hover, .fbtn.active { background: var(--velvet); border-color: var(--velvet); color: #fff; }

.real-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 2.5rem; }
.real-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--r-md); overflow: hidden;
}
.real-img { position: relative; height: 300px; }
.real-img img { width: 100%; height: 100%; object-fit: cover; }
.real-badge-wrap {
  position: absolute; bottom: 12px; left: 12px;
}
.real-cat {
  background: rgba(212,165,165,.92); color: var(--velvet);
  padding: 4px 12px; border-radius: var(--r-pill);
  font-size: 10px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase;
}
.real-body { padding: 20px; }
.real-tech {
  display: block; font-size: 11px; font-style: italic;
  color: var(--blush); letter-spacing: .08em; margin-bottom: 6px;
}
.real-title { font-size: .95rem; font-weight: 600; margin-bottom: 6px; }
.real-body p { font-size: .82rem; color: var(--text-muted); line-height: 1.65; font-weight: 300; }

.insta-cta {
  display: flex; align-items: center; justify-content: space-between;
  gap: 2rem; flex-wrap: wrap;
  background: var(--rose-pale); border: 1px solid var(--border-warm);
  border-radius: var(--r-md); padding: 28px 32px;
}
.ic-left { display: flex; align-items: center; gap: 18px; flex: 1; min-width: 200px; }
.ic-icon { font-size: 2rem; flex-shrink: 0; }
.ic-left strong { display: block; font-family: var(--font-serif); font-size: 1rem; font-weight: 600; margin-bottom: 4px; }
.ic-left p { font-size: .85rem; color: var(--text-muted); font-weight: 300; }

.cta-dk { display: flex; justify-content: space-between; align-items: center; gap: 2rem; flex-wrap: wrap; }

@media (max-width: 1024px) { .real-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) { .real-grid { grid-template-columns: 1fr; } .cta-dk { flex-direction: column; } }
</style>
