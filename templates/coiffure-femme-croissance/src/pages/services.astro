---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout
  title={`Services — ${client.nom}`}
  description={`Coloration, balayage, coupe, soins kératine, chignons et extensions — toutes les prestations de ${client.nom} à Perpignan (66).`}
>

<!-- NAVBAR -->
<nav class="navbar solid" id="navbar">
  <div class="nav-wrap">
    <a href="/" class="nav-logo">
      <div class="nav-logo-mark">✂</div>
      <div class="nav-logo-text">
        <span class="nav-logo-name">{client.nom}</span>
        <span class="nav-logo-sub">Coiffure femme · Perpignan</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href="/">Accueil</a></li>
      <li><a href="/services" class="active">Services</a></li>
      <li><a href="/realisations">Réalisations</a></li>
      <li><a href="/tarifs">Tarifs</a></li>
      <li><a href="/a-propos">À Propos</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="nav-cta">
      <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
      <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-rose">Réserver</a>
    </div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href="/">Accueil</a><a href="/services">Services</a><a href="/realisations">Réalisations</a>
    <a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a><a href="/contact">Contact</a>
    <a href={client.reservationUrl} target="_blank" class="mob-cta">Réserver en ligne →</a>
  </div>
</nav>

<!-- PAGE HEADER -->
<div class="ph">
  <div class="wrap">
    <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Services</span></nav>
    <div class="eyebrow eyebrow-white">Nos prestations</div>
    <h1 class="ph-title">
      Toutes les techniques<br>
      <em>pour sublimer vos cheveux</em>
    </h1>
    <p class="ph-sub">De la couleur aux soins, chaque prestation est réalisée avec des produits professionnels et un savoir-faire certifié.</p>
  </div>
</div>

<!-- SERVICES ALTERNÉS -->
<section class="sec">
  <div class="wrap">
    {client.services.map((s, i) => (
      <article class={`srow ${i % 2 === 1 ? 'rev' : ''} silk`}>
        <div class="srow-img iz">
          <img src={s.image} alt={s.titre} loading="lazy" />
          <!-- numéro discret -->
          <span class="srow-num serif">0{i + 1}</span>
        </div>
        <div class="srow-body">
          <span class="srow-icon">{s.icone}</span>
          <h2 class="serif srow-title">{s.titre}</h2>
          <p class="srow-desc">{s.description}</p>
          <div class="tags-row" style="margin-bottom: 1.5rem">
            {s.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-velvet">
            Réserver ce soin →
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- PRODUITS -->
<section class="sec-rose">
  <div class="wrap produits-layout">
    <div class="silk">
      <div class="eyebrow">Nos marques</div>
      <h2 class="h2 serif">Produits professionnels<br><em style="font-style:italic">sélectionnés avec soin</em></h2>
      <p class="lead" style="margin-top: .8rem">
        Nous n'utilisons que des marques professionnelles testées et approuvées,
        pour un résultat durable et respectueux de la santé de votre cheveu.
      </p>
      <a href="/contact" class="btn btn-velvet" style="margin-top: 1.75rem">Nous contacter →</a>
    </div>
    <div class="produits-grid silk d2">
      {["L'Oréal Professionnel", "Redken", "Wella Professionals", "Great Lengths Extensions", "Kerastase Soin", "Olaplex"].map(p => (
        <div class="produit-chip">
          <span class="pc-icon">✦</span>
          <span>{p}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="sec">
  <div class="wrap faq-layout">
    <div class="silk">
      <div class="eyebrow">Questions fréquentes</div>
      <h2 class="h2 serif">
        Les bonnes réponses<br>
        <em style="font-style:italic">avant votre rendez-vous</em>
      </h2>
      <p class="lead" style="margin-top: .8rem">Une question ? Appelez-nous ou envoyez un message Instagram.</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:1.5rem">
        <a href={client.telephoneLink} class="btn btn-velvet">{client.telephone}</a>
        <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-outline">Réserver en ligne</a>
      </div>
    </div>
    <div class="faq-list silk d2">
      {client.faq.map((f, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="serif faq-q">
            {f.question}
            <span class="faq-plus">+</span>
          </summary>
          <p class="faq-a">{f.reponse}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="sec-dark">
  <div class="wrap cta-dk">
    <div class="silk">
      <h2 class="h2 h2-white serif">Prête pour votre transformation ?</h2>
      <p style="color:rgba(255,255,255,.4);margin-top:10px;font-weight:300">{client.horairesResume}</p>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap" class="silk d2">
      <a href={client.reservationUrl} target="_blank" rel="noopener" class="btn btn-rose btn-lg">Réserver en ligne →</a>
      <a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="wrap">
    <div class="f-bottom" style="border-top:none;padding-top:0">
      <p>© {new Date().getFullYear()} {client.nom} — <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
      <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
    </div>
  </div>
</footer>
</Layout>

<style>
.srow {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 72px; align-items: center;
  padding: 5rem 0; border-bottom: 1px solid var(--border);
}
.srow:last-child { border-bottom: none; }
.srow.rev { direction: rtl; }
.srow.rev > * { direction: ltr; }

.srow-img {
  position: relative; border-radius: var(--r-md);
  overflow: hidden; height: 420px;
}
.srow-img img { width: 100%; height: 100%; object-fit: cover; }
.srow-num {
  position: absolute; bottom: 14px; right: 18px;
  font-size: 5rem; font-weight: 600;
  color: rgba(255,255,255,.15); line-height: 1;
}
.srow-icon { font-size: 2rem; display: block; margin-bottom: 14px; }
.srow-title {
  font-size: 2rem; font-weight: 600; letter-spacing: -.02em;
  margin-bottom: 16px; line-height: 1.15;
}
.srow-desc {
  font-size: .93rem; color: var(--text-muted);
  line-height: 1.85; font-weight: 300; margin-bottom: 18px;
}
.tags-row { display: flex; flex-wrap: wrap; gap: 7px; }

.produits-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
.produits-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.produit-chip {
  display: flex; align-items: center; gap: 10px;
  background: #fff; border: 1px solid var(--border-warm);
  border-radius: var(--r); padding: 12px 16px;
  font-size: .88rem; color: var(--text-muted); font-weight: 300;
}
.pc-icon { color: var(--rose); font-size: .7rem; flex-shrink: 0; }

.faq-layout { display: grid; grid-template-columns: 360px 1fr; gap: 72px; align-items: start; }
.faq-list { display: flex; flex-direction: column; gap: 3px; }
.faq-item { border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.faq-q {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18px 22px; cursor: pointer; font-size: .97rem; font-weight: 500;
  list-style: none; gap: 14px;
}
.faq-q::-webkit-details-marker { display: none; }
.faq-q:hover { background: var(--rose-pale); }
.faq-plus { flex-shrink: 0; font-size: 1.4rem; font-weight: 300; color: var(--rose); transition: transform .3s ease; }
details[open] .faq-plus { transform: rotate(45deg); }
.faq-a { padding: 0 22px 18px; font-size: .88rem; color: var(--text-muted); line-height: 1.85; font-weight: 300; }

.cta-dk { display: flex; justify-content: space-between; align-items: center; gap: 2rem; flex-wrap: wrap; }

@media (max-width: 1024px) {
  .srow { grid-template-columns: 1fr; gap: 28px; }
  .srow.rev { direction: ltr; }
  .srow-img { height: 280px; }
  .produits-layout { grid-template-columns: 1fr; gap: 32px; }
  .faq-layout { grid-template-columns: 1fr; gap: 32px; }
}
@media (max-width: 768px) {
  .produits-grid { grid-template-columns: 1fr; }
  .cta-dk { flex-direction: column; }
}
</style>
