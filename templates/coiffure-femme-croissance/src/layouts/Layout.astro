---
import { client } from '../data/client';
interface Props { title?: string; description?: string; noIndex?: boolean; }
const { title = client.titreSEO, description = client.descriptionSEO, noIndex = false } = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  "name": client.nom,
  "description": client.descriptionSEO,
  "telephone": client.telephoneLink.replace("tel:", ""),
  "email": client.email,
  "url": client.canonicalUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": client.adresse.split(",")[0],
    "addressLocality": client.ville,
    "postalCode": client.codePostal,
    "addressCountry": "FR"
  },
  "openingHoursSpecification": client.horaires
    .filter(h => h.horaire !== "Fermé")
    .map(h => ({ "@type": "OpeningHoursSpecification", "name": h.jour, "description": h.horaire })),
  "priceRange": "€€",
  "image": client.heroImage,
  "sameAs": Object.values(client.reseaux).filter(Boolean),
};
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={client.motsCles.join(', ')} />
  <meta name="robots" content={noIndex ? "noindex,nofollow" : "index,follow"} />
  <link rel="canonical" href={client.canonicalUrl + Astro.url.pathname} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={client.ogImage} />
  <meta property="og:url" content={client.canonicalUrl + Astro.url.pathname} />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={client.ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
</head>
<body>
  <slot />

  {client.cookieConsent && (
    <div class="cookie-bar" id="cookieBar">
      <div class="cookie-inner">
        <p>Ce site utilise des cookies techniques. <a href="/mentions-legales">En savoir plus</a></p>
        <div class="cookie-btns">
          <button id="ckAccept">Accepter</button>
          <button id="ckRefuse" class="ghost">Refuser</button>
        </div>
      </div>
    </div>
  )}

  <style is:global>
    /* ══ RESET ══ */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-padding-top: 80px; }
    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    ::selection { background: rgba(212, 165, 165, .22); }

    /* ══ VARIABLES ══ */
    :root {
      /* Palette — Doux & féminin */
      --velvet:       #2C1A1A;  /* brun velours profond */
      --velvet-mid:   #3D2424;
      --velvet-90:    rgba(44,26,26,.92);
      --rose:         #D4A5A5;  /* rose poudré */
      --rose-light:   #E2BDBD;
      --rose-pale:    #F5EAEA;  /* fond rose très doux */
      --blush:        #C49A7A;  /* blush abricot */
      --blush-light:  #D4B090;
      --blush-glow:   rgba(196,154,122,.2);

      --bg:           #FAF7F5;  /* crème ivoire */
      --bg-alt:       #F3EDE8;  /* crème légèrement rosé */
      --bg-card:      #FFFFFF;
      --bg-dark:      #2C1A1A;

      --border:        rgba(44,26,26,.08);
      --border-warm:   rgba(212,165,165,.3);
      --border-strong: rgba(44,26,26,.16);

      --text:         #2C1A1A;
      --text-muted:   #7A5C5C;
      --text-soft:    rgba(122,92,92,.5);

      --font-serif:   'Cormorant Garamond', Georgia, serif;
      --font-body:    'DM Sans', system-ui, sans-serif;

      --r:       4px;
      --r-md:    12px;
      --r-lg:    24px;
      --r-pill:  9999px;
      --shadow:  0 4px 24px rgba(44,26,26,.06);
      --shadow-md: 0 8px 40px rgba(44,26,26,.10);
      --shadow-lg: 0 20px 60px rgba(44,26,26,.12);
      --nav-h:   76px;
      --wrap:    1200px;
    }

    /* ══ LAYOUT ══ */
    .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 clamp(1rem, 3vw, 2.5rem); }
    .sec      { padding: clamp(5rem, 9vw, 8rem) 0; }
    .sec-alt  { padding: clamp(5rem, 9vw, 8rem) 0; background: var(--bg-alt); }
    .sec-rose { padding: clamp(5rem, 9vw, 8rem) 0; background: var(--rose-pale); }
    .sec-dark { padding: clamp(5rem, 9vw, 8rem) 0; background: var(--bg-dark); }

    /* ══ TYPOGRAPHY ══ */
    .serif { font-family: var(--font-serif); }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 12px;
      font-family: var(--font-body); font-size: 11px; font-weight: 500;
      letter-spacing: .22em; text-transform: uppercase; color: var(--blush);
      margin-bottom: 10px;
    }
    .eyebrow::before {
      content: ''; width: 24px; height: 1px;
      background: var(--rose); border-radius: 2px; flex-shrink: 0;
    }
    .eyebrow-rose { color: var(--rose); }
    .eyebrow-rose::before { background: var(--rose); }
    .eyebrow-white { color: rgba(255,255,255,.5); }
    .eyebrow-white::before { background: rgba(255,255,255,.3); }

    .h2 {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 3.6vw, 3.2rem);
      font-weight: 600; line-height: 1.15; letter-spacing: -.01em;
      color: var(--text);
    }
    .h2-white { color: #fff; }
    .lead {
      font-size: .95rem; color: var(--text-muted);
      line-height: 1.85; max-width: 500px; font-weight: 300;
    }

    /* ══ BOUTONS ══ */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-body); font-size: 12.5px; font-weight: 500;
      padding: 13px 28px; border-radius: var(--r); border: 1.5px solid transparent;
      cursor: pointer; transition: all .3s ease; white-space: nowrap;
      letter-spacing: .04em;
    }
    .btn-velvet {
      background: var(--velvet); color: #fff; border-color: var(--velvet);
    }
    .btn-velvet:hover {
      background: var(--velvet-mid); transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(44,26,26,.22);
    }
    .btn-rose {
      background: var(--rose); color: var(--velvet); border-color: var(--rose);
    }
    .btn-rose:hover {
      background: var(--rose-light); border-color: var(--rose-light);
      transform: translateY(-2px); box-shadow: 0 8px 28px rgba(212,165,165,.4);
    }
    .btn-outline {
      background: transparent; color: var(--text); border-color: var(--border-strong);
    }
    .btn-outline:hover { border-color: var(--velvet); transform: translateY(-2px); }
    .btn-outline-white {
      background: transparent; color: #fff; border-color: rgba(255,255,255,.3);
    }
    .btn-outline-white:hover {
      border-color: rgba(255,255,255,.7); background: rgba(255,255,255,.06);
      transform: translateY(-2px);
    }
    .btn-lg { padding: 16px 36px; font-size: 13px; }

    /* ══ SOCIAL ══ */
    .soc-links { display: flex; gap: 8px; }
    .soc-link {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--bg-alt); border: 1px solid var(--border-warm);
      color: var(--text-muted); transition: all .3s;
    }
    .soc-link:hover { background: var(--rose); border-color: var(--rose); color: #fff; transform: translateY(-3px); }
    .soc-link svg { width: 15px; height: 15px; }
    .soc-dark { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.1); color: rgba(255,255,255,.4); }
    .soc-dark:hover { background: var(--rose); border-color: var(--rose); color: var(--velvet); }

    /* ══ TAGS ══ */
    .tag {
      background: var(--rose-pale); border: 1px solid var(--border-warm);
      padding: 4px 12px; border-radius: var(--r-pill);
      font-size: 11px; font-weight: 400; color: var(--text-muted); letter-spacing: .04em;
    }

    /* ══ SILK FADE — Animations subtiles ══
       Fade + glisse verticale légère (10px), durée longue (0.9s ease),
       délais progressifs pour effet de douceur. Rien de brusque. */
    .silk {
      opacity: 0;
      transform: translateY(12px);
      transition:
        opacity  .9s ease,
        transform .9s ease;
      will-change: transform, opacity;
    }
    .silk.appeared { opacity: 1; transform: translateY(0); }

    /* Délais — longs et progressifs */
    .d1 { transition-delay: .10s; }
    .d2 { transition-delay: .22s; }
    .d3 { transition-delay: .34s; }
    .d4 { transition-delay: .46s; }
    .d5 { transition-delay: .58s; }
    .d6 { transition-delay: .70s; }

    /* Hover lift — très doux */
    .lift {
      transition: transform .45s ease, box-shadow .45s ease;
    }
    .lift:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }

    /* Image zoom — subtil */
    .iz { overflow: hidden; }
    .iz img { transition: transform .8s ease; }
    .iz:hover img { transform: scale(1.04); }

    /* ══ NAVBAR ══ */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: var(--nav-h); transition: all .4s ease;
      background: rgba(250,247,245,.97);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 1px 0 var(--border);
    }
    .nav-wrap {
      display: flex; align-items: center; justify-content: space-between;
      height: 100%; padding: 0 clamp(1rem, 3vw, 2.5rem);
      max-width: var(--wrap); margin: 0 auto;
    }

    /* Logo — élégant */
    .nav-logo { display: flex; align-items: center; gap: 12px; }
    .nav-logo-mark {
      display: flex; align-items: center; justify-content: center;
      width: 34px; height: 34px;
      border: 1.5px solid var(--rose); border-radius: 50%;
      font-size: 14px; color: var(--velvet); flex-shrink: 0;
    }
    .nav-logo-mark.wh { border-color: rgba(255,255,255,.4); color: #fff; }
    .nav-logo-text { display: flex; flex-direction: column; gap: 0; }
    .nav-logo-name {
      font-family: var(--font-serif); font-size: 17px; font-weight: 600;
      color: var(--velvet); line-height: 1; letter-spacing: .01em;
    }
    .nav-logo-name.wh { color: #fff; }
    .nav-logo-sub {
      font-size: 10px; font-weight: 400; letter-spacing: .16em;
      text-transform: uppercase; color: var(--text-muted); line-height: 1.3;
    }
    .nav-logo-sub.wh { color: rgba(255,255,255,.4); }

    .nav-links { display: flex; align-items: center; gap: 30px; list-style: none; }
    .nav-links a {
      font-family: var(--font-body); font-size: 12.5px; font-weight: 400;
      letter-spacing: .06em; color: var(--text-muted);
      transition: color .3s; position: relative;
    }
    .nav-links a.wh { color: rgba(255,255,255,.6); }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1px; background: var(--rose);
      transition: width .35s ease;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--velvet); }
    .nav-links a.wh:hover, .nav-links a.wh.active { color: #fff; }
    .nav-links a:hover::after, .nav-links a.active::after { width: 100%; }

    .nav-cta { display: flex; align-items: center; gap: 14px; }
    .nav-tel { font-family: var(--font-body); font-size: 12.5px; font-weight: 400; color: var(--text-muted); letter-spacing: .04em; transition: color .3s; }
    .nav-tel:hover { color: var(--rose); }
    .nav-tel.wh { color: rgba(255,255,255,.5); }

    .burger { display: none; flex-direction: column; gap: 5px; padding: 8px; border: none; background: none; cursor: pointer; }
    .burger span { display: block; width: 22px; height: 1px; background: var(--velvet); transition: all .3s; }
    .burger.wh span { background: #fff; }
    .burger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .burger.open span:nth-child(2) { opacity: 0; }
    .burger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    .mob-menu {
      display: none; position: fixed; top: var(--nav-h); left: 0; right: 0; bottom: 0;
      background: var(--bg); padding: 48px 32px; flex-direction: column; z-index: 999;
    }
    .mob-menu.open { display: flex; }
    .mob-menu a {
      font-family: var(--font-serif); font-size: 2.2rem; font-weight: 600;
      color: var(--text-muted); padding: 14px 0; border-bottom: 1px solid var(--border);
      transition: color .3s;
    }
    .mob-menu a:hover { color: var(--velvet); }
    .mob-cta {
      margin-top: 32px; padding: 16px 24px; background: var(--velvet);
      color: #fff !important; border-radius: var(--r); text-align: center;
      font-family: var(--font-body) !important; font-size: 13px !important;
      border-bottom: none !important;
    }

    /* ══ PAGE HEADER ══ */
    .ph {
      padding: calc(var(--nav-h) + 4rem) 0 5rem;
      background: var(--bg-dark); position: relative; overflow: hidden;
    }
    /* Texture légère — cercles en arrière-plan */
    .ph::before {
      content: ''; position: absolute;
      width: 500px; height: 500px; border-radius: 50%;
      border: 1px solid rgba(212,165,165,.07);
      top: -200px; right: -100px; pointer-events: none;
    }
    .ph::after {
      content: ''; position: absolute;
      width: 300px; height: 300px; border-radius: 50%;
      border: 1px solid rgba(212,165,165,.05);
      bottom: 0; left: -80px; pointer-events: none;
    }
    .ph-bc {
      display: flex; gap: 8px; font-size: 11px; color: rgba(255,255,255,.25);
      margin-bottom: 16px; align-items: center; letter-spacing: .06em;
    }
    .ph-bc a { color: rgba(255,255,255,.25); transition: color .3s; }
    .ph-bc a:hover { color: var(--rose-light); }
    .ph-title {
      font-family: var(--font-serif);
      font-size: clamp(2.2rem, 4.5vw, 3.8rem);
      font-weight: 600; letter-spacing: -.01em; line-height: 1.12;
      color: #fff; margin: 12px 0 18px;
    }
    .ph-title em { font-style: italic; color: var(--rose-light); }
    .ph-sub {
      font-size: .93rem; color: rgba(255,255,255,.45);
      max-width: 480px; line-height: 1.8; font-weight: 300;
    }

    /* ══ SECTION CENTER ══ */
    .sc { text-align: center; margin-bottom: 3.5rem; }
    .sc .eyebrow { justify-content: center; }
    .sc .eyebrow::before { display: none; }

    /* ══ FOOTER ══ */
    .footer { background: var(--bg-dark); color: rgba(255,255,255,.55); padding: 64px 0 28px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .f-logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
    .f-logo-mark {
      width: 32px; height: 32px; border-radius: 50%;
      border: 1px solid rgba(212,165,165,.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; flex-shrink: 0;
    }
    .f-logo-name { font-family: var(--font-serif); font-size: 1rem; font-weight: 600; color: #fff; }
    .f-brand p { font-size: 12.5px; line-height: 1.85; color: rgba(255,255,255,.3); margin-bottom: 18px; }
    .f-col h4 {
      font-size: 10px; font-weight: 500; letter-spacing: .2em;
      text-transform: uppercase; color: rgba(255,255,255,.22); margin-bottom: 16px;
    }
    .f-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .f-col ul li a { font-size: 12.5px; color: rgba(255,255,255,.38); transition: color .3s; }
    .f-col ul li a:hover { color: var(--rose-light); }
    .f-bottom {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 24px; border-top: 1px solid rgba(255,255,255,.06);
      flex-wrap: wrap; gap: 12px;
    }
    .f-bottom p { font-size: 11.5px; color: rgba(255,255,255,.18); }
    .lorn-badge {
      font-size: 11px; color: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.07); padding: 5px 14px;
      border-radius: var(--r-pill); transition: all .3s;
    }
    .lorn-badge:hover { color: var(--rose-light); border-color: rgba(212,165,165,.3); }

    /* ══ COOKIE ══ */
    .cookie-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      background: var(--velvet); transition: transform .5s ease;
    }
    .cookie-bar.hidden { transform: translateY(120%); }
    .cookie-inner {
      max-width: var(--wrap); margin: 0 auto;
      padding: 14px clamp(1rem, 3vw, 2.5rem);
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
    }
    .cookie-inner p { font-size: 12.5px; color: rgba(255,255,255,.55); flex: 1; min-width: 200px; }
    .cookie-inner a { color: var(--rose-light); text-decoration: underline; }
    .cookie-btns { display: flex; gap: 8px; }
    .cookie-btns button {
      padding: 8px 20px; border-radius: var(--r-pill);
      font-family: var(--font-body); font-size: 12.5px; cursor: pointer; border: none;
    }
    .cookie-btns button:first-child { background: var(--rose); color: var(--velvet); font-weight: 500; }
    .cookie-btns button.ghost {
      background: transparent; border: 1px solid rgba(255,255,255,.18);
      color: rgba(255,255,255,.38);
    }

    /* ══ RESPONSIVE ══ */
    @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; } }
    @media (max-width: 768px) {
      .nav-links, .nav-tel { display: none !important; }
      .burger { display: flex !important; }
      .footer-grid { grid-template-columns: 1fr; gap: 24px; }
      .f-bottom { flex-direction: column; align-items: flex-start; }
    }
    @media (prefers-reduced-motion: reduce) {
      .silk { opacity: 1 !important; transform: none !important; transition: none !important; }
    }
  </style>

  <script>
    // Silk Fade — observer (seuil bas pour déclencher tôt et doucement)
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) e.target.classList.add('appeared');
      });
    }, { threshold: .06, rootMargin: '0px 0px -20px 0px' });
    document.querySelectorAll('.silk').forEach(el => obs.observe(el));

    // Burger
    const burger = document.getElementById('burger');
    const mob = document.getElementById('mob-menu');
    burger?.addEventListener('click', () => {
      burger.classList.toggle('open');
      mob?.classList.toggle('open');
      document.body.style.overflow = mob?.classList.contains('open') ? 'hidden' : '';
    });
    mob?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      burger?.classList.remove('open'); mob?.classList.remove('open');
      document.body.style.overflow = '';
    }));

    // Cookie
    const cb = document.getElementById('cookieBar');
    if (cb && localStorage.getItem('cookies-choice')) cb.classList.add('hidden');
    document.getElementById('ckAccept')?.addEventListener('click', () => {
      localStorage.setItem('cookies-choice', 'accepted'); cb?.classList.add('hidden');
    });
    document.getElementById('ckRefuse')?.addEventListener('click', () => {
      localStorage.setItem('cookies-choice', 'refused'); cb?.classList.add('hidden');
    });

    // Counters
    const cobs = new IntersectionObserver(entries => {
      entries.forEach(el => {
        if (!el.isIntersecting || el.target.classList.contains('done')) return;
        el.target.classList.add('done');
        const tgt = parseFloat((el.target as HTMLElement).dataset.target || '0');
        const sfx = (el.target as HTMLElement).dataset.suffix || '';
        const dur = 1600; const t0 = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - t0) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.target.textContent = (Number.isInteger(tgt) ? Math.round(tgt * eased) : (tgt * eased).toFixed(0)) + sfx;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: .5 });
    document.querySelectorAll('.ctr').forEach(el => cobs.observe(el));
  </script>
</body>
</html>
