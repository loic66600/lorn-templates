---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`À Propos — ${client.nom}`} description={`${client.apropos.sousTitre} — électricien certifié Qualifelec à Perpignan depuis 2004. Équipe de 4 compagnons, pas de sous-traitance.`}>

<nav class="navbar scrolled" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo"><div class="nav-logo-bolt">⚡</div><div class="nav-logo-text"><span class="nav-logo-name">{client.nom}</span><span class="nav-logo-sub">{client.metier}</span></div></a>
    <ul class="nav-links">
      <li><a href="/">Accueil</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/realisations">Réalisations</a></li>
      <li class="nav-dropdown"><button class="nav-dd-toggle">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href="/tarifs">Tarifs</a><a href="/a-propos" class="active">À Propos</a></div></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="nav-cta"><a href={client.telephoneLink} class="nav-tel">{client.telephone}</a><a href="/contact" class="btn btn-accent">Devis gratuit</a></div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href="/">Accueil</a><a href="/services">Services</a><a href="/realisations">Réalisations</a>
    <a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a><a href="/contact">Contact</a>
    <a href="/contact" class="mob-cta">Devis gratuit →</a>
  </div>
</nav>

<!-- Header dark + stats -->
<header class="ap-header section-dark">
  <div class="wrap ap-header-inner">
    <div class="volt">
      <nav class="ph-bc ph-bc-dark"><a href="/">Accueil</a><span>›</span><span>À Propos</span></nav>
      <div class="eyebrow" style="color:var(--accent)">{client.apropos.sousTitre}</div>
      <h1 class="disp ap-title">{client.apropos.titre}</h1>
      <p class="ap-sub">{client.apropos.paragraphe1}</p>
    </div>
    <div class="ap-stats volt-r">
      {client.stats.map(s => (
        <div class="ap-stat">
          <div class="disp ap-stat-num"><span class="ctr" data-target={s.chiffre} data-suffix={s.suffix}>0</span></div>
          <div class="ap-stat-lbl">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</header>

<!-- Histoire + image + certifs -->
<section class="section">
  <div class="wrap story-grid">
    <div class="story-left volt">
      <div class="story-img iz">
        <img src={client.apropos.image} alt={client.apropos.imageAlt} loading="lazy" />
      </div>
      <div class="certs-panel">
        <h3 class="disp certs-h">Certifications & Habilitations</h3>
        {client.apropos.certifications.map(c => (
          <div class="cert-row"><span class="cert-bolt">⚡</span><span>{c}</span></div>
        ))}
      </div>
    </div>
    <div class="story-right volt-r">
      <div class="eyebrow">Notre parcours</div>
      <h2 class="h2">{client.nom}</h2>
      <p class="story-p">{client.apropos.paragraphe1}</p>
      <p class="story-p">{client.apropos.paragraphe2}</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:1.75rem">
        <a href="/contact" class="btn btn-dark">Demander un devis →</a>
        <a href={client.telephoneLink} class="btn btn-outline">{client.telephone}</a>
      </div>
    </div>
  </div>
</section>

<!-- Valeurs -->
<section class="section-alt">
  <div class="wrap">
    <div class="sc"><div class="eyebrow volt">Ce qui nous guide</div><h2 class="h2 volt d1">Nos valeurs</h2></div>
    <div class="val-grid">
      {client.apropos.valeurs.map((v, i) => (
        <div class={`val-card lift volt-up d${i+1}`}>
          <div class="val-num disp">0{i+1}</div>
          <div class="val-icon">{v.icone}</div>
          <h3 class="disp val-title">{v.titre}</h3>
          <p class="val-desc">{v.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Zones -->
<section class="section">
  <div class="wrap">
    <div class="eyebrow volt">Où nous intervenons</div>
    <h2 class="h2 volt d1">Tout le département 66</h2>
    <p class="lead volt d2" style="margin-top:.5rem">{client.rayonKm} km autour de Perpignan — déplacement gratuit pour le devis.</p>
    <div class="zone-tags" style="margin-top:1.5rem">
      {client.zones.map((z, i) => <span class={`tag volt-up d${(i%4)+1}`}>{z}</span>)}
    </div>
  </div>
</section>

<section class="section-dark">
  <div class="wrap cta-dk">
    <div class="volt"><h2 class="h2 h2-white">Travaillons ensemble</h2><p style="color:rgba(255,255,255,.45);margin-top:10px">Diagnostic gratuit · devis 24h · Consuel remis</p></div>
    <div style="display:flex;gap:12px;flex-wrap:wrap" class="volt d1"><a href="/contact" class="btn btn-accent btn-lg">Devis gratuit →</a><a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a></div>
  </div>
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0"><p>© {new Date().getFullYear()} {client.nom} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p><a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a></div></div></footer>
</Layout>

<style>
.ap-header{padding:calc(var(--nav-h) + 3.5rem) 0 4rem;}
.ap-header-inner{display:grid;grid-template-columns:1fr 300px;gap:64px;align-items:center;}
.ph-bc-dark{display:flex;gap:8px;font-size:12px;color:rgba(255,255,255,.28);margin-bottom:14px;align-items:center;}
.ph-bc-dark a{color:rgba(255,255,255,.28);}
.ap-title{font-size:clamp(2rem,4vw,3rem);font-weight:700;letter-spacing:-.04em;color:#fff;margin:10px 0 16px;line-height:1.1;}
.ap-sub{font-size:.92rem;color:rgba(255,255,255,.45);line-height:1.8;max-width:480px;}
.ap-stats{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.07);border-radius:var(--r-md);overflow:hidden;}
.ap-stat{background:rgba(255,255,255,.03);padding:18px;}
.ap-stat-num{font-size:1.7rem;font-weight:700;color:var(--accent);line-height:1;}
.ap-stat-lbl{font-size:11px;color:rgba(255,255,255,.35);margin-top:4px;}
.story-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
.story-img{border-radius:var(--r-md);overflow:hidden;height:400px;margin-bottom:18px;}
.story-img img{width:100%;height:100%;object-fit:cover;}
.certs-panel{background:var(--bg-alt);border:1px solid var(--border);border-radius:var(--r-md);padding:20px;}
.certs-h{font-size:.78rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:12px;}
.cert-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border);font-size:.86rem;}
.cert-row:last-child{border-bottom:none;}
.cert-bolt{color:var(--accent);}
.story-p{font-size:.93rem;color:var(--text-muted);line-height:1.85;margin-bottom:.9rem;}
.val-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.val-card{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r-md);padding:24px;position:relative;overflow:hidden;}
.val-card:hover{border-color:var(--accent);}
.val-num{position:absolute;top:10px;right:14px;font-size:2.8rem;font-weight:700;color:var(--bg-alt);line-height:1;}
.val-icon{font-size:1.6rem;margin-bottom:10px;}
.val-title{font-size:.95rem;font-weight:700;margin-bottom:7px;}
.val-desc{font-size:.83rem;color:var(--text-muted);line-height:1.7;}
.zone-tags{display:flex;flex-wrap:wrap;gap:7px;}
.cta-dk{display:flex;justify-content:space-between;align-items:center;gap:2rem;flex-wrap:wrap;}
@media(max-width:1024px){.ap-header-inner{grid-template-columns:1fr;}.ap-stats{grid-template-columns:repeat(4,1fr);}.story-grid{grid-template-columns:1fr;gap:36px;}.val-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:768px){.ap-stats{grid-template-columns:repeat(2,1fr);}.val-grid{grid-template-columns:1fr;}.cta-dk{flex-direction:column;}}
</style>
