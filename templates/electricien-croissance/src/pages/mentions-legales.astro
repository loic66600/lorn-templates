---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout title={`Mentions légales — ${client.nom}`} description={`Mentions légales et politique de confidentialité de ${client.nom}.`} noIndex={true}>

<nav class="navbar scrolled" id="navbar">
  <div class="nav-inner">
    <a href={import.meta.env.BASE_URL} class="nav-logo"><div class="nav-logo-bolt">⚡</div><div class="nav-logo-text"><span class="nav-logo-name">{client.nom}</span><span class="nav-logo-sub">{client.metier}</span></div></a>
    <ul class="nav-links"><li><a href={import.meta.env.BASE_URL}>Accueil</a></li><li><a href={`${base}/services`}>Services</a></li><li><a href={`${base}/contact`}>Contact</a></li></ul>
    <div class="nav-cta"><a href={client.telephoneLink} class="nav-tel">{client.telephone}</a></div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu"><a href={import.meta.env.BASE_URL}>Accueil</a><a href={`${base}/services`}>Services</a><a href={`${base}/contact`}>Contact</a></div>
</nav>

<section class="legal-wrap">
  <div class="wrap legal-container">
    <nav class="ph-bc ph-bc-light"><a href={import.meta.env.BASE_URL}>Accueil</a><span>›</span><span>Mentions légales</span></nav>
    <h1 class="disp legal-title">Mentions légales</h1>
    <p class="legal-date">Dernière mise à jour : {new Date().toLocaleDateString('fr-FR',{year:'numeric',month:'long',day:'numeric'})}</p>

    <div class="legal-blocks">

      <div class="lb">
        <h2>1. Éditeur du site</h2>
        <p><strong>{client.responsable}</strong><br/>Entreprise individuelle · SIRET : {client.siret}<br/>
        Adresse : {client.adresse}<br/>
        Téléphone : <a href={client.telephoneLink}>{client.telephone}</a><br/>
        Email : <a href={`mailto:${client.email}`}>{client.email}</a></p>
        <p>Activité principale : {client.specialite}</p>
      </div>

      <div class="lb">
        <h2>2. Hébergement</h2>
        <p>{client.hebergeur} — <a href="https://www.netlify.com" target="_blank" rel="noopener">www.netlify.com</a></p>
      </div>

      <div class="lb">
        <h2>3. Conception & développement</h2>
        <p>Ce site a été conçu et développé par <strong>LORN Digital Studio</strong>.<br/>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener">vitemonsite-artisan.fr</a></p>
      </div>

      <div class="lb">
        <h2>4. Propriété intellectuelle</h2>
        <p>L'ensemble du contenu de ce site (textes, images, design, structure) est la propriété de {client.nom} ou de ses partenaires. Toute reproduction sans autorisation écrite préalable est interdite (art. L.335-2 CPI).</p>
        <p>Les photographies proviennent de Unsplash.com (licence Unsplash, usage commercial libre).</p>
      </div>

      <div class="lb">
        <h2>5. Protection des données (RGPD)</h2>
        <h3>Données collectées</h3>
        <p>Via le formulaire de contact : nom, téléphone, email, commune, type de travaux, type de logement, message. Ces données sont utilisées exclusivement pour répondre à votre demande de devis.</p>
        <h3>Base légale</h3>
        <p>Traitement fondé sur votre consentement (art. 6.1.a RGPD) et sur l'intérêt légitime de {client.nom} (art. 6.1.f RGPD).</p>
        <h3>Durée de conservation</h3>
        <p>3 ans à compter de votre dernière interaction (recommandation CNIL).</p>
        <h3>Vos droits</h3>
        <p>Droits d'accès, rectification, suppression, limitation, portabilité et opposition. Exercez-les par email : <a href={`mailto:${client.email}`}>{client.email}</a>. Réclamation possible auprès de la <a href="https://www.cnil.fr" target="_blank" rel="noopener">CNIL</a>.</p>
        <h3>Prestataire de formulaire</h3>
        <p>Les données du formulaire sont transmises via <strong>Web3Forms</strong> (web3forms.com), service conforme RGPD. Aucune donnée n'est vendue à des tiers.</p>
      </div>

      <div class="lb">
        <h2>6. Cookies</h2>
        <p>Ce site utilise uniquement des cookies techniques strictement nécessaires (mémorisation du choix de la bannière cookies). Aucun cookie publicitaire ou traceur tiers n'est utilisé.</p>
      </div>

      <div class="lb">
        <h2>7. Droit applicable</h2>
        <p>Le présent site est soumis au droit français. En cas de litige, les tribunaux français sont compétents.</p>
      </div>
    </div>

    <a href={import.meta.env.BASE_URL} class="btn btn-outline" style="margin-top:2rem">← Retour à l'accueil</a>
  </div>
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0"><p>© {new Date().getFullYear()} {client.nom}</p><a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a></div></div></footer>
</Layout>

<style>
.legal-wrap{padding:calc(var(--nav-h) + 4rem) 0 5rem;}
.legal-container{max-width:720px;}
.ph-bc-light{display:flex;gap:8px;font-size:12px;color:var(--text-muted);margin-bottom:18px;align-items:center;}
.ph-bc-light a{color:var(--text-muted);}
.legal-title{font-size:2.4rem;font-weight:700;letter-spacing:-.04em;margin-bottom:6px;}
.legal-date{font-size:13px;color:var(--text-muted);margin-bottom:3rem;}
.legal-blocks{display:flex;flex-direction:column;}
.lb{padding:1.75rem 0;border-bottom:1px solid var(--border);}
.lb:last-child{border-bottom:none;}
.lb h2{font-family:var(--font-disp);font-size:1.05rem;font-weight:700;margin-bottom:.9rem;}
.lb h3{font-family:var(--font-disp);font-size:.9rem;font-weight:700;margin:.9rem 0 .4rem;}
.lb p{font-size:.88rem;color:var(--text-muted);line-height:1.85;margin-bottom:.6rem;}
.lb p:last-child{margin-bottom:0;}
.lb a{color:var(--accent);text-decoration:underline;text-underline-offset:3px;}
.lb strong{color:var(--text);}
</style>
