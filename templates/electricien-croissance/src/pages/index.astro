---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
const socials = Object.entries(client.reseaux).filter(([_,v]) => v);
const socialIcons: Record<string,string> = {
  facebook: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>',
  instagram:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>',
  linkedin: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>',
  youtube:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>',
  tiktok:   '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52V6.83a4.84 4.84 0 01-1-.14z"/></svg>',
  twitter:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
};

const featuredServices = client.services.filter(s => s.featured);
const smallServices    = client.services.filter(s => !s.featured);
---

<Layout>

  <!-- ═══ URGENCE BAR ═══ -->
  {client.urgence && (
    <div class="urg-bar" id="urgBar">
      ⚡ {client.urgenceTexte} —
      <a href={client.urgenceTelLink}>{client.urgenceTel}</a>
    </div>
  )}

  <!-- ═══ NAVBAR ═══ -->
  <nav class="navbar dark-nav with-urg-bar" id="navbar">
    <div class="nav-inner">
      <a href={import.meta.env.BASE_URL} class="nav-logo">
        <div class="nav-logo-bolt">⚡</div>
        <div class="nav-logo-text">
          <span class="nav-logo-name white">{client.nom}</span>
          <span class="nav-logo-sub white">{client.metier}</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href={import.meta.env.BASE_URL} class="active wh">Accueil</a></li>
        <li><a href={`${base}/services`} class="wh">Services</a></li>
        <li><a href={`${base}/realisations`} class="wh">Réalisations</a></li>
        <li class="nav-dropdown"><button class="nav-dd-toggle wh">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href={`${base}/tarifs`}>Tarifs</a><a href={`${base}/a-propos`}>À Propos</a></div></li>
        <li><a href={`${base}/contact`} class="wh">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel wh">{client.telephone}</a>
        <a href={`${base}/contact`} class="btn btn-accent">Devis gratuit</a>
      </div>
      <button class="burger wh" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
    <div class="mob-menu" id="mob-menu">
      <a href={import.meta.env.BASE_URL}>Accueil</a>
      <a href={`${base}/services`}>Services</a>
      <a href={`${base}/realisations`}>Réalisations</a>
      <a href={`${base}/tarifs`}>Tarifs</a>
      <a href={`${base}/a-propos`}>À Propos</a>
      <a href={`${base}/contact`}>Contact</a>
      <a href={`${base}/contact`} class="mob-cta">Devis gratuit →</a>
    </div>
  </nav>

  <!-- ═══ HERO SPLIT ═══ -->
  <section class="hero">
    <!-- Gauche — texte sur fond noir -->
    <div class="hero-left">
      <div class="hero-left-inner">
        <div class="hero-badges volt">
          <span class="hb"><span class="hb-dot"></span>Qualifelec · RGE · IRVE</span>
          <span class="hb hb-urgence">⚡ Urgence 24h/7j</span>
        </div>

        <h1 class="hero-h1 volt d1">
          <span class="h1-top">Électricien</span>
          <span class="h1-mid">Perpignan</span>
          <span class="h1-bot">& tout le 66</span>
        </h1>

        <p class="hero-p volt d2">
          Installation, mise aux normes, domotique, borne IRVE, solaire.
          Devis gratuit sous <strong>24h</strong> · Intervention urgence <strong>sous 2h</strong>.
        </p>

        <div class="hero-cta volt d3">
          <a href={`${base}/contact`} class="btn btn-accent btn-lg">Devis gratuit →</a>
          <a href={client.urgenceTelLink} class="btn btn-outline-white btn-lg">⚡ {client.urgenceTel}</a>
        </div>

        <div class="hero-certs volt d4">
          {client.apropos.certifications.map(c => (
            <span class="cert-chip">✓ {c}</span>
          ))}
        </div>

        <!-- Stats inline -->
        <div class="hero-stats volt d5">
          {client.stats.map(s => (
            <div class="hs">
              <div class="hs-num disp">
                <span class="ctr" data-target={s.chiffre} data-suffix={s.suffix}>0</span>
              </div>
              <div class="hs-lbl">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Droite — image avec barre diagonale accent -->
    <div class="hero-right">
      <div class="hero-img-wrap">
        <img src={client.heroImage} alt={client.heroImageAlt} loading="eager" />
        <div class="hero-diag"></div>
      </div>
      <!-- Floating card -->
      <div class="hero-float volt-r">
        <span class="hero-float-icon">🏆</span>
        <div>
          <strong class="disp">{client.temoignages.length * 60}+ avis 5★</strong>
          <span>sur Google</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BANDE URGENCE ═══ -->
  <section class="urg-band">
    <div class="wrap urg-band-inner">
      <div class="urg-band-txt volt">
        <span class="urg-icon">⚡</span>
        <div>
          <h3 class="disp">Panne électrique ? Disjoncteur qui saute ?</h3>
          <p>Électricien disponible <strong>24h/24 · 7j/7</strong> — intervention sous 2h sur Perpignan et le 66</p>
        </div>
      </div>
      <div class="urg-band-cta volt-r">
        <a href={client.urgenceTelLink} class="btn btn-accent btn-lg">{client.urgenceTel} →</a>
        <p class="urg-note">Court-circuit · Panne totale · Choc électrique</p>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="section" id="services">
    <div class="wrap">
      <div class="svc-head">
        <div>
          <div class="eyebrow volt">Nos prestations</div>
          <h2 class="h2 volt d1">Installation, domotique<br>& dépannage électrique</h2>
          <p class="lead volt d2">Tous vos travaux électriques réalisés par un électricien certifié Qualifelec, avec remise du Consuel.</p>
        </div>
        <a href={`${base}/services`} class="btn btn-outline volt d1">Voir tous nos services →</a>
      </div>

      <!-- 2 services vedettes -->
      <div class="svc-featured-grid">
        {featuredServices.map((s, i) => (
          <article class={`svc-feat-card lift volt d${i+1}`}>
            <div class="sfc-img iz">
              <img src={s.image} alt={s.titre} loading="lazy" />
              <div class="sfc-num disp">0{i+1}</div>
            </div>
            <div class="sfc-body">
              <span class="sfc-icon">{s.icone}</span>
              <h3 class="disp sfc-title">{s.titre}</h3>
              <p class="sfc-desc">{s.description}</p>
              <div class="tags-row">
                {s.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Autres services en grille mini -->
      <div class="svc-mini-grid">
        {smallServices.map((s, i) => (
          <a href={`${base}/services`} class={`svc-mini-card lift volt-up d${i+1}`}>
            <div class="smc-icon-wrap">{s.icone}</div>
            <div class="smc-body">
              <strong class="disp">{s.titre}</strong>
              <p>{s.tags.join(' · ')}</p>
            </div>
            <span class="smc-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PROCESSUS ═══ -->
  <section class="section-alt" id="processus">
    <div class="wrap">
      <div class="sc">
        <div class="eyebrow volt">Comment ça marche</div>
        <h2 class="h2 volt d1">Simple, rapide, sans surprise</h2>
      </div>
      <div class="proc-grid">
        {client.processus.map((p, i) => (
          <div class={`proc-card volt-up d${i+1}`}>
            <div class="proc-num disp">{p.num}</div>
            <h3 class="proc-title disp">{p.titre}</h3>
            <p class="proc-desc">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ RÉALISATIONS APERÇU ═══ -->
  <section class="section" id="realisations">
    <div class="wrap">
      <div class="rh">
        <div>
          <div class="eyebrow volt">Chantiers récents</div>
          <h2 class="h2 volt d1">Quelques réalisations</h2>
        </div>
        <a href={`${base}/realisations`} class="btn btn-outline volt">Tout voir →</a>
      </div>
      <div class="real-grid">
        {client.realisations.slice(0,3).map((r, i) => (
          <article class={`real-card lift volt-up d${i+1}`}>
            <div class="rc-img iz">
              <img src={r.image} alt={r.titre} loading="lazy" />
              <span class="rc-cat">{r.categorie}</span>
            </div>
            <div class="rc-body">
              <div class="rc-meta disp">
                <span>📍 {r.lieu}</span>
                <span>· {r.annee}</span>
                <span class="rc-detail">· {r.detail}</span>
              </div>
              <h3 class="disp rc-title">{r.titre}</h3>
              <p>{r.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TÉMOIGNAGES ═══ -->
  <section class="section-dark" id="temoignages">
    <div class="wrap">
      <div class="sc">
        <div class="eyebrow" style="color:var(--accent)">Avis clients vérifiés</div>
        <h2 class="h2 h2-white volt d1">Ils nous font confiance<br>dans tout le 66</h2>
        <div class="stars-row volt d2">
          <span class="stars-note disp">5,0</span>
          <div class="stars-icons">★★★★★</div>
          <span class="stars-lbl">· {client.temoignages.length * 60}+ avis Google</span>
        </div>
      </div>
      <div class="test-grid">
        {client.temoignages.map((t, i) => (
          <article class={`test-card volt-up d${i+1}`}>
            <div class="tc-top">
              <div class="tc-avatar disp">{t.nom.charAt(0)}</div>
              <div>
                <div class="tc-nom disp">{t.nom}</div>
                <div class="tc-type">{t.type} · {t.ville}</div>
              </div>
              <div class="tc-stars">{"★".repeat(t.note)}</div>
            </div>
            <blockquote class="tc-txt">"{t.texte}"</blockquote>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ZONES + CERTIFICATIONS ═══ -->
  <section class="section-alt" id="zones">
    <div class="wrap zones-split">
      <div class="zones-left volt">
        <div class="eyebrow">Zone d'intervention</div>
        <h2 class="h2">{client.rayonKm} km autour<br>de Perpignan</h2>
        <p class="lead" style="margin-top:.75rem">Pyrénées-Orientales (66) — de la Côte Vermeille aux Pyrénées. Déplacement gratuit pour le devis.</p>
        <div class="zone-tags" style="margin-top:1.5rem">
          {client.zones.map(z => <span class="tag">{z}</span>)}
        </div>
        <a href={`${base}/contact`} class="btn btn-dark" style="margin-top:1.75rem">Vérifier ma zone →</a>
      </div>
      <div class="zones-right volt-r">
        <div class="certs-box">
          <h3 class="disp certs-title">Certifications</h3>
          {client.apropos.certifications.map(c => (
            <div class="cert-row">
              <span class="cert-ck">⚡</span>
              <span>{c}</span>
            </div>
          ))}
        </div>
        <div class="valeurs-mini">
          {client.apropos.valeurs.map((v, i) => (
            <div class={`vm lift volt-up d${i+1}`}>
              <span class="vm-icon">{v.icone}</span>
              <div>
                <strong class="disp">{v.titre}</strong>
                <p>{v.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA DEVIS ═══ -->
  <section class="cta-section section">
    <div class="wrap cta-inner">
      <div class="volt">
        <div class="eyebrow">Sans engagement</div>
        <h2 class="h2">Votre devis en 24h</h2>
        <p class="lead" style="margin-top:.5rem">Diagnostic gratuit sur Perpignan et tout le 66.</p>
      </div>
      <div class="cta-btns volt d1">
        <a href={`${base}/contact`} class="btn btn-accent btn-lg">Demander un devis →</a>
        <a href={client.telephoneLink} class="btn btn-outline btn-lg">📞 {client.telephone}</a>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="wrap">
      <div class="footer-grid">
        <div class="f-brand">
          <div class="f-brand-row">
            <div class="f-brand-bolt">⚡</div>
            <span class="f-brand-name disp">{client.nom}</span>
          </div>
          <p>{client.specialite}.<br/>{client.ville} et tout le 66 depuis 2004.</p>
          {socials.length > 0 && (
            <div class="socials">
              {socials.map(([k,v]) => (
                <a href={v} target="_blank" rel="noopener" class="soc-link soc-dark" title={k} set:html={socialIcons[k] || k} />
              ))}
            </div>
          )}
        </div>
        <div class="f-col">
          <h4>Navigation</h4>
          <ul>
            <li><a href={import.meta.env.BASE_URL}>Accueil</a></li>
            <li><a href={`${base}/services`}>Services</a></li>
            <li><a href={`${base}/realisations`}>Réalisations</a></li>
            <li><a href={`${base}/tarifs`}>Tarifs</a></li>
            <li><a href={`${base}/a-propos`}>À Propos</a></li>
            <li><a href={`${base}/contact`}>Contact</a></li>
          </ul>
        </div>
        <div class="f-col">
          <h4>Prestations</h4>
          <ul>
            {client.services.map(s => <li><a href={`${base}/services`}>{s.titre}</a></li>)}
          </ul>
        </div>
        <div class="f-col">
          <h4>Contact</h4>
          <ul>
            <li><a href={client.telephoneLink}>{client.telephone}</a></li>
            <li><a href={`mailto:${client.email}`}>{client.email}</a></li>
            <li><a href="#">{client.adresse}</a></li>
            {client.urgence && <li><a href={client.urgenceTelLink} style="color:var(--accent)">⚡ Urgence : {client.urgenceTel}</a></li>}
          </ul>
        </div>
      </div>
      <div class="f-bottom">
        <p>© {new Date().getFullYear()} {client.nom} — {client.ville} | <a href={`${base}/mentions-legales`} style="color:inherit">Mentions légales</a></p>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
      </div>
    </div>
  </footer>

</Layout>

<script define:vars={{ urgenceBarH: client.urgence ? 38 : 0 }}>
  const nav = document.getElementById('navbar');
  if(nav && urgenceBarH) nav.style.top = urgenceBarH + 'px';
</script>

<style>
/* ═══ HERO ═══ */
.hero{display:grid;grid-template-columns:1fr 1fr;min-height:100vh;padding-top:calc(var(--nav-h) + 38px);}
.hero-left{background:var(--primary);display:flex;align-items:center;padding:4rem clamp(2rem,5vw,5rem);}
.hero-left-inner{max-width:560px;}

.hero-badges{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px;}
.hb{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.7);padding:6px 14px;border-radius:var(--r-pill);font-size:12px;font-weight:600;}
.hb-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:ping 2s infinite;}
.hb-urgence{background:rgba(245,158,11,.15);border-color:var(--accent);color:var(--accent);}
@keyframes ping{0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.5);}50%{box-shadow:0 0 0 8px rgba(245,158,11,0);}}

.hero-h1{font-family:var(--font-disp);font-weight:700;line-height:1.0;letter-spacing:-.04em;color:#fff;margin-bottom:24px;}
.h1-top{display:block;font-size:clamp(1.8rem,3.5vw,2.8rem);color:rgba(255,255,255,.5);font-weight:500;}
.h1-mid{display:block;font-size:clamp(3rem,5.5vw,5rem);color:var(--accent);line-height:.95;}
.h1-bot{display:block;font-size:clamp(1.8rem,3.5vw,2.8rem);color:rgba(255,255,255,.5);font-weight:500;}

.hero-p{font-size:1rem;line-height:1.75;color:rgba(255,255,255,.6);max-width:460px;margin-bottom:32px;}
.hero-p strong{color:#fff;}
.hero-cta{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:28px;}
.hero-certs{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px;}
.cert-chip{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.55);padding:5px 12px;border-radius:var(--r-pill);font-size:11px;font-weight:600;}

.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid rgba(255,255,255,.1);padding-top:28px;}
.hs{text-align:center;padding:0 12px;border-right:1px solid rgba(255,255,255,.08);}
.hs:last-child{border-right:none;}
.hs-num{font-size:1.6rem;font-weight:700;color:var(--accent);line-height:1;}
.hs-lbl{font-size:11px;color:rgba(255,255,255,.35);margin-top:4px;}

.hero-right{position:relative;overflow:hidden;}
.hero-img-wrap{position:absolute;inset:0;}
.hero-img-wrap img{width:100%;height:100%;object-fit:cover;}
.hero-diag{position:absolute;top:0;left:0;bottom:0;width:80px;background:var(--primary);clip-path:polygon(0 0,100% 0,0 100%);z-index:2;}
.hero-float{position:absolute;bottom:40px;right:32px;z-index:3;background:rgba(12,15,26,.9);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.12);border-radius:var(--r-md);padding:14px 18px;display:flex;align-items:center;gap:12px;color:#fff;}
.hero-float-icon{font-size:1.5rem;}
.hero-float strong{display:block;font-family:var(--font-disp);font-size:.95rem;font-weight:700;}
.hero-float span{font-size:12px;color:rgba(255,255,255,.45);}

/* ═══ URGENCE BAND ═══ */
.urg-band{background:var(--primary);padding:clamp(2rem,3.5vw,3rem) 0;}
.urg-band-inner{display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;}
.urg-band-txt{display:flex;align-items:center;gap:18px;flex:1;min-width:260px;}
.urg-icon{font-size:2.2rem;flex-shrink:0;}
.urg-band-txt h3{font-size:1.15rem;font-weight:700;color:#fff;margin-bottom:4px;}
.urg-band-txt p{font-size:.88rem;color:rgba(255,255,255,.5);}
.urg-band-txt strong{color:#fff;}
.urg-band-cta{display:flex;flex-direction:column;align-items:flex-end;gap:8px;}
.urg-note{font-size:11px;color:rgba(255,255,255,.3);text-align:right;}

/* ═══ SERVICES ═══ */
.svc-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;gap:2rem;flex-wrap:wrap;}
.svc-featured-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-bottom:16px;}
.svc-feat-card{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;}
.sfc-img{position:relative;height:280px;}
.sfc-img img{width:100%;height:100%;object-fit:cover;}
.sfc-num{position:absolute;top:14px;left:16px;font-size:3.5rem;font-weight:700;color:rgba(255,255,255,.18);line-height:1;}
.sfc-body{padding:24px;}
.sfc-icon{font-size:1.4rem;display:block;margin-bottom:10px;}
