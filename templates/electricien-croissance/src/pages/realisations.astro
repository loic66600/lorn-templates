---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`Réalisations — ${client.nom}`} description={`Chantiers réalisés par ${client.nom} : tableau électrique, domotique, IRVE, solaire, urgences. Perpignan et Pyrénées-Orientales.`}>

<nav class="navbar scrolled" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo"><div class="nav-logo-bolt">⚡</div><div class="nav-logo-text"><span class="nav-logo-name">{client.nom}</span><span class="nav-logo-sub">{client.metier}</span></div></a>
    <ul class="nav-links">
      <li><a href="/">Accueil</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/realisations" class="active">Réalisations</a></li>
      <li class="nav-dropdown"><button class="nav-dd-toggle">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a></div></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="nav-cta"><a href={client.telephoneLink} class="nav-tel">{client.telephone}</a><a href="/contact" class="btn btn-accent">Devis gratuit</a></div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href="/">Accueil</a><a href="/services">Services</a><a href="/realisations">Réalisations</a>
    <a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a><a href="/contact">Contact</a>
    <a href="/contact" class="mob-cta">Devis gratuit →</a>
  </div>
</nav>

<header class="ph">
  <div class="wrap">
    <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Réalisations</span></nav>
    <div class="eyebrow" style="color:var(--accent)">Nos chantiers</div>
    <h1 class="ph-title">{client.stats[1].chiffre}+ chantiers<br>électriques dans le 66</h1>
    <p class="ph-sub">Une sélection de projets récents réalisés dans les Pyrénées-Orientales.</p>
  </div>
</header>

<section class="section">
  <div class="wrap">
    <!-- Filtres -->
    <div class="filters volt">
      {client.realisationsCategories.map(cat => (
        <button class={`fbtn ${cat.id === 'all' ? 'active' : ''}`} data-filter={cat.id}>
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Grille -->
    <div class="real-grid" id="realGrid">
      {client.realisations.map((r, i) => (
        <article class={`rc lift volt-up d${(i%3)+1}`} data-cat={r.categorie}>
          <div class="rc-img iz">
            <img src={r.image} alt={r.titre} loading="lazy" />
            <div class="rc-badges">
              <span class="rc-cat-badge">{r.categorie}</span>
              <span class="rc-detail-badge">{r.detail}</span>
            </div>
          </div>
          <div class="rc-body">
            <div class="rc-meta disp"><span>📍 {r.lieu}</span><span>· {r.annee}</span></div>
            <h3 class="disp rc-title">{r.titre}</h3>
            <p>{r.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section-dark">
  <div class="wrap cta-dk">
    <div class="volt"><div class="eyebrow" style="color:var(--accent)">Votre projet</div><h2 class="h2 h2-white">Le prochain chantier,<br>c'est le vôtre ?</h2></div>
    <div style="display:flex;gap:12px;flex-wrap:wrap" class="volt d1"><a href="/contact" class="btn btn-accent btn-lg">Devis gratuit →</a><a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a></div>
  </div>
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0"><p>© {new Date().getFullYear()} {client.nom} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p><a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a></div></div></footer>
</Layout>

<script>
  document.querySelectorAll('.fbtn').forEach(btn => btn.addEventListener('click', () => {
    document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = (btn as HTMLElement).dataset.filter || 'all';
    document.querySelectorAll('[data-cat]').forEach(c => {
      (c as HTMLElement).style.display = f === 'all' || (c as HTMLElement).dataset.cat === f ? '' : 'none';
    });
  }));
</script>

<style>
.filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:2.5rem;}
.fbtn{padding:8px 18px;border-radius:var(--r-pill);font-family:var(--font-disp);font-size:12px;font-weight:700;border:2px solid var(--border);background:transparent;color:var(--text-muted);cursor:pointer;transition:all .2s;}
.fbtn:hover,.fbtn.active{background:var(--primary);border-color:var(--primary);color:#fff;}
.real-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.rc{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;}
.rc-img{position:relative;height:240px;}
.rc-img img{width:100%;height:100%;object-fit:cover;}
.rc-badges{position:absolute;top:12px;left:12px;right:12px;display:flex;justify-content:space-between;}
.rc-cat-badge{background:var(--primary);color:#fff;padding:4px 11px;border-radius:var(--r-pill);font-family:var(--font-disp);font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.rc-detail-badge{background:rgba(245,158,11,.9);color:#000;padding:4px 10px;border-radius:var(--r-pill);font-size:11px;font-weight:700;}
.rc-body{padding:18px;}
.rc-meta{display:flex;gap:7px;font-size:11px;color:var(--text-muted);margin-bottom:7px;}
.rc-title{font-size:.95rem;font-weight:700;margin-bottom:6px;}
.rc-body p{font-size:.82rem;color:var(--text-muted);line-height:1.65;}
.cta-dk{display:flex;justify-content:space-between;align-items:center;gap:2rem;flex-wrap:wrap;}
@media(max-width:1024px){.real-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:640px){.real-grid{grid-template-columns:1fr;}.cta-dk{flex-direction:column;}}
</style>
