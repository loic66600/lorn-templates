---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

const titre = `${client.nom} — Trottinettes électriques premium assemblées en France`;
const description = `${client.nomComplet} : trottinettes électriques haut de gamme conçues et assemblées à ${client.adresse.ville}. Découvrez la Zéphyr, la Sirocco et l'Autan. Essai sur rendez-vous, livraison nationale.`;

const heroModele = client.modeles[client.modeles.length - 1]; // Autan, le flagship
---

<Layout title={titre} description={description}>
  <!-- ======================= HERO ======================= -->
  <section class="hero">
    <div class="hero-media" id="hero-media">
      <img
        src="https://images.unsplash.com/photo-1571068316344-75bc76f77890?q=80&w=2200&auto=format&fit=crop"
        alt={`Trottinette électrique ${client.nom} ${heroModele.nom}`}
        fetchpriority="high"
      />
      <!-- <img src="/images/hero.jpg" alt={`Trottinette électrique ${client.nom} ${heroModele.nom}`} fetchpriority="high" /> -->
    </div>
    <div class="hero-voile" aria-hidden="true"></div>

    <div class="conteneur hero-contenu">
      <p class="hero-eyebrow">{client.signature}</p>
      <h1 class="hero-titre">
        <span>Roulez</span>
        <span class="hero-bleu">l'exception</span>
      </h1>
      <p class="hero-sous">{client.manifeste}</p>
      <div class="hero-actions">
        <a href="/modeles" class="btn btn-plein btn-fleche">Découvrir la gamme</a>
        <a href="/reservation" class="btn btn-vide">Réserver un essai</a>
      </div>
    </div>

    <div class="hero-bas">
      <span class="hero-scroll">Défiler</span>
      <span class="hero-ref">{heroModele.nom} · {heroModele.segment}</span>
    </div>
  </section>

  <!-- ======================= GAMME ======================= -->
  <section class="gamme">
    <div class="conteneur gamme-tete">
      <p class="etiquette reveler">La gamme</p>
      <h2 class="titre-section reveler">Trois <em>tempéraments</em></h2>
    </div>

    <div class="gamme-liste">
      {
        client.modeles.map((m) => (
          <a href={`/modeles/${m.slug}`} class="gamme-item reveler">
            <div class="gamme-image">
              <img src={m.finitions[0].image} alt={`${client.nom} ${m.nom}`} loading="lazy" />
              {/* <img src={m.finitions[0].imageLocale} alt={`${client.nom} ${m.nom}`} loading="lazy" /> */}
            </div>
            <div class="gamme-info">
              <span class="gamme-ordre">{m.ordre}</span>
              <div class="gamme-titre-bloc">
                <h3 class="gamme-nom">{m.nom}</h3>
                <span class="gamme-segment">{m.segment}</span>
              </div>
              <p class="gamme-accroche">{m.accroche}</p>
              <div class="gamme-pied">
                <span class="gamme-prix">dès {m.prix.toLocaleString("fr-FR")} €</span>
                <span class="gamme-fleche" aria-hidden="true">→</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ======================= MANIFESTE / CHIFFRES ======================= -->
  <section class="chiffres">
    <div class="conteneur">
      <h2 class="chiffres-phrase reveler">
        Conçu comme une <em>voiture de sport.</em><br />
        Pensé pour la <em>ville.</em>
      </h2>
      <div class="chiffres-grille">
        {
          client.chiffres.map((c) => (
            <div class="chiffre reveler">
              <span class="chiffre-valeur" data-cible={c.valeur}>0</span>
              <span class="chiffre-suffixe">{c.suffixe}</span>
              <span class="chiffre-label">{c.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= TECHNOLOGIE ======================= -->
  <section class="techno">
    <div class="conteneur">
      <div class="techno-tete reveler">
        <p class="etiquette">Ingénierie</p>
        <h2 class="titre-section">Sous <em>le capot</em></h2>
      </div>
      <div class="techno-grille">
        {
          client.technologie.map((t) => (
            <article class="techno-item reveler">
              <span class="techno-code">{t.code}</span>
              <h3 class="techno-titre">{t.titre}</h3>
              <p class="techno-desc">{t.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= BANDEAU FLAGSHIP ======================= -->
  <section class="flagship">
    <div class="flagship-media">
      <img
        src={heroModele.film.poster}
        alt={`${client.nom} ${heroModele.nom} — performance`}
        loading="lazy"
      />
      <!-- <img src="/images/flagship.jpg" alt={`${client.nom} ${heroModele.nom}`} loading="lazy" /> -->
    </div>
    <div class="flagship-voile" aria-hidden="true"></div>
    <div class="conteneur flagship-contenu reveler">
      <p class="etiquette">Série limitée — {heroModele.specs.find((s) => s.label === "Série")?.valeur} exemplaires</p>
      <h2 class="flagship-titre">{heroModele.nom}</h2>
      <p class="flagship-accroche">{heroModele.accroche}</p>
      <a href={`/modeles/${heroModele.slug}`} class="btn btn-plein btn-fleche">Découvrir l'{heroModele.nom}</a>
    </div>
  </section>

  <!-- ======================= AVIS ======================= -->
  <section class="avis">
    <div class="conteneur">
      <p class="etiquette reveler">Ils roulent en Mistral</p>
      <h2 class="titre-section reveler">La <em>parole</em> aux pilotes</h2>
      <div class="avis-grille">
        {
          client.avis.map((a) => (
            <figure class="avis-carte reveler">
              <p class="avis-note" aria-label={`${a.note} sur 5`}>{"★".repeat(a.note)}</p>
              <blockquote>{a.texte}</blockquote>
              <figcaption>{a.nom} — <span>{a.ville}</span></figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= CTA ======================= -->
  <section class="cta">
    <div class="conteneur cta-inner reveler">
      <h2 class="cta-titre">Le meilleur essai,<br /><em>c'est le vôtre.</em></h2>
      <p class="cta-sous">
        Réservez un créneau au showroom de {client.adresse.ville} ou faites-vous
        livrer partout en France sous 48h.
      </p>
      <div class="hero-actions">
        <a href="/reservation" class="btn btn-plein btn-fleche">Réserver un essai</a>
        <a href="/modeles" class="btn btn-vide">Comparer les modèles</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    will-change: transform;
  }
  .hero-media img {
    width: 100%;
    height: 110%;
    object-fit: cover;
    filter: saturate(0.85) contrast(1.05);
  }
  .hero-voile {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, var(--noir) 3%, transparent 55%),
      linear-gradient(to right, rgba(8,8,10,0.7), transparent 60%);
  }
  .hero-contenu {
    position: relative;
    z-index: 2;
    padding-bottom: 8rem;
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--bleu-clair);
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }
  .hero-titre {
    font-size: clamp(4rem, 16vw, 13rem);
    line-height: 0.86;
    letter-spacing: 0.01em;
  }
  .hero-titre span {
    display: block;
    opacity: 0;
    transform: translateY(40px);
    animation: fadeUp 1s cubic-bezier(0.2,0.7,0.2,1) forwards;
  }
  .hero-titre span:nth-child(1) { animation-delay: 0.2s; }
  .hero-titre span:nth-child(2) { animation-delay: 0.35s; }
  .hero-bleu { color: var(--bleu-clair); }
  @keyframes fadeUp { to { opacity: 1; transform: none; } }
  .hero-sous {
    max-width: 52ch;
    margin: 2rem 0 2.4rem;
    color: var(--blanc);
    opacity: 0;
    font-size: 1.05rem;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.9s ease 0.65s forwards; }
  .hero-bas {
    position: absolute;
    bottom: 2rem;
    left: 0; right: 0;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    width: min(1320px, 100% - 3rem);
    margin-inline: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gris);
  }
  .hero-scroll { position: relative; padding-left: 1.6rem; }
  .hero-scroll::before {
    content: "";
    position: absolute;
    left: 0; top: 50%;
    width: 1rem; height: 1px;
    background: var(--bleu);
    animation: scrollLine 1.8s ease-in-out infinite;
  }
  @keyframes scrollLine { 50% { width: 1.4rem; opacity: 0.4; } }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-titre span, .hero-sous, .hero-actions { animation: none; opacity: 1; transform: none; }
    .hero-scroll::before { animation: none; }
  }

  /* ---- Gamme ---- */
  .gamme { padding-block: 8rem 4rem; }
  .gamme-tete { margin-bottom: 3.5rem; }
  .gamme-liste {
    display: grid;
    gap: 1px;
    background: var(--ligne);
    border-block: 1px solid var(--ligne);
  }
  .gamme-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--noir);
    transition: background 0.4s ease;
  }
  .gamme-item:hover { background: var(--noir-2); }
  .gamme-image { overflow: hidden; aspect-ratio: 16 / 10; }
  .gamme-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.85);
    transition: transform 0.8s cubic-bezier(0.2,0.7,0.2,1);
  }
  .gamme-item:hover .gamme-image img { transform: scale(1.06); }
  .gamme-info {
    padding: 3rem 3rem 2.4rem;
    display: grid;
    align-content: center;
    position: relative;
  }
  .gamme-ordre {
    position: absolute;
    top: 2rem; right: 3rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--gris-fonce);
  }
  .gamme-titre-bloc { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .gamme-nom { font-size: clamp(2.4rem, 5vw, 3.8rem); }
  .gamme-segment {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bleu-clair);
  }
  .gamme-accroche {
    font-family: var(--font-display);
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--gris);
    margin: 0.8rem 0 1.8rem;
  }
  .gamme-pied {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--ligne);
    padding-top: 1.4rem;
  }
  .gamme-prix {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.04em;
  }
  .gamme-fleche { color: var(--bleu-clair); font-size: 1.4rem; transition: transform 0.3s ease; }
  .gamme-item:hover .gamme-fleche { transform: translateX(6px); }

  /* ---- Chiffres ---- */
  .chiffres { padding-block: 7rem; border-top: 1px solid var(--ligne); }
  .chiffres-phrase {
    font-size: clamp(2rem, 5.5vw, 4.4rem);
    line-height: 1.02;
    margin-bottom: 3.5rem;
  }
  .chiffres-phrase em { font-style: normal; color: var(--bleu-clair); }
  .chiffres-grille {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--ligne);
    border: 1px solid var(--ligne);
  }
  .chiffre {
    background: var(--noir);
    padding: 2.4rem 2rem;
    display: flex;
    flex-direction: column;
  }
  .chiffre-valeur {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4.6rem);
    line-height: 1;
    color: var(--bleu-clair);
    display: inline;
  }
  .chiffre-suffixe {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--bleu-clair);
    margin-bottom: 0.8rem;
  }
  .chiffre-label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gris);
  }

  /* ---- Technologie ---- */
  .techno { padding-block: 7rem; }
  .techno-tete { margin-bottom: 3rem; }
  .techno-grille {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--ligne);
    border: 1px solid var(--ligne);
  }
  .techno-item {
    background: var(--noir);
    padding: 2.8rem 2.4rem;
    transition: background 0.35s ease;
  }
  .techno-item:hover { background: var(--noir-2); }
  .techno-code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--bleu-clair);
  }
  .techno-titre { font-size: 1.8rem; margin: 0.8rem 0 0.9rem; }
  .techno-desc { color: var(--gris); max-width: 52ch; }

  /* ---- Flagship ---- */
  .flagship {
    position: relative;
    min-height: 86svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .flagship-media { position: absolute; inset: 0; }
  .flagship-media img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.8) contrast(1.08);
  }
  .flagship-voile {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(8,8,10,0.9) 10%, rgba(8,8,10,0.3) 70%, transparent);
  }
  .flagship-contenu { position: relative; z-index: 2; }
  .flagship-titre {
    font-size: clamp(4rem, 14vw, 11rem);
    line-height: 0.85;
    margin: 1rem 0 0.6rem;
  }
  .flagship-accroche {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    text-transform: uppercase;
    color: var(--gris);
    margin-bottom: 2rem;
  }

  /* ---- Avis ---- */
  .avis { padding-block: 7.5rem; }
  .avis-grille {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .avis-carte {
    border: 1px solid var(--ligne);
    padding: 2.2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .avis-note { color: var(--bleu-clair); letter-spacing: 0.3em; }
  .avis-carte blockquote { font-size: 1rem; color: var(--blanc); line-height: 1.6; }
  .avis-carte figcaption {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.06em;
    color: var(--blanc);
    margin-top: auto;
  }
  .avis-carte figcaption span { color: var(--gris); }

  /* ---- CTA ---- */
  .cta { padding-block: 8rem; border-top: 1px solid var(--ligne); text-align: center; }
  .cta-titre { font-size: clamp(2.6rem, 7vw, 5.5rem); }
  .cta-titre em { font-style: normal; color: var(--bleu-clair); }
  .cta-sous { color: var(--gris); max-width: 50ch; margin: 1.4rem auto 2.4rem; }
  .cta-inner .hero-actions { justify-content: center; animation: none; opacity: 1; }

  @media (max-width: 880px) {
    .gamme-item { grid-template-columns: 1fr; }
    .gamme-info { padding: 2rem; }
    .gamme-ordre { right: 2rem; top: 1.4rem; }
    .techno-grille, .chiffres-grille { grid-template-columns: 1fr 1fr; }
    .avis-grille { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .chiffres-grille { grid-template-columns: 1fr; }
    .techno-grille { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Parallaxe hero
  const heroMedia = document.getElementById("hero-media");
  const reduit = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (heroMedia && !reduit) {
    window.addEventListener(
      "scroll",
      () => {
        const y = window.scrollY;
        if (y < window.innerHeight) {
          heroMedia.style.transform = `translateY(${y * 0.35}px) scale(1.05)`;
        }
      },
      { passive: true }
    );
  }

  // Compteurs animés
  const compteurs = document.querySelectorAll<HTMLElement>(".chiffre-valeur");
  const animer = (el: HTMLElement) => {
    const cible = parseFloat(el.dataset.cible || "0");
    const duree = 1400;
    const debut = performance.now();
    const pas = (t: number) => {
      const p = Math.min((t - debut) / duree, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = cible * eased;
      el.textContent = cible >= 100 ? Math.round(val).toLocaleString("fr-FR") : val.toFixed(0);
      if (p < 1) requestAnimationFrame(pas);
      else el.textContent = cible.toLocaleString("fr-FR");
    };
    requestAnimationFrame(pas);
  };
  const obsC = new IntersectionObserver(
    (entrees) => {
      entrees.forEach((e) => {
        if (e.isIntersecting) {
          animer(e.target as HTMLElement);
          obsC.unobserve(e.target);
        }
      });
    },
    { threshold: 0.6 }
  );
  compteurs.forEach((c) => obsC.observe(c));
</script>
