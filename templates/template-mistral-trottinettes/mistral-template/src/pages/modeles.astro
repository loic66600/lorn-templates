---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

const titre = `La gamme — Trottinettes électriques ${client.nom} | Zéphyr · Sirocco · Autan`;
const description = `Comparez les trottinettes électriques ${client.nom} : la Zéphyr urbaine (45 km), la Sirocco grande autonomie (90 km) et l'Autan performance (110 km, série limitée). Conçues et assemblées en France.`;

// Schéma ItemList des produits
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: client.modeles.map((m, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Product",
      name: `${client.nom} ${m.nom}`,
      url: `${client.siteUrl}/modeles/${m.slug}`,
      offers: {
        "@type": "Offer",
        price: m.prix,
        priceCurrency: "EUR",
        availability: "https://schema.org/InStock",
      },
    },
  })),
};
---

<Layout title={titre} description={description} jsonLd={jsonLd}>
  <section class="intro">
    <div class="conteneur">
      <p class="etiquette">La gamme — {client.modeles.length} modèles</p>
      <h1 class="titre-section">Choisissez<br /><em>votre vent.</em></h1>
      <p class="intro-texte">
        Chaque Mistral porte le nom d'un vent. Trois caractères, une même
        exigence d'ingénierie : châssis monocoque, freinage redondant et
        assemblage à la main dans notre atelier de {client.adresse.ville}.
      </p>
    </div>
  </section>

  {
    client.modeles.map((m, i) => (
      <section class:list={["modele", { invert: i % 2 === 1 }]}>
        <div class="conteneur modele-grille">
          <a href={`/modeles/${m.slug}`} class="modele-media reveler">
            <img src={m.finitions[0].image} alt={`${client.nom} ${m.nom} — ${m.segment}`} loading="lazy" />
            {/* <img src={m.finitions[0].imageLocale} alt={`${client.nom} ${m.nom} — ${m.segment}`} loading="lazy" /> */}
            <span class="modele-ordre" aria-hidden="true">{m.ordre}</span>
          </a>

          <div class="modele-texte reveler">
            <span class="modele-segment">{m.segment}</span>
            <h2 class="modele-nom">{m.nom}</h2>
            <p class="modele-accroche">{m.accroche}</p>
            <p class="modele-promesse">{m.promesse}</p>

            <ul class="modele-specs">
              {m.specs.slice(0, 4).map((s) => (
                <li>
                  <span class="spec-valeur">{s.valeur}<small>{s.unite}</small></span>
                  <span class="spec-label">{s.label}</span>
                </li>
              ))}
            </ul>

            <div class="modele-actions">
              <a href={`/modeles/${m.slug}`} class="btn btn-plein btn-fleche">Voir la fiche</a>
              <span class="modele-prix">dès {m.prix.toLocaleString("fr-FR")} €</span>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <section class="cta">
    <div class="conteneur cta-inner reveler">
      <h2 class="cta-titre">Hésitation ?<br /><em>Essayez les trois.</em></h2>
      <a href="/reservation" class="btn btn-plein btn-fleche">Réserver un essai au showroom</a>
    </div>
  </section>
</Layout>

<style>
  .intro { padding: 12rem 0 5rem; }
  .intro-texte { max-width: 60ch; color: var(--gris); margin-top: 1rem; }

  .modele { padding-block: 5rem; border-top: 1px solid var(--ligne); }
  .modele-grille {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4.5rem;
    align-items: center;
  }
  .modele.invert .modele-media { order: 2; }
  .modele-media {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .modele-media img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(0.85);
    transition: transform 0.8s cubic-bezier(0.2,0.7,0.2,1);
  }
  .modele-media:hover img { transform: scale(1.05); }
  .modele-ordre {
    position: absolute;
    bottom: 1rem; left: 1.4rem;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    color: var(--blanc);
    mix-blend-mode: difference;
    pointer-events: none;
  }
  .modele-segment {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--bleu-clair);
  }
  .modele-nom { font-size: clamp(3rem, 8vw, 6rem); margin: 0.6rem 0; }
  .modele-accroche {
    font-family: var(--font-display);
    font-size: 1.5rem;
    text-transform: uppercase;
    color: var(--gris);
    margin-bottom: 1.2rem;
  }
  .modele-promesse { color: var(--gris); max-width: 52ch; margin-bottom: 2rem; }
  .modele-specs {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--ligne);
    border: 1px solid var(--ligne);
    margin-bottom: 2rem;
  }
  .modele-specs li {
    background: var(--noir);
    padding: 1.2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .spec-valeur { font-family: var(--font-display); font-size: 1.7rem; line-height: 1; }
  .spec-valeur small { font-size: 0.85rem; color: var(--gris); margin-left: 2px; }
  .spec-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gris);
  }
  .modele-actions { display: flex; align-items: center; gap: 1.6rem; flex-wrap: wrap; }
  .modele-prix { font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 0.04em; }

  .cta { padding-block: 8rem; border-top: 1px solid var(--ligne); text-align: center; }
  .cta-titre { font-size: clamp(2.4rem, 6vw, 4.6rem); margin-bottom: 2rem; }
  .cta-titre em { font-style: normal; color: var(--bleu-clair); }

  @media (max-width: 900px) {
    .modele-grille { grid-template-columns: 1fr; gap: 2.2rem; }
    .modele.invert .modele-media { order: 0; }
    .modele-specs { grid-template-columns: 1fr 1fr; }
  }
</style>
