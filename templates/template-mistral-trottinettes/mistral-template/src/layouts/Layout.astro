---
import { client } from "@data/client";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CookieBanner from "@components/CookieBanner.astro";

interface Props {
  title: string;
  description: string;
  noIndex?: boolean;
  jsonLd?: object | null;
}

const { title, description, noIndex = false, jsonLd = null } = Astro.props;
const canonical = new URL(Astro.url.pathname, client.siteUrl).href;

// ---- Schéma Organization (toutes pages) ----
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": client.siteUrl + "/#org",
  name: client.nomComplet,
  alternateName: client.nom,
  description: client.description,
  url: client.siteUrl,
  email: client.email,
  telephone: client.telephoneLien,
  foundingDate: String(client.anneeFondation),
  address: {
    "@type": "PostalAddress",
    streetAddress: client.adresse.rue,
    postalCode: client.adresse.codePostal,
    addressLocality: client.adresse.ville,
    addressRegion: client.adresse.region,
    addressCountry: "FR",
  },
  areaServed: { "@type": "Country", name: "France" },
  sameAs: Object.values(client.reseaux),
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={client.seo.motsCles.join(", ")} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Géolocalisation (atelier / showroom) -->
    <meta name="geo.region" content="FR-66" />
    <meta name="geo.placename" content={client.adresse.ville} />
    <meta name="geo.position" content={`${client.geo.lat};${client.geo.lng}`} />
    <meta name="ICBM" content={`${client.geo.lat}, ${client.geo.lng}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={client.nom} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Polices : Saira Condensed (display caps) + Manrope (texte) + Spline Sans Mono (specs) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600&family=Spline+Sans+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>

<style is:global>
  :root {
    --noir: #08080a;
    --noir-2: #101216;
    --noir-3: #181b21;
    --blanc: #f3f5f9;
    --gris: #878d99;
    --gris-fonce: #4a4f59;
    --bleu: #2c5bff;
    --bleu-clair: #5b82ff;
    --bleu-sombre: #0e2a9e;
    --ligne: rgba(243, 245, 249, 0.12);
    --font-display: "Saira Condensed", system-ui, sans-serif;
    --font-texte: "Manrope", system-ui, sans-serif;
    --font-mono: "Spline Sans Mono", monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--noir);
    color: var(--blanc);
    font-family: var(--font-texte);
    font-weight: 300;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  a { color: inherit; text-decoration: none; }
  img, video { display: block; max-width: 100%; }

  .conteneur {
    width: min(1320px, 100% - 3rem);
    margin-inline: auto;
  }

  /* Étiquette mono */
  .etiquette {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--bleu-clair);
  }
  .etiquette::before {
    content: "";
    width: 2rem;
    height: 1px;
    background: var(--bleu);
  }

  /* Titres monumentaux */
  .titre-section {
    font-size: clamp(2.6rem, 7vw, 6rem);
    letter-spacing: 0.01em;
    margin: 1.2rem 0 1.4rem;
  }
  .titre-section em {
    font-style: normal;
    color: var(--bleu-clair);
  }

  /* Boutons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1.05rem 2.2rem;
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--blanc);
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }
  .btn-plein {
    background: var(--blanc);
    color: var(--noir);
    border-color: var(--blanc);
  }
  .btn-plein:hover {
    background: var(--bleu);
    border-color: var(--bleu);
    color: var(--blanc);
    transform: translateY(-2px);
  }
  .btn-vide { color: var(--blanc); }
  .btn-vide:hover {
    border-color: var(--bleu);
    color: var(--bleu-clair);
  }
  .btn-fleche::after {
    content: "→";
    font-size: 1.1em;
    transition: transform 0.3s ease;
  }
  .btn-fleche:hover::after { transform: translateX(4px); }

  /* Apparition au scroll */
  .reveler {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.9s cubic-bezier(0.2,0.7,0.2,1), transform 0.9s cubic-bezier(0.2,0.7,0.2,1);
  }
  .reveler.visible { opacity: 1; transform: none; }

  ::selection { background: var(--bleu); color: var(--blanc); }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .reveler { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(
    (entrees) => {
      entrees.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          obs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll(".reveler").forEach((el) => obs.observe(el));
</script>
