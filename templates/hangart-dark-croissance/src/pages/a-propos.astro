---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`Le Studio — ${client.nomComplet}`} description={`${client.nomComplet} Perpignan — histoire, valeurs, Ink Master, tatouage sur mesure. 68 av. Grande-Bretagne, 66000.`}>
<nav class="navbar" id="navbar"><div class="nav-in">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span class="f">ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/artistes">Artistes</a></li><li><a href="/a-propos" class="active">Studio</a></li><li><a href="/hygiene">Hygiène</a></li><li><a href="/videos">Vidéos</a></li><li><a href="/tarifs">Tarifs</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><div class="mob-header"><div class="mob-logo">HANG<span class="f">ART</span></div><button class="mob-close" id="mobClose">✕</button></div>
<nav class="mob-nav"><a href="/">Accueil</a><a href="/artistes">Artistes</a><a href="/a-propos" class="active">Studio</a><a href="/hygiene">Hygiène</a><a href="/videos">Vidéos</a><a href="/tarifs">Tarifs</a><a href="/contact" class="mob-reserve">Réserver →</a></nav>
<div class="mob-footer"><a href={client.telephoneLink}>{client.telephone}</a></div></div></nav>

<div class="ph"><div class="wrap">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Studio</span></nav>
  <span class="lbl">Notre histoire</span>
  <h1 class="ph-title">HANGART<br><em>DEPUIS {client.fondation}</em></h1>
  <p class="ph-sub mono">{client.adresse}</p>
</div></div>

<section class="sec sec-1">
  <div class="wrap story-lay">
    <div data-r>
      <span class="lbl">L'histoire</span>
      <h2 class="h2" style="margin-top:8px">Un hangar.<br><span class="fire">De l'art.</span><br>Perpignan.</h2>
      <div class="fire-line"></div>
      <p class="lead">{client.apropos.p1}</p>
      <p class="lead" style="margin-top:.6rem">{client.apropos.p2}</p>
      <p class="lead" style="margin-top:.6rem">{client.apropos.p3}</p>
    </div>
    <div class="story-img" data-r="r">
      <img src={client.apropos.photoStudio} alt={`Studio ${client.nomComplet}`} loading="lazy"/>
      <div class="si-dark"></div>
    </div>
  </div>
</section>

<section class="sec-cendre">
  <div class="wrap">
    <div class="sh-center" data-r><span class="lbl lbl-cendre">Ce qui nous définit</span><h2 class="h2 h2-dark" style="margin-top:8px;text-align:center">6 piliers.<br>Un seul niveau.</h2></div>
    <div class="val-grid">
      {[
        {n:"Talent",i:"01",d:"6 artistes sélectionnés pour la qualité de leur travail. Chaque style est une expertise exclusive — pas de touche-à-tout."},
        {n:"Ink Master",i:"02",d:"Plusieurs de nos artistes ont participé à des concours de type Ink Master au niveau national et européen."},
        {n:"Sur mesure",i:"03",d:"Nous ne copions pas. Chaque tatouage est pensé pour vous — votre corps, votre histoire, votre esthétique."},
        {n:"Hygiène",i:"04",d:"Aiguilles usage unique, autoclave certifié, encres CE, surfaces protégées. Notre protocole est détaillé et transparent."},
        {n:"Durabilité",i:"05",d:"Un tatouage bien fait dure toute la vie. Encres certifiées, techniques adaptées à votre peau, aftercare inclus."},
        {n:"Communauté",i:"06",d:"Conventions, flash days, guest artistes. Le Hangart est un lieu vivant ancré dans la culture tattoo."},
      ].map((v, i) => (
        <div class="vi" data-r style={`transition-delay:${(i%3)*.1}s`}>
          <span class="mono vi-n">{v.i}</span>
          <h3 class="disp vi-t">{v.n}</h3>
          <div style="width:32px;height:2px;background:var(--braise);margin:8px 0"></div>
          <p class="mono vi-d">{v.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="sec sec-1">
  <div class="wrap"><div class="stats-row" style="border:1px solid var(--border-w)">
    {client.stats.map((s, i) => (
      <div class="st-item" data-r style={`transition-delay:${i*.1}s`}>
        <strong class="disp st-n"><span class="ctr" data-target={s.chiffre} data-suffix={s.suffix}>0</span></strong>
        <span class="mono st-l">{s.label}</span>
      </div>
    ))}
  </div>
  <div class="art-mini-grid" style="margin-top:2px">
    {client.artistes.map(a => (
      <a href={`/artistes/${a.slug}`} class="amg-item">
        <img src={a.photo} alt={a.pseudo} loading="lazy"/>
        <div class="amg-dark"></div>
        <div class="amg-info"><span class="disp amg-name" style={`color:${a.couleur}`}>{a.pseudo}</span><span class="mono amg-s">{a.styleShort}</span></div>
        <div class="amg-bar" style={`background:${a.couleur}`}></div>
      </a>
    ))}
  </div></div>
</section>

<section class="cta-blaze"><div class="blaze-line"></div><div class="wrap cta-inner">
  <div data-r><h2 class="h2">Venez.<br><span class="fire">Réservez.</span></h2></div>
  <div class="cta-acts" data-r="r"><a href="/contact" class="btn btn-fire btn-lg">Réserver →</a><a href={client.telephoneLink} class="btn btn-ghost btn-lg">{client.telephone}</a></div>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.story-lay{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
.story-img{position:sticky;top:calc(var(--nav-h)+2rem);height:560px;overflow:hidden;position:relative}
.story-img img{width:100%;height:100%;object-fit:cover;filter:grayscale(.3)}
.si-dark{position:absolute;inset:0;background:linear-gradient(135deg,transparent 0%,rgba(8,8,6,.5) 100%)}
.val-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid rgba(8,8,6,.1);margin-top:2.5rem}
.vi{padding:26px 22px;border-right:1px solid rgba(8,8,6,.08);border-bottom:1px solid rgba(8,8,6,.08)}
.vi:nth-child(3n){border-right:none}.vi:nth-child(4),.vi:nth-child(5),.vi:nth-child(6){border-bottom:none}
.vi:hover{background:rgba(255,69,0,.04)}
.vi-n{font-size:2rem;color:rgba(8,8,6,.07);display:block;margin-bottom:8px;line-height:1}
.vi-t{font-size:.95rem;color:var(--noir);margin-bottom:0}
.vi-d{font-size:.76rem;color:rgba(8,8,6,.48);line-height:1.9}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr)}
.st-item{padding:1.4rem;border-right:1px solid var(--border-w);display:flex;flex-direction:column;gap:5px}
.st-item:last-child{border-right:none}
.st-n{font-size:2.5rem;color:var(--cendre);line-height:1}
.st-l{font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--fumee)}
.art-mini-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:2px}
.amg-item{position:relative;height:240px;overflow:hidden;display:block}
.amg-item img{width:100%;height:100%;object-fit:cover;filter:grayscale(.4);transition:transform .5s ease,filter .4s}
.amg-item:hover img{transform:scale(1.08);filter:grayscale(0)}
.amg-dark{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,6,.9) 0%,rgba(8,8,6,.2) 100%)}
.amg-info{position:absolute;bottom:10px;left:12px}
.amg-name{font-size:.9rem;font-weight:900;display:block;letter-spacing:.06em}
.amg-s{font-size:8.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--fumee-d)}
.amg-bar{position:absolute;bottom:0;left:0;right:0;height:2px}
.cta-blaze{background:var(--noir-1);border-top:1px solid var(--border);padding:clamp(4rem,7vw,7rem) 0;position:relative}
.blaze-line{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--braise),transparent)}
.cta-inner{display:flex;justify-content:space-between;align-items:center;gap:3rem;flex-wrap:wrap}
.cta-acts{display:flex;flex-direction:column;gap:12px}
.sh-center{text-align:center;margin-bottom:2.5rem}
@media(max-width:1280px){.art-mini-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:1024px){.story-lay{grid-template-columns:1fr}.story-img{position:static;height:320px}}
@media(max-width:768px){.val-grid{grid-template-columns:1fr}.vi{border-right:none}.stats-row{grid-template-columns:repeat(2,1fr)}.art-mini-grid{grid-template-columns:repeat(2,1fr)}.cta-inner{flex-direction:column}}
</style>
