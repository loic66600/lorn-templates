---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`Hygiène — ${client.nomComplet}`} description={`Protocole hygiène complet du Hangart Perpignan. Aiguilles usage unique, autoclave EN13060, encres CE REACH. Votre sécurité, notre priorité absolue.`}>
<nav class="navbar" id="navbar"><div class="nav-in">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span class="f">ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/artistes">Artistes</a></li><li><a href="/a-propos">Studio</a></li><li><a href="/hygiene" class="active">Hygiène</a></li><li><a href="/videos">Vidéos</a></li><li><a href="/tarifs">Tarifs</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><div class="mob-header"><div class="mob-logo">HANG<span class="f">ART</span></div><button class="mob-close" id="mobClose">✕</button></div>
<nav class="mob-nav"><a href="/">Accueil</a><a href="/artistes">Artistes</a><a href="/a-propos">Studio</a><a href="/hygiene" class="active">Hygiène</a><a href="/videos">Vidéos</a><a href="/tarifs">Tarifs</a><a href="/contact" class="mob-reserve">Réserver →</a></nav>
<div class="mob-footer"><a href={client.telephoneLink}>{client.telephone}</a></div></div></nav>

<div class="ph"><div class="wrap">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Hygiène</span></nav>
  <span class="lbl">Sécurité totale</span>
  <h1 class="ph-title">HYGIÈNE<br><em>ZÉRO COMPROMIS</em></h1>
  <p class="ph-sub mono">Votre sécurité n'est pas une option. C'est le fondement de tout ce que nous faisons.</p>
</div></div>

<section class="sec-cendre">
  <div class="wrap">
    <div class="hy-intro" data-r>
      <div><span class="lbl lbl-cendre">Notre protocole</span><h2 class="h2 h2-dark" style="margin-top:8px">6 piliers.<br>100% certifiés.</h2></div>
      <p class="lead lead-dark">Chaque artiste du Hangart est titulaire du brevet professionnel de tatoueur incluant la formation hygiène. Notre protocole va au-delà des exigences légales.</p>
    </div>
    <div class="hy-g">
      {client.hygiene.map((h, i) => (
        <div class="hy-c" data-r style={`transition-delay:${(i%2)*.1}s`}>
          <span class="mono hy-n">{h.icone}</span>
          <div><h3 class="disp hy-t">{h.titre}</h3><p class="mono hy-d">{h.desc}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="sec sec-1">
  <div class="wrap">
    <span class="lbl" data-r>Déroulement d'une séance</span>
    <h2 class="h2" data-r style="transition-delay:.1s;margin-top:8px">Avant. Pendant.<br><span class="fire">Après.</span></h2>
    <div class="steps" style="margin-top:2.5rem">
      {[
        {n:"01",t:"Préparation du poste",d:"Désinfection complète + films barrières sur toutes les surfaces. Systématique, sans exception."},
        {n:"02",t:"Matériel stérile ouvert devant vous",d:"L'emballage stérile des aiguilles est ouvert devant vous. Vérifiez, c'est votre droit."},
        {n:"03",t:"EPI complets",d:"Gants stériles, masque chirurgical, tablier. Changement si interruption de séance."},
        {n:"04",t:"Préparation peau",d:"Nettoyage, rasage, antiseptique. Vérification du motif avec vous avant de commencer."},
        {n:"05",t:"La séance",d:"Encres CE REACH, pauses régulières, changement de gants si nécessaire."},
        {n:"06",t:"Aftercare",d:"Film Dermalize + fiche d'entretien détaillée. On reste disponibles pour toute question."},
      ].map((s, i) => (
        <div class="step" data-r style={`transition-delay:${i*.07}s`}>
          <span class="mono s-n">{s.n}</span>
          <div class="s-dot"></div>
          <h3 class="disp s-t">{s.t}</h3>
          <p class="mono s-d">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="cta-blaze"><div class="blaze-line"></div><div class="wrap cta-inner">
  <div data-r><h2 class="h2">Confiez-nous<br><span class="fire">votre peau.</span></h2></div>
  <a href="/contact" class="btn btn-fire btn-lg" data-r="r">Réserver →</a>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.hy-intro{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;margin-bottom:2.5rem}
.hy-g{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid rgba(8,8,6,.1)}
.hy-c{display:flex;gap:16px;align-items:flex-start;padding:24px;border-bottom:1px solid rgba(8,8,6,.08);border-right:1px solid rgba(8,8,6,.08)}
.hy-c:nth-child(2n){border-right:none}.hy-c:nth-child(5),.hy-c:nth-child(6){border-bottom:none}
.hy-c:hover{background:rgba(255,69,0,.04)}
.hy-n{font-size:2rem;color:rgba(8,8,6,.09);min-width:48px;flex-shrink:0;line-height:1}
.hy-t{font-size:.9rem;color:var(--noir);margin-bottom:7px}
.hy-d{font-size:.76rem;color:rgba(8,8,6,.48);line-height:1.9}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--border-w)}
.step{padding:26px;border-right:1px solid var(--border-w);border-bottom:1px solid var(--border-w)}
.step:nth-child(3n){border-right:none}.step:nth-child(4),.step:nth-child(5),.step:nth-child(6){border-bottom:none}
.s-n{font-size:1.8rem;color:rgba(232,227,220,.07);display:block;margin-bottom:8px;line-height:1}
.s-dot{width:5px;height:5px;background:var(--braise);margin-bottom:10px}
.s-t{font-size:.88rem;color:var(--cendre);margin-bottom:7px;font-weight:900}
.s-d{font-size:.76rem;color:var(--fumee);line-height:1.85}
.cta-blaze{background:var(--noir-1);border-top:1px solid var(--border);padding:clamp(4rem,7vw,7rem) 0;position:relative}
.blaze-line{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--braise),transparent)}
.cta-inner{display:flex;justify-content:space-between;align-items:center;gap:3rem;flex-wrap:wrap}
@media(max-width:1024px){.hy-intro{grid-template-columns:1fr}.steps{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.hy-g{grid-template-columns:1fr}.hy-c{border-right:none}.steps{grid-template-columns:1fr}.step{border-right:none}.cta-inner{flex-direction:column}}
</style>
