---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
function ytId(s: string): string {
  if (!s) return '';
  const m = s.match(/(?:v=|youtu\.be\/|embed\/)([^?&]+)/);
  return m ? m[1] : s;
}
---
<Layout title={`Vidéos — ${client.nomComplet}`} description={`Vidéos ${client.nomComplet} Perpignan — coulisses du studio, time-lapse tattoo, conventions.`}>
<nav class="navbar" id="navbar"><div class="nav-in">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span class="f">ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/artistes">Artistes</a></li><li><a href="/a-propos">Studio</a></li><li><a href="/hygiene">Hygiène</a></li><li><a href="/videos" class="active">Vidéos</a></li><li><a href="/tarifs">Tarifs</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><div class="mob-header"><div class="mob-logo">HANG<span class="f">ART</span></div><button class="mob-close" id="mobClose">✕</button></div>
<nav class="mob-nav"><a href="/">Accueil</a><a href="/artistes">Artistes</a><a href="/a-propos">Studio</a><a href="/hygiene">Hygiène</a><a href="/videos" class="active">Vidéos</a><a href="/tarifs">Tarifs</a><a href="/contact" class="mob-reserve">Réserver →</a></nav>
<div class="mob-footer"><a href={client.telephoneLink}>{client.telephone}</a></div></div></nav>

<div class="ph"><div class="wrap">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Vidéos</span></nav>
  <span class="lbl">En images</span>
  <h1 class="ph-title">VOYEZ<br><em>NOTRE ART</em></h1>
</div></div>

<section class="sec sec-1">
  <div class="wrap">
    {client.videos.length > 0 && (
      <div class="v-hero" data-r>
        <div class="vh-embed"><iframe src={`https://www.youtube.com/embed/${ytId(client.videos[0].youtubeId)}?rel=0&modestbranding=1&color=white`} title={client.videos[0].titre} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe></div>
        <div class="vh-info">
          <span class="lbl">À la une</span>
          <h2 class="h2" style="margin-top:8px;font-size:clamp(1.5rem,3vw,2.5rem)">{client.videos[0].titre}</h2>
          <p class="lead" style="margin-top:.6rem">{client.videos[0].description}</p>
        </div>
      </div>
    )}
    {client.videos.length > 1 && (
      <div class="v-grid" style="margin-top:2px">
        {client.videos.slice(1).map((v, i) => (
          <div class="vg-item" data-r style={`transition-delay:${i*.1}s`}>
            <div class="vgi-e"><iframe src={`https://www.youtube.com/embed/${ytId(v.youtubeId)}?rel=0&modestbranding=1`} title={v.titre} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe></div>
            <div class="vgi-i"><h3 class="disp vgt">{v.titre}</h3><p class="mono vgd">{v.description}</p></div>
          </div>
        ))}
      </div>
    )}
    <div class="v-tip mono" data-r>
      <span style="color:var(--braise)">▸</span>
      <div>
        <strong class="disp">Ajouter vos vidéos</strong>
        <p>Dans <code>client.ts</code>, ajoutez dans le tableau <code>videos[]</code> avec <code>youtubeId</code>.<br/>Formats : URL YouTube complète, youtu.be/ID, ou ID seul.</p>
      </div>
    </div>
    {client.reseaux.instagram && (
      <div class="v-insta" data-r>
        <div><span class="lbl">Plus de contenu</span><h2 class="h2" style="margin-top:8px">Instagram<br><span class="fire">en direct.</span></h2></div>
        <a href={client.reseaux.instagram} target="_blank" rel="noopener" class="btn btn-fire btn-lg">@hangart.tattoo.studio →</a>
      </div>
    )}
  </div>
</section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.v-hero{display:grid;grid-template-columns:3fr 2fr;gap:2px}
.vh-embed{aspect-ratio:16/9;overflow:hidden;background:var(--noir-2)}.vh-embed iframe{width:100%;height:100%;border:none;display:block}
.vh-info{background:var(--noir-2);padding:2rem;display:flex;flex-direction:column;justify-content:center}
.v-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px}
.vg-item{background:var(--noir-2)}
.vgi-e{aspect-ratio:16/9;overflow:hidden}.vgi-e iframe{width:100%;height:100%;border:none;display:block}
.vgi-i{padding:1.25rem}
.vgt{font-size:.9rem;color:var(--cendre);margin-bottom:6px}
.vgd{font-size:.76rem;color:var(--fumee);line-height:1.7}
.v-tip{display:flex;gap:12px;align-items:flex-start;border:1px solid var(--border-w);padding:18px;margin-top:24px}
.v-tip strong{display:block;font-size:.85rem;margin-bottom:5px;color:var(--cendre)}
.v-tip p{font-size:.75rem;color:var(--fumee);line-height:1.85}
.v-tip code{color:var(--braise);font-size:.73rem}
.v-insta{display:flex;justify-content:space-between;align-items:center;gap:3rem;flex-wrap:wrap;border:1px solid var(--border-w);padding:2.5rem;margin-top:2px}
@media(max-width:1024px){.v-hero{grid-template-columns:1fr}}
@media(max-width:768px){.v-grid{grid-template-columns:1fr}.v-insta{flex-direction:column}}
</style>
