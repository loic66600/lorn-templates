---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`Mentions légales — ${client.nomComplet}`} noIndex={true}>
<nav class="navbar" id="navbar"><div class="nav-in">
  <a href="/" class="nav-logo"><div class="nav-logo-main">HANG<span class="f">ART</span></div><div class="nav-logo-sub">Tattoo Studio · Perpignan 66</div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/contact" class="reserve">Réserver →</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><div class="mob-header"><div class="mob-logo">HANG<span class="f">ART</span></div><button class="mob-close" id="mobClose">✕</button></div>
<nav class="mob-nav"><a href="/">Accueil</a><a href="/contact">Réserver</a></nav></div></nav>

<section class="lw"><div class="wrap lc">
  <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Mentions légales</span></nav>
  <h1 class="disp lt">MENTIONS<br>LÉGALES</h1>
  <p class="mono ld">Mis à jour le {new Date().toLocaleDateString('fr-FR',{year:'numeric',month:'long',day:'numeric'})}</p>
  <div class="lx">
    <div class="lb"><h2 class="disp">01 — Éditeur</h2><p class="mono"><strong>{client.responsable}</strong><br/>SIRET : {client.siret}<br/>Adresse : {client.adresse}<br/>Tél : <a href={client.telephoneLink}>{client.telephone}</a><br/>Email : <a href={`mailto:${client.email}`}>{client.email}</a></p></div>
    <div class="lb"><h2 class="disp">02 — Hébergement</h2><p class="mono">{client.hebergeur}</p></div>
    <div class="lb"><h2 class="disp">03 — Conception</h2><p class="mono">LORN Digital Studio — <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener">vitemonsite-artisan.fr</a></p></div>
    <div class="lb"><h2 class="disp">04 — Propriété intellectuelle</h2><p class="mono">Contenu et tatouages : propriété de {client.nomComplet} et de ses artistes. Toute reproduction non autorisée est interdite (CPI art. L.335-2).</p></div>
    <div class="lb"><h2 class="disp">05 — Données personnelles (RGPD)</h2>
      <p class="mono"><strong>Collecte :</strong> nom, téléphone, email via le formulaire. Usage exclusif : traitement de votre demande.</p>
      <p class="mono" style="margin-top:.5rem"><strong>Vos droits :</strong> <a href={`mailto:${client.email}`}>{client.email}</a> · <a href="https://www.cnil.fr" target="_blank" rel="noopener">cnil.fr</a></p>
      <p class="mono" style="margin-top:.5rem"><strong>Sous-traitant :</strong> Web3Forms (web3forms.com) — conforme RGPD.</p>
    </div>
    <div class="lb"><h2 class="disp">06 — Cookies</h2><p class="mono">Cookies techniques uniquement (localStorage pour consentement). Aucun traceur publicitaire.</p></div>
    <div class="lb"><h2 class="disp">07 — Droit applicable</h2><p class="mono">Droit français — tribunaux de Perpignan.</p></div>
  </div>
  <a href="/" class="btn btn-ghost" style="margin-top:2.5rem">← Retour à l'accueil</a>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nomComplet} · SIRET {client.siret}</p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.lw{padding:calc(var(--nav-h)+4.5rem) 0 5rem}
.lc{max-width:680px}
.lt{font-size:clamp(2.5rem,6vw,6rem);font-weight:900;color:var(--cendre);margin-bottom:8px;line-height:.9}
.ld{font-size:9.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--fumee-d);margin-bottom:3rem}
.lx{display:flex;flex-direction:column}
.lb{padding:1.5rem 0;border-bottom:1px solid var(--border-w)}.lb:last-child{border-bottom:none}
.lb h2{font-size:.76rem;letter-spacing:.2em;color:var(--braise);margin-bottom:.85rem}
.lb p{font-size:.76rem;color:var(--fumee);line-height:2.0;letter-spacing:.04em}
.lb a{color:var(--braise)}.lb strong{color:var(--cendre);font-weight:500}
</style>
