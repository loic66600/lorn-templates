---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

const titre = `Essai & atelier — VTT électriques ${client.nom} à ${client.adresse.ville}`;
const description = `Réservez une sortie d'essai des VTT électriques ${client.nom} sur les sentiers du Canigou, ou configurez votre modèle (Canigó, Carlit, Puigmal). Livraison dans toute la France.`;

const web3formsKey = client.web3formsKey;
const geo = client.geo;
const nomMarque = client.nom;
const modeles = client.modeles.map((m) => ({ slug: m.slug, nom: m.nom, prix: m.prix }));
---

<Layout title={titre} description={description}>
  <section class="page-tete">
    <div class="topo" aria-hidden="true"></div>
    <div class="conteneur page-tete-inner">
      <p class="etiquette">Essai & atelier</p>
      <h1 class="titre-section">Venez<br /><em>l'essayer.</em></h1>
      <p class="page-intro">
        Réservez une sortie d'essai gratuite sur les sentiers au départ de notre
        atelier de {client.adresse.ville}, ou configurez votre Volta pour une
        livraison partout en France. Réponse sous 24h.
      </p>
    </div>
  </section>

  <section class="resa">
    <div class="conteneur resa-grille">
      <form id="formulaire" class="formulaire">
        <fieldset class="champ-modele">
          <legend>Modèle souhaité</legend>
          <div class="modele-choix">
            {
              modeles.map((m, i) => (
                <label class="choix">
                  <input type="radio" name="modele" value={m.nom} checked={i === 0} />
                  <span class="choix-corps">
                    <span class="choix-nom">{m.nom}</span>
                    <span class="choix-prix">dès {m.prix.toLocaleString("fr-FR")} €</span>
                  </span>
                </label>
              ))
            }
          </div>
        </fieldset>

        <fieldset class="champ-modele">
          <legend>Votre demande</legend>
          <div class="demande-choix">
            <label class="choix choix-inline">
              <input type="radio" name="demande" value="Essai sur sentier" checked />
              <span>Essai sur sentier</span>
            </label>
            <label class="choix choix-inline">
              <input type="radio" name="demande" value="Devis / commande" />
              <span>Devis / commande</span>
            </label>
            <label class="choix choix-inline">
              <input type="radio" name="demande" value="Question" />
              <span>Une question</span>
            </label>
          </div>
        </fieldset>

        <div class="champ-duo">
          <div class="champ"><label for="nom">Nom *</label><input type="text" id="nom" name="nom" required autocomplete="name" /></div>
          <div class="champ"><label for="telephone">Téléphone *</label><input type="tel" id="telephone" name="telephone" required autocomplete="tel" /></div>
        </div>
        <div class="champ-duo">
          <div class="champ"><label for="email">Email *</label><input type="email" id="email" name="email" required autocomplete="email" /></div>
          <div class="champ"><label for="ville">Votre ville</label><input type="text" id="ville" name="ville" placeholder="Pour la livraison" /></div>
        </div>
        <div class="champ">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="4" placeholder="Taille, niveau, créneau souhaité, questions…"></textarea>
        </div>
        <button type="submit" class="btn btn-plein btn-fleche">Envoyer ma demande</button>
        <p class="form-statut" id="form-statut" role="status" aria-live="polite"></p>
      </form>

      <aside class="infos">
        <div class="infos-bloc">
          <h2>Atelier & showroom</h2>
          <address>
            {client.adresse.rue}<br />
            {client.adresse.codePostal} {client.adresse.ville}<br />
            {client.adresse.departement}
          </address>
          <a class="infos-lien" href={`tel:${client.telephoneLien}`}>{client.telephone}</a>
          <a class="infos-lien" href={`mailto:${client.email}`}>{client.email}</a>
        </div>
        <div class="infos-bloc">
          <h2>Horaires</h2>
          <ul class="horaires">
            {client.horaires.map((h) => (<li><span>{h.jour}</span><span>{h.horaire}</span></li>))}
          </ul>
        </div>
        <div class="infos-bloc">
          <h2>Livraison & reprise</h2>
          <p class="infos-note">
            Expédition assurée dans toute la France. Reprise de votre ancien vélo
            possible à l'achat, et financement en plusieurs fois.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="carte-section">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <div id="carte" aria-label={`Atelier ${client.nom} à ${client.adresse.ville}`}></div>
  </section>
</Layout>

<style>
  .page-tete { position: relative; padding: 12rem 0 4rem; overflow: hidden; }
  .page-tete-inner { position: relative; z-index: 1; }
  .page-intro { max-width: 58ch; color: var(--sauge); }

  .resa { padding-block: 4rem 6rem; }
  .resa-grille { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 5rem; }

  .formulaire { display: grid; gap: 1.8rem; }
  .champ-modele { border: none; }
  .champ-modele legend { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sauge); margin-bottom: 0.9rem; }
  .modele-choix { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  .demande-choix { display: flex; flex-wrap: wrap; gap: 0.8rem; }
  .choix { cursor: pointer; }
  .choix input { position: absolute; opacity: 0; }
  .choix-corps { display: flex; flex-direction: column; gap: 0.3rem; padding: 1rem 1.2rem; border: 1px solid var(--ligne); border-radius: 12px; transition: border-color 0.25s ease, background 0.25s ease; }
  .choix-nom { font-family: var(--font-display); font-weight: 600; font-size: 1.3rem; }
  .choix-prix { font-family: var(--font-mono); font-size: 0.74rem; color: var(--sauge); }
  .choix input:checked + .choix-corps { border-color: var(--cuivre); background: rgba(201,122,69,0.1); }
  .choix-inline span { display: inline-block; padding: 0.7rem 1.2rem; border: 1px solid var(--ligne); border-radius: 100px; font-size: 0.9rem; transition: border-color 0.25s ease, background 0.25s ease; }
  .choix-inline input:checked + span { border-color: var(--cuivre); background: rgba(201,122,69,0.1); }

  .champ-duo { display: grid; grid-template-columns: 1fr 1fr; gap: 1.6rem; }
  .champ { display: grid; gap: 0.5rem; }
  .champ label { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--sauge); }
  .champ input, .champ textarea { font-family: var(--font-texte); font-size: 0.95rem; padding: 0.9rem 1rem; background: var(--terre-2); border: 1px solid var(--ligne); border-radius: 10px; color: var(--creme); transition: border-color 0.25s ease; }
  .champ input:focus, .champ textarea:focus { outline: none; border-color: var(--cuivre); }
  .form-statut { font-family: var(--font-mono); font-size: 0.82rem; min-height: 1.4em; }
  .form-statut.ok { color: var(--cuivre-clair); }
  .form-statut.erreur { color: #e0795e; }

  .infos { display: grid; gap: 2.4rem; align-content: start; }
  .infos-bloc h2 { font-size: 1.3rem; margin-bottom: 0.9rem; letter-spacing: -0.02em; }
  .infos-bloc address { font-style: normal; color: var(--sauge); margin-bottom: 0.8rem; }
  .infos-lien { display: block; margin-bottom: 0.45rem; transition: color 0.25s ease; }
  .infos-lien:hover { color: var(--cuivre-clair); }
  .horaires { list-style: none; border-top: 1px solid var(--ligne); }
  .horaires li { display: flex; justify-content: space-between; gap: 1rem; padding-block: 0.5rem; border-bottom: 1px solid var(--ligne); font-size: 0.86rem; }
  .horaires li span:first-child { color: var(--sauge); }
  .infos-note { color: var(--sauge); font-size: 0.9rem; }

  .carte-section { position: relative; }
  #carte { height: 420px; width: 100%; filter: invert(1) hue-rotate(150deg) saturate(0.45) brightness(0.92); z-index: 1; }

  @media (max-width: 900px) {
    .resa-grille { grid-template-columns: 1fr; gap: 3.5rem; }
    .modele-choix { grid-template-columns: 1fr; }
    .champ-duo { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ web3formsKey, geo, nomMarque }}>
  const params = new URLSearchParams(window.location.search);
  const slug = params.get("modele");
  if (slug) {
    document.querySelectorAll('input[name="modele"]').forEach((r) => {
      if (r.value.toLowerCase() === slug.toLowerCase()) r.checked = true;
    });
    const demande = document.querySelector('input[name="demande"][value="Devis / commande"]');
    if (demande) demande.checked = true;
  }

  const formulaire = document.getElementById("formulaire");
  const statut = document.getElementById("form-statut");
  formulaire?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!formulaire.reportValidity()) return;
    statut.textContent = "Envoi en cours…";
    statut.className = "form-statut";
    const donnees = new FormData(formulaire);
    donnees.append("access_key", web3formsKey);
    donnees.append("subject", `Demande ${nomMarque} — essai / commande`);
    try {
      const r = await fetch("https://api.web3forms.com/submit", { method: "POST", body: donnees });
      const res = await r.json();
      if (res.success) {
        statut.textContent = "Demande envoyée. L'atelier vous recontacte sous 24h.";
        statut.className = "form-statut ok";
        formulaire.reset();
      } else throw new Error(res.message);
    } catch {
      statut.textContent = "L'envoi a échoué. Appelez-nous ou réessayez dans un instant.";
      statut.className = "form-statut erreur";
    }
  });

  const s = document.createElement("script");
  s.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
  s.integrity = "sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=";
  s.crossOrigin = "";
  s.onload = () => {
    const carte = L.map("carte", { scrollWheelZoom: false }).setView([geo.lat, geo.lng], 14);
    L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
      maxZoom: 19,
    }).addTo(carte);
    L.marker([geo.lat, geo.lng]).addTo(carte).bindPopup(`${nomMarque} — Atelier`);
  };
  document.body.appendChild(s);
</script>
