---
import Layout from "@layouts/Layout.astro";
import { client } from "@data/client";

export function getStaticPaths() {
  return client.modeles.map((modele) => ({
    params: { slug: modele.slug },
    props: { modele },
  }));
}

const { modele } = Astro.props;

const titre = `${client.nom} ${modele.nom} — VTT électrique ${modele.segment.toLowerCase()} | ${modele.prix.toLocaleString("fr-FR")} €`;
const description = `${modele.promesse} ${modele.specs.find((s) => s.label === "Autonomie")?.valeur ?? ""} km d'autonomie. VTT électrique ${client.nom} ${modele.nom}, carbone, assemblé à la main au pied du Canigou.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${client.nom} ${modele.nom}`,
  description: modele.promesse,
  brand: { "@type": "Brand", name: client.nom },
  category: "VTT électrique",
  image: modele.finitions.map((f) => f.image),
  offers: {
    "@type": "Offer",
    price: modele.prix,
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
    url: `${client.siteUrl}/modeles/${modele.slug}`,
    seller: { "@type": "Organization", name: client.nomComplet },
  },
  additionalProperty: modele.specs.map((s) => ({
    "@type": "PropertyValue",
    name: s.label,
    value: `${s.valeur} ${s.unite}`.trim(),
  })),
};

const autres = client.modeles.filter((m) => m.slug !== modele.slug);
---

<Layout title={titre} description={description} jsonLd={jsonLd}>
  <!-- ======================= HERO PRODUIT ======================= -->
  <section class="ph">
    <div class="ph-media">
      <img
        id="ph-image"
        src={modele.finitions[0].image}
        alt={`${client.nom} ${modele.nom} — ${modele.finitions[0].nom}`}
        fetchpriority="high"
      />
    </div>
    <div class="ph-voile" aria-hidden="true"></div>

    <div class="conteneur ph-contenu">
      <a href="/modeles" class="ph-retour">← La collection</a>
      <p class="etiquette">{modele.segment} · Modèle {modele.ordre}</p>
      <h1 class="ph-titre">{modele.nom}</h1>
      <p class="ph-accroche">{modele.accroche}</p>

      <!-- Configurateur finitions -->
      <div class="config">
        <span class="config-label" id="config-nom">{modele.finitions[0].nom}</span>
        <div class="config-puces" role="group" aria-label="Choisir une finition">
          {
            modele.finitions.map((f, i) => (
              <button
                class:list={["config-puce", { actif: i === 0 }]}
                style={`--c:${f.hex}`}
                data-image={f.image}
                data-nom={f.nom}
                aria-label={f.nom}
                title={f.nom}
              />
            ))
          }
        </div>
      </div>

      <!-- Sélecteur de tailles -->
      <div class="tailles">
        <span class="tailles-label">Taille</span>
        <div class="tailles-puces" role="group" aria-label="Choisir une taille">
          {
            modele.tailles.map((t, i) => (
              <button class:list={["taille-puce", { actif: i === 0 }]} data-taille={t}>{t}</button>
            ))
          }
        </div>
        <a href="#geo" class="tailles-guide">Guide des tailles</a>
      </div>

      <div class="ph-actions">
        <a href={`/reservation?modele=${modele.slug}`} class="btn btn-plein btn-fleche">
          Configurer — dès {modele.prix.toLocaleString("fr-FR")} €
        </a>
        <a href="#film" class="btn btn-vide">Voir le film</a>
      </div>
    </div>
  </section>

  <!-- ======================= SPECS ======================= -->
  <section class="specs" id="geo">
    <div class="conteneur">
      <p class="etiquette reveler">Fiche technique</p>
      <div class="specs-grille">
        {
          modele.specs.map((s) => (
            <div class="spec reveler">
              <span class="spec-v">{s.valeur}<small>{s.unite}</small></span>
              <span class="spec-l">{s.label}</span>
            </div>
          ))
        }
      </div>
      <p class="specs-note">{client.noteVae}</p>
    </div>
  </section>

  <!-- ======================= BLOC FILM (VIDÉO) ======================= -->
  <section class="film" id="film">
    <div class="conteneur film-tete reveler">
      <p class="etiquette">En mouvement</p>
      <h2 class="titre-section">Le <em>film</em></h2>
    </div>
    <div class="film-cadre reveler">
      <!--
        Bloc vidéo : le poster (image) s'affiche immédiatement.
        Déposer le fichier dans public/videos/ puis décommenter <source>
        pour activer la lecture automatique en boucle.
      -->
      <video class="film-video" poster={modele.film.poster} autoplay muted loop playsinline preload="none">
        <!-- <source src={modele.film.src} type="video/mp4" /> -->
      </video>
      <button class="film-play" id="film-play" aria-label="Lire le film">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
      </button>
      <span class="film-legende">{modele.film.legende}</span>
    </div>
  </section>

  <!-- ======================= POINTS FORTS ======================= -->
  <section class="forts">
    <div class="topo" aria-hidden="true"></div>
    <div class="conteneur forts-grille">
      <div class="forts-texte reveler">
        <p class="etiquette">Ce qui change tout</p>
        <h2 class="titre-section">Pensé<br /><em>au gramme près</em></h2>
        <p class="forts-promesse">{modele.promesse}</p>
      </div>
      <ul class="forts-liste">
        {
          modele.pointsForts.map((p, i) => (
            <li class="reveler" style={`transition-delay:${i * 0.07}s`}>
              <span class="forts-num">{String(i + 1).padStart(2, "0")}</span>
              {p}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ======================= GALERIE (IMAGES) ======================= -->
  <section class="galerie">
    <div class="conteneur galerie-tete reveler">
      <p class="etiquette">Galerie</p>
      <h2 class="titre-section">Sous tous<br /><em>les angles</em></h2>
    </div>
    <div class="galerie-grille">
      {
        modele.galerie.map((img, i) => (
          <figure class:list={["galerie-item reveler", { large: i === 0 }]}>
            <img src={img} alt={`${client.nom} ${modele.nom} — vue ${i + 1}`} loading="lazy" />
            {/* <img src={modele.galerieLocale?.[i]} alt={`${client.nom} ${modele.nom} — vue ${i + 1}`} loading="lazy" /> */}
          </figure>
        ))
      }
    </div>
  </section>

  <!-- ======================= SUITE ======================= -->
  <section class="suite">
    <div class="conteneur">
      <div class="suite-cta reveler">
        <h2 class="suite-titre">Prêt à rouler en {modele.nom} ?</h2>
        <div class="ph-actions">
          <a href={`/reservation?modele=${modele.slug}`} class="btn btn-plein btn-fleche">Configurer & commander</a>
          <a href="/reservation" class="btn btn-vide">Réserver un essai</a>
        </div>
      </div>

      <p class="etiquette reveler" style="margin-top:5rem">Autres modèles</p>
      <div class="suite-autres">
        {
          autres.map((m) => (
            <a href={`/modeles/${m.slug}`} class="suite-item reveler">
              <div class="suite-image">
                <img src={m.finitions[0].image} alt={`${client.nom} ${m.nom}`} loading="lazy" />
              </div>
              <div class="suite-info">
                <span class="suite-segment">{m.segment}</span>
                <h3 class="suite-nom">{m.nom}</h3>
                <span class="suite-prix">dès {m.prix.toLocaleString("fr-FR")} € →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .ph { position: relative; min-height: 100svh; display: flex; align-items: flex-end; overflow: hidden; }
  .ph-media { position: absolute; inset: 0; }
  .ph-media img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.92) contrast(1.04); transition: opacity 0.4s ease; }
  .ph-media img.fade { opacity: 0; }
  .ph-voile { position: absolute; inset: 0; background: linear-gradient(to top, var(--terre) 4%, transparent 50%), linear-gradient(to right, rgba(14,19,16,0.65), transparent 55%); }
  .ph-contenu { position: relative; z-index: 2; padding-bottom: 5rem; }
  .ph-retour { font-family: var(--font-mono); font-size: 0.78rem; color: var(--sauge); display: inline-block; margin-bottom: 1.6rem; transition: color 0.25s ease; }
  .ph-retour:hover { color: var(--cuivre-clair); }
  .ph-titre { font-size: clamp(4rem, 15vw, 11rem); line-height: 0.84; letter-spacing: -0.03em; }
  .ph-accroche { font-size: clamp(1.3rem, 3vw, 2.2rem); color: var(--sauge); margin: 0.6rem 0 2rem; }

  .config { display: flex; align-items: center; gap: 1.4rem; margin-bottom: 1.4rem; }
  .config-label { font-family: var(--font-mono); font-size: 0.82rem; min-width: 10rem; }
  .config-puces { display: flex; gap: 0.8rem; }
  .config-puce { width: 2.2rem; height: 2.2rem; border-radius: 50%; background: var(--c); border: 1px solid rgba(236,231,221,0.25); cursor: pointer; position: relative; transition: transform 0.25s ease; }
  .config-puce::after { content: ""; position: absolute; inset: -5px; border: 1px solid transparent; border-radius: 50%; transition: border-color 0.25s ease; }
  .config-puce:hover { transform: scale(1.1); }
  .config-puce.actif::after { border-color: var(--cuivre-clair); }

  .tailles { display: flex; align-items: center; gap: 1.4rem; margin-bottom: 2.2rem; flex-wrap: wrap; }
  .tailles-label { font-family: var(--font-mono); font-size: 0.82rem; min-width: 10rem; }
  .tailles-puces { display: flex; gap: 0.6rem; }
  .taille-puce {
    font-family: var(--font-mono); font-size: 0.82rem;
    width: 2.6rem; height: 2.6rem;
    border: 1px solid var(--ligne); background: transparent; color: var(--creme);
    border-radius: 8px; cursor: pointer;
    transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease;
  }
  .taille-puce:hover { border-color: var(--cuivre); }
  .taille-puce.actif { background: var(--cuivre); border-color: var(--cuivre); color: var(--terre); }
  .tailles-guide { font-family: var(--font-mono); font-size: 0.74rem; color: var(--sauge); text-decoration: underline; text-underline-offset: 3px; }
  .tailles-guide:hover { color: var(--cuivre-clair); }

  .ph-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .specs { padding-block: 6rem; }
  .specs-grille { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1px; background: var(--ligne); border: 1px solid var(--ligne); border-radius: 12px; overflow: hidden; margin-top: 2rem; }
  .spec { background: var(--terre); padding: 1.8rem 1.4rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .spec-v { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1; }
  .spec-v small { font-size: 0.8rem; color: var(--sauge); margin-left: 3px; }
  .spec-l { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sauge); }
  .specs-note { margin-top: 1.4rem; font-family: var(--font-mono); font-size: 0.72rem; color: var(--sauge-fonce); max-width: 90ch; line-height: 1.6; }

  .film { padding-block: 5rem; }
  .film-tete { margin-bottom: 2.5rem; }
  .film-cadre { position: relative; aspect-ratio: 16 / 9; overflow: hidden; border-radius: 16px; border: 1px solid var(--ligne); }
  .film-video { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.92); }
  .film-play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 5.5rem; height: 5.5rem; border-radius: 50%;
    border: 1px solid var(--creme); background: rgba(14,19,16,0.4); backdrop-filter: blur(4px);
    color: var(--creme); cursor: pointer; display: grid; place-items: center;
    transition: background 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }
  .film-play svg { width: 2rem; height: 2rem; margin-left: 3px; }
  .film-play:hover { background: var(--cuivre); border-color: var(--cuivre); color: var(--terre); transform: translate(-50%, -50%) scale(1.06); }
  .film-play.cache { opacity: 0; pointer-events: none; }
  .film-legende { position: absolute; bottom: 1.2rem; left: 1.4rem; font-family: var(--font-mono); font-size: 0.72rem; color: var(--creme); background: rgba(14,19,16,0.55); padding: 0.4rem 0.8rem; border-radius: 6px; backdrop-filter: blur(4px); }

  .forts { position: relative; padding-block: 6rem; overflow: hidden; }
  .forts-grille { position: relative; z-index: 1; display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 4rem; align-items: center; }
  .forts-promesse { color: var(--sauge); max-width: 46ch; margin-top: 1rem; }
  .forts-liste { list-style: none; border-top: 1px solid var(--ligne); }
  .forts-liste li {
    display: flex; align-items: baseline; gap: 1.4rem;
    padding-block: 1.6rem; border-bottom: 1px solid var(--ligne);
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(1.2rem, 2.4vw, 1.8rem); letter-spacing: -0.02em;
  }
  .forts-num { font-family: var(--font-mono); font-size: 0.8rem; color: var(--cuivre-clair); }

  .galerie { padding-block: 6rem; }
  .galerie-tete { margin-bottom: 2.5rem; }
  .galerie-grille { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .galerie-item { overflow: hidden; border-radius: 14px; aspect-ratio: 3 / 2; }
  .galerie-item.large { grid-column: 1 / -1; aspect-ratio: 21 / 9; }
  .galerie-item img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.92); transition: transform 0.8s cubic-bezier(0.2,0.7,0.2,1); }
  .galerie-item:hover img { transform: scale(1.04); }

  .suite { padding-block: 6rem 8rem; border-top: 1px solid var(--ligne); }
  .suite-cta { text-align: center; }
  .suite-titre { font-size: clamp(2.2rem, 6vw, 4.2rem); margin-bottom: 2rem; letter-spacing: -0.03em; }
  .suite-cta .ph-actions { justify-content: center; }
  .suite-autres { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
  .suite-item { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--ligne); border-radius: 14px; overflow: hidden; transition: background 0.35s ease; }
  .suite-item:hover { background: var(--terre-2); }
  .suite-image { overflow: hidden; }
  .suite-image img { width: 100%; height: 100%; object-fit: cover; min-height: 170px; transition: transform 0.7s ease; }
  .suite-item:hover .suite-image img { transform: scale(1.06); }
  .suite-info { padding: 1.8rem; display: flex; flex-direction: column; justify-content: center; gap: 0.4rem; }
  .suite-segment { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cuivre-clair); }
  .suite-nom { font-size: 2.2rem; letter-spacing: -0.02em; }
  .suite-prix { font-family: var(--font-mono); font-size: 0.82rem; color: var(--sauge); }

  @media (max-width: 900px) {
    .specs-grille { grid-template-columns: repeat(3, 1fr); }
    .forts-grille { grid-template-columns: 1fr; gap: 2rem; }
    .galerie-grille { grid-template-columns: 1fr; }
    .galerie-item, .galerie-item.large { aspect-ratio: 16 / 10; }
    .suite-autres { grid-template-columns: 1fr; }
    .config, .tailles { flex-direction: column; align-items: flex-start; gap: 0.9rem; }
  }
  @media (max-width: 520px) {
    .specs-grille { grid-template-columns: 1fr 1fr; }
    .suite-item { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Configurateur : swap image au clic finition
  const image = document.getElementById("ph-image") as HTMLImageElement | null;
  const nomFinition = document.getElementById("config-nom");
  const puces = document.querySelectorAll<HTMLButtonElement>(".config-puce");
  puces.forEach((puce) => {
    puce.addEventListener("click", () => {
      const src = puce.dataset.image;
      const nom = puce.dataset.nom;
      if (!image || !src) return;
      image.classList.add("fade");
      const tmp = new Image();
      tmp.onload = () => { image.src = src; image.classList.remove("fade"); };
      tmp.src = src;
      if (nomFinition && nom) nomFinition.textContent = nom;
      puces.forEach((p) => p.classList.remove("actif"));
      puce.classList.add("actif");
    });
  });

  // Sélecteur de tailles
  const taillePuces = document.querySelectorAll<HTMLButtonElement>(".taille-puce");
  taillePuces.forEach((t) => {
    t.addEventListener("click", () => {
      taillePuces.forEach((p) => p.classList.remove("actif"));
      t.classList.add("actif");
    });
  });

  // Bouton lecture film
  const video = document.querySelector<HTMLVideoElement>(".film-video");
  const play = document.getElementById("film-play");
  const aSource = !!video?.querySelector("source");
  if (!aSource && play) {
    play.addEventListener("click", () => play.classList.add("cache"));
  } else if (play && video) {
    play.addEventListener("click", () => { video.play(); play.classList.add("cache"); });
  }
</script>
