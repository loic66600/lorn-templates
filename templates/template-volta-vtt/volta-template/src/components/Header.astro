---
import { client } from "@data/client";

const liens = [
  { href: "/modeles", label: "Les modèles" },
  { href: "/reservation", label: "Essai & atelier" },
];
const cheminActuel = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="entete" id="entete">
  <div class="conteneur entete-inner">
    <a href="/" class="logo" aria-label={`${client.nom} — accueil`}>
      <svg class="logo-icone" viewBox="0 0 32 24" aria-hidden="true">
        <path d="M2 21 L11 6 L17 15 L21 9 L30 21 Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
      </svg>
      <span class="logo-mot">{client.nom}</span>
    </a>

    <nav class="nav" id="nav">
      <a href="/" class:list={["nav-lien", { actif: cheminActuel === "/" }]}>Accueil</a>
      {
        liens.map((l) => (
          <a href={l.href} class:list={["nav-lien", { actif: cheminActuel.startsWith(l.href) }]}>
            {l.label}
          </a>
        ))
      }
      <a href="/reservation" class="nav-cta">Configurer</a>
    </nav>

    <button class="burger" id="burger" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .entete {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .entete.colle {
    background: rgba(14, 19, 16, 0.85);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--ligne);
  }
  .entete-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.3rem;
  }
  .logo { display: flex; align-items: center; gap: 0.7rem; color: var(--creme); }
  .logo-icone { width: 32px; height: 24px; color: var(--cuivre); }
  .logo-mot {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.06em;
  }
  .nav { display: flex; align-items: center; gap: 2.3rem; }
  .nav-lien {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--creme);
    opacity: 0.74;
    transition: opacity 0.25s ease, color 0.25s ease;
  }
  .nav-lien:hover, .nav-lien.actif { opacity: 1; color: var(--cuivre-clair); }
  .nav-cta {
    font-size: 0.88rem;
    font-weight: 500;
    padding: 0.55rem 1.4rem;
    border: 1px solid var(--creme);
    border-radius: 100px;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  .nav-cta:hover { background: var(--cuivre); border-color: var(--cuivre); color: var(--terre); }
  .burger {
    display: none;
    flex-direction: column;
    gap: 7px;
    background: none; border: none; cursor: pointer; padding: 0.5rem;
  }
  .burger span { width: 26px; height: 1.5px; background: var(--creme); transition: transform 0.3s ease; }

  @media (max-width: 880px) {
    .burger { display: flex; }
    .nav {
      position: fixed; inset: 0;
      flex-direction: column; justify-content: center; gap: 2.6rem;
      background: var(--terre);
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.2,0.7,0.2,1);
    }
    .nav.ouvert { transform: none; }
    .nav-lien { font-size: 1.4rem; }
    .burger[aria-expanded="true"] span:first-child { transform: translateY(4.5px) rotate(45deg); }
    .burger[aria-expanded="true"] span:last-child { transform: translateY(-4px) rotate(-45deg); }
  }
</style>

<script>
  const entete = document.getElementById("entete");
  const burger = document.getElementById("burger");
  const nav = document.getElementById("nav");
  const onScroll = () => entete?.classList.toggle("colle", window.scrollY > 40);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
  burger?.addEventListener("click", () => {
    const ouvert = nav?.classList.toggle("ouvert");
    burger.setAttribute("aria-expanded", String(!!ouvert));
  });
</script>
