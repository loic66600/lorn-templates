---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<Layout title={`Contact & Devis — ${client.nom}`} description={`Contactez ${client.nom} pour un devis gratuit. Charpente, couverture, toiture Perpignan (66). Réponse sous 48h.`}>

  <nav class="navbar scrolled" id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <div class="nav-logo-icon">🏠</div>
        <div class="nav-logo-text">
          <span class="nav-logo-name">{client.nom}</span>
          <span class="nav-logo-sub">{client.metier}</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href="/">Accueil</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/realisations">Réalisations</a></li>
        <li class="nav-dropdown">
          <button class="nav-dropdown-toggle">
            Plus
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href="/tarifs">Tarifs</a>
            <a href="/a-propos">À Propos</a>
          </div>
        </li>
        <li><a href="/contact" class="active">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
        <a href="/contact" class="btn btn-accent">Devis gratuit</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
    <div class="nav-mobile" id="mobile-menu">
      <a href="/">Accueil</a><a href="/services">Services</a><a href="/realisations">Réalisations</a>
      <a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a><a href="/contact">Contact</a>
      <a href="/contact" class="mob-cta">Devis gratuit →</a>
    </div>
  </nav>

  <!-- HEADER -->
  <header class="page-header-simple">
    <div class="container">
      <nav class="breadcrumb"><a href="/">Accueil</a><span>›</span><span>Contact</span></nav>
      <div class="eyebrow reveal">Gratuit & sans engagement</div>
      <h1 class="font-display page-title reveal reveal-d1">Demandez votre devis</h1>
      <p class="page-sub reveal reveal-d2">Déplacement gratuit sur Perpignan et tout le 66. Réponse sous 48h garantie.</p>
    </div>
  </header>

  <!-- CONTACT GRID -->
  <section class="section">
    <div class="container contact-grid">

      <!-- INFOS -->
      <div class="contact-infos slide-left">

        <!-- Urgence -->
        {client.urgence && (
          <div class="urgence-card">
            <div class="urgence-card-head">
              <span>⚡</span>
              <strong class="font-display">Urgence toiture</strong>
            </div>
            <p>Fuite, tuile cassée, tempête ? Appelez le numéro d'urgence disponible 7j/7.</p>
            <a href={client.urgenceTelLink} class="btn btn-accent" style="margin-top:12px;width:100%;justify-content:center">
              {client.urgenceTel}
            </a>
          </div>
        )}

        <!-- Coordonnées -->
        <div class="info-block">
          <h3 class="info-block-title font-display">Coordonnées</h3>
          <div class="info-items">
            <div class="info-item">
              <span class="info-icon">📞</span>
              <div>
                <small>Téléphone</small>
                <a href={client.telephoneLink}>{client.telephone}</a>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">✉️</span>
              <div>
                <small>Email</small>
                <a href={`mailto:${client.email}`}>{client.email}</a>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">📍</span>
              <div>
                <small>Adresse</small>
                <span>{client.adresse}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Horaires -->
        <div class="info-block">
          <h3 class="info-block-title font-display">Horaires</h3>
          <div class="horaires-list">
            {client.horaires.map(h => (
              <div class="horaire-row">
                <span class="horaire-jour font-display">{h.jour}</span>
                <span class={`horaire-val ${h.horaire === 'Fermé' ? 'ferme' : ''}`}>{h.horaire}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Zone -->
        <div class="info-block">
          <h3 class="info-block-title font-display">Zone d'intervention</h3>
          <p class="info-zone-text">{client.departement} — rayon {client.rayonKm} km autour de Perpignan.</p>
          <div class="zones-tags">
            {client.zones.slice(0, 8).map(z => <span class="zone-tag">{z}</span>)}
            <span class="zone-tag zone-more">+{client.zones.length - 8} communes</span>
          </div>
        </div>
      </div>

      <!-- FORMULAIRE -->
      <div class="contact-form-wrap slide-right">
        <div class="form-card" id="contactForm">
          <h2 class="form-title font-display">Votre projet en détail</h2>
          <p class="form-sub">Plus votre description est précise, plus notre devis sera exact.</p>

          <div class="form-fields">
            <div class="f-row">
              <div class="fg">
                <label for="fNom">Prénom & Nom *</label>
                <input type="text" id="fNom" placeholder="Jean Dupont" required />
              </div>
              <div class="fg">
                <label for="fTel">Téléphone *</label>
                <input type="tel" id="fTel" placeholder="06 00 00 00 00" required />
              </div>
            </div>

            <div class="fg">
              <label for="fEmail">Email</label>
              <input type="email" id="fEmail" placeholder="jean@exemple.fr" />
            </div>

            <div class="fg">
              <label for="fVille">Commune du chantier *</label>
              <input type="text" id="fVille" placeholder="Ex : Perpignan, Canet, Thuir…" required />
            </div>

            <div class="f-row">
              <div class="fg">
                <label for="fPresta">Type de travaux *</label>
                <select id="fPresta" required>
                  <option value="">Choisir…</option>
                  {client.services.map(s => <option value={s.titre}>{s.icone} {s.titre}</option>)}
                  <option value="Urgence">⚡ Urgence</option>
                  <option value="Autre">Autre / Je ne sais pas encore</option>
                </select>
              </div>
              <div class="fg">
                <label for="fSurface">Surface estimée</label>
                <input type="text" id="fSurface" placeholder="Ex : 150 m², je ne sais pas…" />
              </div>
            </div>

            <div class="fg">
              <label for="fMsg">Description du projet</label>
              <textarea id="fMsg" rows="4" placeholder="Décrivez votre projet : type de toiture, âge, problèmes constatés, délai souhaité…"></textarea>
            </div>

            <button type="button" class="btn btn-accent btn-lg form-submit" id="submitBtn" style="width:100%;justify-content:center">
              Envoyer ma demande →
            </button>
          </div>
        </div>

        <!-- Succès -->
        <div class="form-success" id="formSuccess" style="display:none">
          <div class="success-icon">✅</div>
          <h3 class="font-display">Demande reçue !</h3>
          <p>Nous vous recontactons sous 48h pour fixer la visite gratuite.</p>
          <p style="margin-top:8px;font-size:.9rem;color:var(--text-muted)">
            En attendant : <a href={client.telephoneLink}>{client.telephone}</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CARTE -->
  {client.googleMapsEmbed && (
    <section class="map-section">
      <iframe
        src={client.googleMapsEmbed}
        width="100%" height="400"
        style="border:0"
        allowfullscreen loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Localisation"
      />
    </section>
  )}

  <footer class="footer">
    <div class="container">
      <div class="footer-bottom" style="border-top:none;padding-top:0">
        <p>© {new Date().getFullYear()} {client.nom} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
      </div>
    </div>
  </footer>

</Layout>

<script define:vars={{ web3Key, emailClient: client.email, nomClient: client.nom }}>
  const btn = document.getElementById('submitBtn'),
        form = document.getElementById('contactForm'),
        ok   = document.getElementById('formSuccess');

  btn?.addEventListener('click', async () => {
    const nom      = (document.getElementById('fNom') as HTMLInputElement)?.value || '',
          tel      = (document.getElementById('fTel') as HTMLInputElement)?.value || '',
          email    = (document.getElementById('fEmail') as HTMLInputElement)?.value || '',
          ville    = (document.getElementById('fVille') as HTMLInputElement)?.value || '',
          presta   = (document.getElementById('fPresta') as HTMLSelectElement)?.value || '',
          surface  = (document.getElementById('fSurface') as HTMLInputElement)?.value || '',
          msg      = (document.getElementById('fMsg') as HTMLTextAreaElement)?.value || '';

    if (!nom || !tel || !ville || !presta) { alert('Remplissez les champs obligatoires (*)'); return; }
    btn.disabled = true; btn.textContent = 'Envoi en cours…';

    if (web3Key) {
      try {
        const r = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_key: web3Key,
            subject: `Devis toiture — ${presta} — ${nom} (${ville})`,
            from_name: nom, telephone: tel, email,
            commune: ville, prestation: presta, surface, message: msg,
          }),
        });
        const d = await r.json();
        if (d.success && form && ok) { form.style.display = 'none'; ok.style.display = 'flex'; return; }
      } catch(e) {}
    }
    // Fallback mailto
    window.location.href = 'mailto:' + emailClient +
      '?subject=' + encodeURIComponent('Devis toiture — ' + presta + ' — ' + ville) +
      '&body=' + encodeURIComponent(`Nom: ${nom}\nTél: ${tel}\nCommune: ${ville}\nPrestation: ${presta}\nSurface: ${surface}\n\n${msg}`);
  });
</script>

<style>
  .page-header-simple { padding:calc(var(--nav-h) + 4rem) 0 4rem; background:var(--bg-alt); border-bottom:1px solid var(--border); }
  .breadcrumb { display:flex; gap:8px; font-size:13px; color:var(--text-muted); margin-bottom:16px; }
  .breadcrumb a { color:var(--text-muted); }
  .page-title { font-size:clamp(2rem,4vw,3.2rem); font-weight:800; letter-spacing:-0.04em; line-height:1.1; margin:12px 0 16px; }
  .page-sub { font-size:1rem; color:var(--text-muted); max-width:500px; line-height:1.7; }

  .contact-grid { display:grid; grid-template-columns:380px 1fr; gap:64px; align-items:start; }

  /* Infos */
  .urgence-card {
    background:var(--primary); border-radius:var(--radius-md); padding:20px;
    margin-bottom:20px;
  }
  .urgence-card-head { display:flex; align-items:center; gap:10px; color:var(--accent); font-size:1.1rem; margin-bottom:10px; }
  .urgence-card p { font-size:.88rem; color:rgba(255,255,255,0.6); line-height:1.7; }

  .info-block { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-md); padding:20px; margin-bottom:16px; }
  .info-block-title { font-size:.8rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:var(--text-muted); margin-bottom:14px; }

  .info-items { display:flex; flex-direction:column; gap:14px; }
  .info-item { display:flex; align-items:flex-start; gap:12px; }
  .info-icon { font-size:1.1rem; margin-top:2px; flex-shrink:0; }
  .info-item small { display:block; font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px; }
  .info-item a, .info-item span { font-size:.9rem; font-weight:600; color:var(--text); }
  .info-item a:hover { color:var(--accent); }

  .horaires-list { display:flex; flex-direction:column; gap:2px; }
  .horaire-row { display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border); font-size:.88rem; }
  .horaire-row:last-child { border-bottom:none; }
  .horaire-jour { font-weight:700; color:var(--text); }
  .horaire-val { color:var(--text-muted); }
  .horaire-val.ferme { color:var(--text-light); }

  .info-zone-text { font-size:.88rem; color:var(--text-muted); margin-bottom:12px; line-height:1.6; }
  .zones-tags { display:flex; flex-wrap:wrap; gap:6px; }
  .zone-tag { background:var(--bg-alt); border:1px solid var(--border); padding:4px 10px; border-radius:var(--radius-full); font-size:11px; font-weight:600; color:var(--text-muted); }
  .zone-more { background:var(--accent); border-color:var(--accent); color:white; }

  /* Formulaire */
  .form-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-md); padding:36px; }
  .form-title { font-size:1.5rem; font-weight:800; letter-spacing:-0.03em; margin-bottom:8px; }
  .form-sub { font-size:.9rem; color:var(--text-muted); margin-bottom:28px; }
  .form-fields { display:flex; flex-direction:column; gap:16px; }
  .f-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .fg { display:flex; flex-direction:column; gap:6px; }
  .fg label { font-size:13px; font-weight:700; color:var(--text); font-family:var(--font-display); }
  .fg input, .fg select, .fg textarea {
    padding:11px 14px; border:1.5px solid var(--border); border-radius:var(--radius);
    background:var(--bg); font-family:var(--font-body); font-size:.9rem; color:var(--text);
    transition:border-color .2s;
  }
  .fg input:focus, .fg select:focus, .fg textarea:focus { outline:none; border-color:var(--accent); }
  .fg textarea { resize:vertical; min-height:110px; }
  .form-submit { font-size:1rem; }

  .form-success {
    background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-md);
    padding:48px 36px; flex-direction:column; align-items:center; text-align:center; gap:12px;
  }
  .success-icon { font-size:3rem; }
  .form-success h3 { font-size:1.5rem; font-weight:800; }
  .form-success p { color:var(--text-muted); line-height:1.7; }
  .form-success a { color:var(--accent); font-weight:700; }

  .map-section { height:400px; }
  .map-section iframe { display:block; }

  @media(max-width:1024px) {
    .contact-grid { grid-template-columns:1fr; }
    .contact-infos { order:2; }
    .contact-form-wrap { order:1; }
  }
  @media(max-width:640px) {
    .f-row { grid-template-columns:1fr; }
    .form-card { padding:24px; }
  }
</style>
