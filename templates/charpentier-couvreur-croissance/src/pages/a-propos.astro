---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const { apropos } = client;
---

<Layout title={`À Propos — ${client.nom}`} description={`Découvrez ${client.nom}, ${client.metier} à ${client.ville} depuis 1998. Compagnon du Tour de France, garantie décennale, équipe de 6 compagnons.`}>

  <!-- NAVBAR -->
  <nav class="navbar scrolled" id="navbar">
    <div class="nav-inner">
      <a href={import.meta.env.BASE_URL} class="nav-logo">
        <div class="nav-logo-icon">🏠</div>
        <div class="nav-logo-text">
          <span class="nav-logo-name">{client.nom}</span>
          <span class="nav-logo-sub">{client.metier}</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href={import.meta.env.BASE_URL}>Accueil</a></li>
        <li><a href={`${base}/services`}>Services</a></li>
        <li><a href={`${base}/realisations`}>Réalisations</a></li>
        <li class="nav-dropdown">
          <button class="nav-dropdown-toggle">
            Plus
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href={`${base}/tarifs`}>Tarifs</a>
            <a href={`${base}/a-propos`} class="active">À Propos</a>
          </div>
        </li>
        <li><a href={`${base}/contact`}>Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
        <a href={`${base}/contact`} class="btn btn-accent">Devis gratuit</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
    <div class="nav-mobile" id="mobile-menu">
      <a href={import.meta.env.BASE_URL}>Accueil</a>
      <a href={`${base}/services`}>Services</a>
      <a href={`${base}/realisations`}>Réalisations</a>
      <a href={`${base}/tarifs`}>Tarifs</a>
      <a href={`${base}/a-propos`}>À Propos</a>
      <a href={`${base}/contact`}>Contact</a>
      <a href={`${base}/contact`} class="mob-cta">Devis gratuit →</a>
    </div>
  </nav>

  <!-- HERO ABOUT -->
  <header class="about-hero">
    <div class="container about-hero-inner">
      <div class="about-hero-text">
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href={import.meta.env.BASE_URL}>Accueil</a><span>›</span><span>À Propos</span>
        </nav>
        <div class="eyebrow reveal">Notre histoire</div>
        <h1 class="font-display about-title reveal reveal-d1">{apropos.titre}</h1>
        <p class="about-sub reveal reveal-d2">{apropos.sousTitre}</p>
        <div class="about-certs reveal reveal-d3">
          {apropos.certifications.map(c => (
            <span class="cert-chip">✓ {c}</span>
          ))}
        </div>
      </div>
      <div class="about-hero-img reveal reveal-d2">
        <div class="img-zoom">
          <img src={apropos.image} alt={apropos.imageAlt} loading="eager" />
        </div>
        <div class="about-exp-badge font-display">
          <span class="about-exp-num">{client.stats[0].chiffre}{client.stats[0].suffix}</span>
          <span>{client.stats[0].label}</span>
        </div>
      </div>
    </div>
  </header>

  <!-- HISTOIRE -->
  <section class="section">
    <div class="container about-story">
      <div class="story-text slide-left">
        <div class="eyebrow">Notre parcours</div>
        <h2 class="section-title" style="margin-bottom:1.5rem">Du compagnonnage<br>à votre toit</h2>
        <p class="story-p">{apropos.paragraphe1}</p>
        <p class="story-p">{apropos.paragraphe2}</p>
        <div class="story-stats">
          {client.stats.map(s => (
            <div class="story-stat">
              <span class="story-stat-num font-display">{s.chiffre}{s.suffix}</span>
              <span class="story-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="story-img slide-right">
        <div class="img-zoom story-img-wrap">
          <img src={client.heroImage2} alt="Chantier couverture" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- VALEURS -->
  <section class="section-alt">
    <div class="container">
      <div class="sec-center reveal">
        <div class="eyebrow">Ce qui nous guide</div>
        <h2 class="section-title reveal reveal-d1">Nos valeurs</h2>
      </div>
      <div class="values-grid">
        {apropos.valeurs.map((v, i) => (
          <div class={`value-card reveal reveal-d${i + 1}`}>
            <div class="value-icon">{v.icone}</div>
            <h3 class="font-display value-titre">{v.titre}</h3>
            <p class="value-desc">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container faq-wrap">
      <div class="eyebrow reveal">Questions fréquentes</div>
      <h2 class="section-title reveal reveal-d1" style="margin-bottom:2.5rem">On vous répond</h2>
      <div class="faq-list">
        {client.faq.map((item, i) => (
          <details class={`faq-item reveal reveal-d${(i % 3) + 1}`}>
            <summary class="faq-q font-display">{item.question}</summary>
            <p class="faq-a">{item.reponse}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <div class="reveal">
        <div class="eyebrow" style="color:var(--accent)">On vous attend</div>
        <h2 class="font-display cta-title">Parlons de votre projet</h2>
        <p>Visite gratuite, devis sous 48h, réponse garantie.</p>
      </div>
      <div class="reveal reveal-d1">
        <a href={`${base}/contact`} class="btn btn-accent btn-lg">Demander un devis →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .about-hero {
    padding:calc(var(--nav-h) + 5rem) 0 5rem;
    background:var(--bg-alt);
  }
  .about-hero-inner {
    display:grid; grid-template-columns:1fr 420px; gap:64px; align-items:center;
  }
  .breadcrumb { display:flex; align-items:center; gap:8px; font-size:12px; color:var(--text-muted); margin-bottom:16px; }
  .breadcrumb a { color:var(--text-muted); transition:color 0.2s; }
  .breadcrumb a:hover { color:var(--accent); }
  .about-title {
    font-size:clamp(2rem,4vw,3rem); font-weight:800; line-height:1.1;
    letter-spacing:-0.035em; margin:10px 0 16px;
  }
  .about-sub { font-size:1.05rem; color:var(--text-muted); line-height:1.7; max-width:480px; margin-bottom:24px; }
  .about-certs { display:flex; flex-wrap:wrap; gap:8px; }
  .cert-chip {
    background:var(--bg-card); border:1px solid var(--border);
    padding:5px 12px; border-radius:var(--radius-full);
    font-size:11px; font-weight:600; color:var(--text-muted);
  }

  .about-hero-img { position:relative; }
  .about-hero-img .img-zoom { border-radius:var(--radius-md); overflow:hidden; height:420px; }
  .about-hero-img img { width:100%; height:100%; object-fit:cover; }
  .about-exp-badge {
    position:absolute; bottom:-20px; right:20px;
    background:var(--accent); color:white;
    border-radius:var(--radius-md); padding:16px 22px;
    box-shadow:0 8px 32px rgba(200,121,65,0.35);
    display:flex; flex-direction:column; gap:2px; text-align:center;
  }
  .about-exp-num { font-size:2rem; font-weight:800; line-height:1; }
  .about-exp-badge span:last-child { font-size:11px; opacity:0.8; }

  /* STORY */
  .about-story { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
  .story-p { font-size:1rem; color:var(--text-muted); line-height:1.8; margin-bottom:1.2rem; }
  .story-stats { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-top:2rem; }
  .story-stat {
    background:var(--bg-alt); border:1px solid var(--border);
    border-radius:var(--radius-md); padding:18px; text-align:center;
  }
  .story-stat-num { display:block; font-size:1.8rem; font-weight:800; color:var(--accent); line-height:1; }
  .story-stat-label { font-size:12px; color:var(--text-muted); margin-top:4px; display:block; }
  .story-img-wrap { border-radius:var(--radius-md); overflow:hidden; height:440px; }
  .story-img-wrap img { width:100%; height:100%; object-fit:cover; }

  /* VALEURS */
  .sec-center { text-align:center; margin-bottom:3rem; }
  .sec-center .eyebrow { justify-content:center; }
  .sec-center .eyebrow::before { display:none; }
  .values-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-top:3rem; }
  .value-card {
    background:var(--bg-card); border:1px solid var(--border);
    border-radius:var(--radius-md); padding:28px 22px; text-align:center;
    transition:border-color 0.2s, box-shadow 0.2s;
  }
  .value-card:hover { border-color:var(--accent); box-shadow:0 8px 32px rgba(200,121,65,0.1); }
  .value-icon { font-size:2.2rem; margin-bottom:14px; }
  .value-titre { font-size:1rem; font-weight:800; letter-spacing:-0.02em; margin-bottom:10px; }
  .value-desc { font-size:0.88rem; color:var(--text-muted); line-height:1.7; }

  /* FAQ */
  .faq-wrap { max-width:760px; }
  .faq-list { display:flex; flex-direction:column; gap:2px; }
  .faq-item {
    border:1px solid var(--border); border-radius:var(--radius-md);
    overflow:hidden; background:var(--bg-card);
  }
  .faq-q {
    font-size:0.95rem; font-weight:700; padding:18px 20px;
    cursor:pointer; list-style:none; display:flex; justify-content:space-between; align-items:center;
    transition:color 0.2s;
  }
  .faq-q::-webkit-details-marker { display:none; }
  .faq-q::after {
    content:'＋'; font-size:1.2rem; font-weight:400; color:var(--text-muted);
    transition:transform 0.25s;
  }
  details[open] .faq-q::after { content:'－'; }
  details[open] .faq-q { color:var(--accent); }
  .faq-a {
    padding:0 20px 18px; font-size:0.9rem; color:var(--text-muted); line-height:1.75;
  }

  /* CTA */
  .cta-band { background:var(--primary); padding:clamp(3rem,5vw,5rem) 0; }
  .cta-band-inner { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
  .cta-title { font-size:clamp(1.6rem,3vw,2.2rem); font-weight:800; color:white; margin:8px 0; line-height:1.1; letter-spacing:-0.035em; }
  .cta-band p { color:rgba(255,255,255,0.5); font-size:0.95rem; margin-top:6px; }

  /* RESPONSIVE */
  @media(max-width:1024px) {
    .about-hero-inner { grid-template-columns:1fr; }
    .about-hero-img { display:none; }
    .about-story { grid-template-columns:1fr; }
    .story-img { display:none; }
    .values-grid { grid-template-columns:repeat(2,1fr); }
  }
  @media(max-width:600px) {
    .values-grid { grid-template-columns:1fr 1fr; }
    .story-stats { grid-template-columns:1fr 1fr; }
    .cta-band-inner { flex-direction:column; align-items:flex-start; }
  }
</style>
