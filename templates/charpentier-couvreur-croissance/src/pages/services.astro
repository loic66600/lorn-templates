---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title={`Nos Services — ${client.nom}`} description={`Tous les services de ${client.nom} : charpente, couverture tuile et ardoise, zinguerie, isolation toiture, urgences. Perpignan et 66.`}>

  <!-- NAVBAR -->
  <nav class="navbar scrolled" id="navbar">
    <div class="nav-inner">
      <a href={import.meta.env.BASE_URL} class="nav-logo">
        <div class="nav-logo-icon">🏠</div>
        <div class="nav-logo-text">
          <span class="nav-logo-name">{client.nom}</span>
          <span class="nav-logo-sub">{client.metier}</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href={import.meta.env.BASE_URL}>Accueil</a></li>
        <li><a href={`${base}/services`} class="active">Services</a></li>
        <li><a href={`${base}/realisations`}>Réalisations</a></li>
        <li class="nav-dropdown">
          <button class="nav-dropdown-toggle">
            Plus
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href={`${base}/tarifs`}>Tarifs</a>
            <a href={`${base}/a-propos`}>À Propos</a>
          </div>
        </li>
        <li><a href={`${base}/contact`}>Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
        <a href={`${base}/contact`} class="btn btn-accent">Devis gratuit</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
    <div class="nav-mobile" id="mobile-menu">
      <a href={import.meta.env.BASE_URL}>Accueil</a>
      <a href={`${base}/services`}>Services</a>
      <a href={`${base}/realisations`}>Réalisations</a>
      <a href={`${base}/tarifs`}>Tarifs</a>
      <a href={`${base}/a-propos`}>À Propos</a>
      <a href={`${base}/contact`}>Contact</a>
      <a href={`${base}/contact`} class="mob-cta">Devis gratuit →</a>
    </div>
  </nav>

  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="page-header-bg">
      <img src={client.heroImage2} alt="Services charpente couverture" />
    </div>
    <div class="page-header-ov"></div>
    <div class="container page-header-content">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href={import.meta.env.BASE_URL}>Accueil</a>
        <span>›</span>
        <span>Services</span>
      </nav>
      <div class="eyebrow" style="color:var(--accent)">Ce que nous faisons</div>
      <h1 class="font-display page-title">Toiture, charpente<br>& zinguerie</h1>
      <p class="page-sub">Du diagnostic au parfait achèvement — tous travaux de couverture dans les Pyrénées-Orientales.</p>
    </div>
  </header>

  <!-- SERVICES LISTE COMPLÈTE -->
  <section class="section">
    <div class="container">
      {client.services.map((s, i) => (
        <article class={`service-row ${i % 2 === 1 ? 'reverse' : ''} reveal`}>
          <div class="service-img img-zoom">
            <img src={s.image} alt={s.titre} loading="lazy" />
            <div class="service-num font-display">0{i + 1}</div>
          </div>
          <div class="service-content">
            <span class="service-icon">{s.icone}</span>
            <h2 class="service-titre font-display">{s.titre}</h2>
            <p class="service-desc">{s.description}</p>
            <div class="service-tags">
              {s.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <a href={`${base}/contact`} class="btn btn-primary" style="margin-top:1.5rem">Demander un devis →</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- GARANTIES -->
  <section class="section-alt">
    <div class="container">
      <div class="sec-center">
        <div class="eyebrow reveal">Nos engagements</div>
        <h2 class="section-title reveal reveal-d1">Pourquoi nous choisir ?</h2>
      </div>
      <div class="garanties-grid">
        {[
          { icon:"🛡️", titre:"Garantie décennale",    desc:"Tous nos travaux sont couverts 10 ans. Vous êtes protégé." },
          { icon:"📋", titre:"Devis gratuit 48h",      desc:"Visite gratuite et devis détaillé sans engagement sous 48h." },
          { icon:"⚡", titre:"Urgence 2h",             desc:"Fuite ou tempête ? Intervention rapide 7j/7 sur Perpignan et le 66." },
          { icon:"🌿", titre:"RGE Eco Artisan",        desc:"Éligible MaPrimeRénov', CEE, TVA 5.5% sur isolation." },
          { icon:"🪵", titre:"Matériaux premium",      desc:"Tuile, ardoise, zinc — uniquement des matériaux certifiés qualité." },
          { icon:"👷", titre:"Équipe salariée",        desc:"Pas de sous-traitance. 6 compagnons formés, maîtrisés, assurés." },
        ].map((g, i) => (
          <div class={`garantie-card hover-lift reveal reveal-d${i + 1}`}>
            <div class="garantie-icon">{g.icon}</div>
            <h3 class="garantie-titre font-display">{g.titre}</h3>
            <p class="garantie-desc">{g.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="faq-grid">
        <div class="faq-intro slide-left">
          <div class="eyebrow">Questions fréquentes</div>
          <h2 class="section-title">Tout ce que vous<br>voulez savoir</h2>
          <p class="faq-sub">Une question sur votre projet ? Consultez la FAQ ou appelez-nous directement.</p>
          <a href={client.telephoneLink} class="btn btn-primary" style="margin-top:1.5rem">{client.telephone}</a>
        </div>
        <div class="faq-list slide-right">
          {client.faq.map((f, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-question font-display">
                {f.question}
                <span class="faq-chevron">+</span>
              </summary>
              <p class="faq-reponse">{f.reponse}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA DEVIS -->
  <section class="section-dark">
    <div class="container cta-dark-inner">
      <div class="reveal">
        <h2 class="section-title section-title-white">Votre projet toiture à Perpignan</h2>
        <p style="color:rgba(255,255,255,0.55);margin-top:12px">Diagnostic gratuit — devis sous 48h — garantie décennale</p>
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap" class="reveal reveal-d1">
        <a href={`${base}/contact`} class="btn btn-accent btn-lg">Devis gratuit →</a>
        <a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a>
      </div>
    </div>
  </section>

  <!-- FOOTER minimal -->
  <footer class="footer">
    <div class="container">
      <div class="footer-bottom" style="border-top:none;padding-top:0">
        <p>© {new Date().getFullYear()} {client.nom} | <a href={import.meta.env.BASE_URL} style="color:inherit">Accueil</a> · <a href={`${base}/mentions-legales`} style="color:inherit">Mentions légales</a></p>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .page-header {
    position:relative; padding:calc(var(--nav-h) + 3rem) 0 4rem;
    overflow:hidden; min-height:360px; display:flex; align-items:flex-end;
  }
  .page-header-bg { position:absolute; inset:0; }
  .page-header-bg img { width:100%; height:100%; object-fit:cover; }
  .page-header-ov {
    position:absolute; inset:0;
    background:linear-gradient(160deg, rgba(12,14,22,0.88) 0%, rgba(12,14,22,0.7) 100%);
  }
  .page-header-content { position:relative; z-index:1; }
  .breadcrumb { display:flex; gap:8px; align-items:center; font-size:13px; color:rgba(255,255,255,0.45); margin-bottom:16px; }
  .breadcrumb a { color:rgba(255,255,255,0.45); transition:color .2s; }
  .breadcrumb a:hover { color:var(--accent); }
  .page-title { font-size:clamp(2rem,4vw,3.2rem); font-weight:800; letter-spacing:-0.04em; line-height:1.1; color:white; margin:12px 0 16px; }
  .page-sub { font-size:1rem; color:rgba(255,255,255,0.6); max-width:500px; }

  /* Services rows */
  .service-row {
    display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;
    padding:4rem 0; border-bottom:1px solid var(--border);
  }
  .service-row:last-child { border-bottom:none; }
  .service-row.reverse { direction:rtl; }
  .service-row.reverse > * { direction:ltr; }

  .service-img { position:relative; border-radius:var(--radius-md); overflow:hidden; height:360px; }
  .service-img img { width:100%; height:100%; object-fit:cover; }
  .service-num {
    position:absolute; bottom:16px; right:20px;
    font-size:5rem; font-weight:800; color:rgba(255,255,255,0.15); line-height:1;
  }
  .service-icon { font-size:2rem; display:block; margin-bottom:12px; }
  .service-titre { font-size:1.8rem; font-weight:800; letter-spacing:-0.04em; margin-bottom:16px; }
  .service-desc { font-size:0.95rem; color:var(--text-muted); line-height:1.8; margin-bottom:18px; }
  .service-tags { display:flex; flex-wrap:wrap; gap:8px; }
  .tag { background:var(--bg-alt); border:1px solid var(--border); padding:4px 11px; border-radius:var(--radius-full); font-size:11px; font-weight:600; color:var(--text-muted); }

  /* Garanties */
  .garanties-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:3rem; }
  .garantie-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-md); padding:28px; }
  .garantie-icon { font-size:1.8rem; margin-bottom:14px; }
  .garantie-titre { font-size:1rem; font-weight:800; margin-bottom:8px; }
  .garantie-desc { font-size:0.88rem; color:var(--text-muted); line-height:1.7; }

  /* FAQ */
  .faq-grid { display:grid; grid-template-columns:340px 1fr; gap:64px; align-items:start; }
  .faq-sub { font-size:0.95rem; color:var(--text-muted); margin-top:12px; line-height:1.7; }
  .faq-list { display:flex; flex-direction:column; gap:2px; }
  .faq-item { border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
  .faq-item + .faq-item { margin-top:4px; }
  .faq-question {
    display:flex; justify-content:space-between; align-items:center;
    padding:18px 20px; cursor:pointer; font-size:0.95rem; font-weight:700;
    list-style:none; gap:12px;
  }
  .faq-question::-webkit-details-marker { display:none; }
  .faq-question:hover { background:var(--bg-alt); }
  .faq-chevron { flex-shrink:0; font-size:1.3rem; font-weight:300; color:var(--accent); transition:transform 0.2s; }
  details[open] .faq-chevron { transform:rotate(45deg); }
  .faq-reponse { padding:0 20px 18px; font-size:0.9rem; color:var(--text-muted); line-height:1.8; }

  /* CTA dark */
  .cta-dark-inner { display:flex; justify-content:space-between; align-items:center; gap:2rem; flex-wrap:wrap; }

  @media(max-width:1024px) {
    .service-row { grid-template-columns:1fr; gap:32px; }
    .service-row.reverse { direction:ltr; }
    .service-img { height:260px; }
    .garanties-grid { grid-template-columns:repeat(2,1fr); }
    .faq-grid { grid-template-columns:1fr; gap:32px; }
  }
  @media(max-width:768px) {
    .garanties-grid { grid-template-columns:1fr; }
  }
</style>
