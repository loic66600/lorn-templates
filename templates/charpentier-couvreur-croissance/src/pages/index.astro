---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
const socials = Object.entries(client.reseaux).filter(([_,v]) => v);
const socialIcons: Record<string,string> = {
  facebook: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>',
  instagram: '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>',
  linkedin:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>',
  youtube:   '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>',
  tiktok:    '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52V6.83a4.84 4.84 0 01-1-.14z"/></svg>',
  twitter:   '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
};

const featuredServices = client.services.filter(s => s.featured);
const recentRealisations = client.realisations.slice(0, 3);
---

<Layout>

  <!-- ══ URGENCE BAR ══ -->
  {client.urgence && (
    <div class="urgence-bar" id="urgenceBar">
      ⚡ {client.urgenceTexte} — <a href={client.urgenceTelLink}>{client.urgenceTel}</a>
    </div>
  )}

  <!-- ══ NAVBAR ══ -->
  <nav class="navbar" id="navbar" class:list={[client.urgence ? 'with-urgence' : '']}>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <div class="nav-logo-icon">🏠</div>
        <div class="nav-logo-text">
          <span class="nav-logo-name">{client.nom}</span>
          <span class="nav-logo-sub">{client.metier}</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="active">Accueil</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/realisations">Réalisations</a></li>
        <li class="nav-dropdown">
          <button class="nav-dropdown-toggle">
            Plus
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href="/tarifs">Tarifs</a>
            <a href="/a-propos">À Propos</a>
          </div>
        </li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
        <a href="/contact" class="btn btn-accent">Devis gratuit</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
    <div class="nav-mobile" id="mobile-menu">
      <a href="/">Accueil</a>
      <a href="/services">Services</a>
      <a href="/realisations">Réalisations</a>
      <a href="/tarifs">Tarifs</a>
      <a href="/a-propos">À Propos</a>
      <a href="/contact">Contact</a>
      <a href="/contact" class="mob-cta">Devis gratuit →</a>
    </div>
  </nav>

  <!-- ══ HERO — FULL SCREEN avec overlay incliné ══ -->
  <section class="hero">
    <div class="hero-bg">
      <img src={client.heroImage} alt={client.heroImageAlt} loading="eager" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-diagonal"></div>

    <div class="container hero-content">
      <div class="hero-text">
        <div class="hero-badges reveal">
          <span class="hero-badge">
            <span class="badge-dot"></span>
            Qualibat — RGE — Décennale
          </span>
          <span class="hero-badge hero-badge-urgence">⚡ Urgence 7j/7</span>
        </div>

        <h1 class="hero-title font-display reveal reveal-d1">
          <span class="hero-title-top">Charpente &</span>
          <span class="hero-title-main">Couverture</span>
          <span class="hero-title-bottom">à Perpignan</span>
        </h1>

        <p class="hero-sub reveal reveal-d2">
          Artisan couvreur depuis 1998 dans les Pyrénées-Orientales.
          Tuile canal, ardoise, charpente bois, zinguerie, isolation.
          <strong>Devis gratuit sous 48h.</strong>
        </p>

        <div class="hero-actions reveal reveal-d3">
          <a href="/contact" class="btn btn-accent btn-lg">Devis gratuit →</a>
          <a href={client.urgenceTelLink} class="btn btn-outline-white btn-lg">⚡ Urgence : {client.urgenceTel}</a>
        </div>

        <div class="hero-certs reveal reveal-d4">
          {client.apropos.certifications.slice(0, 4).map(c => (
            <span class="cert-chip">✓ {c}</span>
          ))}
        </div>
      </div>

      <div class="hero-card reveal reveal-d3">
        <div class="hero-card-head">
          <span class="hero-card-label font-display">Nos chiffres</span>
        </div>
        <div class="hero-stats">
          {client.stats.map(s => (
            <div class="hero-stat">
              <div class="hero-stat-num font-display">
                <span class="counter-val" data-target={s.chiffre} data-suffix={s.suffix}>0</span>
              </div>
              <div class="hero-stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="hero-scroll">
      <div class="scroll-line"></div>
      <span>Défiler</span>
    </div>
  </section>

  <!-- ══ SERVICES PRINCIPAUX ══ -->
  <section class="section" id="services">
    <div class="container">
      <div class="svc-head">
        <div>
          <div class="eyebrow reveal">Nos prestations</div>
          <h2 class="section-title reveal reveal-d1">
            Charpente, couverture<br>& zinguerie
          </h2>
          <p class="svc-sub reveal reveal-d2">
            Du diagnostic à la livraison, nous réalisons tous vos travaux de toiture
            avec des matériaux premium et la garantie décennale.
          </p>
        </div>
        <a href="/services" class="btn btn-outline reveal reveal-d1">Toutes nos prestations →</a>
      </div>

      <div class="svc-grid">
        {featuredServices.map((s, i) => (
          <article class={`svc-card hover-lift reveal ${i > 0 ? 'reveal-d' + i : ''}`}>
            <div class="svc-img img-zoom">
              <img src={s.image} alt={s.titre} loading="lazy" />
              <div class="svc-num font-display">0{i + 1}</div>
            </div>
            <div class="svc-body">
              <span class="svc-icon">{s.icone}</span>
              <h3 class="svc-titre font-display">{s.titre}</h3>
              <p class="svc-desc">{s.description}</p>
              <div class="svc-tags">
                {s.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Grille petits services -->
      <div class="svc-mini-grid">
        {client.services.filter(s => !s.featured).map((s, i) => (
          <div class={`svc-mini reveal reveal-d${i + 1}`}>
            <span class="svc-mini-icon">{s.icone}</span>
            <div>
              <strong class="font-display">{s.titre}</strong>
              <p>{s.tags.join(' · ')}</p>
            </div>
            <a href="/services" class="svc-mini-arrow">→</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ BANDE URGENCE ══ -->
  <section class="urgence-section">
    <div class="container urgence-inner">
      <div class="urgence-text slide-left">
        <span class="urgence-icon">⚡</span>
        <div>
          <h3 class="font-display">Fuite toiture ? Tuile cassée ?</h3>
          <p>Intervention d'urgence sous 2h — 7j/7 dans un rayon de 40 km autour de Perpignan.</p>
        </div>
      </div>
      <div class="urgence-cta slide-right">
        <a href={client.urgenceTelLink} class="btn btn-accent btn-lg">{client.urgenceTel} →</a>
        <p class="urgence-note">Tramontane, Marin, tempête — on se déplace</p>
      </div>
    </div>
  </section>

  <!-- ══ PROCESSUS ══ -->
  <section class="section-alt" id="processus">
    <div class="container">
      <div class="sec-center">
        <div class="eyebrow reveal">Comment ça marche</div>
        <h2 class="section-title reveal reveal-d1">Notre méthode,<br>pas de surprise</h2>
      </div>

      <div class="process-grid">
        {client.processus.map((p, i) => (
          <div class={`process-card reveal reveal-d${i + 1}`}>
            <div class="process-num font-display">{p.num}</div>
            <div class="process-connector"></div>
            <h3 class="process-titre font-display">{p.titre}</h3>
            <p class="process-desc">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ RÉALISATIONS APERÇU ══ -->
  <section class="section" id="realisations">
    <div class="container">
      <div class="real-head">
        <div>
          <div class="eyebrow reveal">Nos chantiers</div>
          <h2 class="section-title reveal reveal-d1">Réalisations récentes</h2>
        </div>
        <a href="/realisations" class="btn btn-outline reveal">Voir tout →</a>
      </div>

      <div class="real-grid">
        {recentRealisations.map((r, i) => (
          <article class={`real-card hover-lift reveal reveal-d${i + 1}`}>
            <div class="real-img img-zoom">
              <img src={r.image} alt={r.titre} loading="lazy" />
              <span class="real-cat">{r.categorie}</span>
            </div>
            <div class="real-body">
              <div class="real-meta font-display">
                <span>📍 {r.lieu}</span>
                <span>{r.annee}</span>
                <span>{r.surface}</span>
              </div>
              <h3 class="real-titre font-display">{r.titre}</h3>
              <p>{r.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ TÉMOIGNAGES ══ -->
  <section class="section-dark" id="temoignages">
    <div class="container">
      <div class="sec-center">
        <div class="eyebrow" style="color:var(--accent)">Avis clients</div>
        <h2 class="section-title section-title-white reveal reveal-d1">
          Ils nous font confiance<br>dans tout le 66
        </h2>
        <div class="stars-global reveal reveal-d2">
          <span class="stars-note font-display">5.0</span>
          <div class="stars-icons">{"★★★★★"}</div>
          <span class="stars-label">— {client.temoignages.length * 65}+ avis Google vérifiés</span>
        </div>
      </div>

      <div class="test-grid">
        {client.temoignages.map((t, i) => (
          <article class={`test-card reveal reveal-d${i + 1}`}>
            <div class="test-top">
              <div class="test-avatar font-display">{t.nom.charAt(0)}</div>
              <div>
                <div class="test-nom font-display">{t.nom}</div>
                <div class="test-type">{t.type} · {t.ville}</div>
              </div>
              <div class="test-stars">{"★".repeat(t.note)}</div>
            </div>
            <blockquote class="test-texte">"{t.texte}"</blockquote>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ ZONES D'INTERVENTION ══ -->
  <section class="section-alt" id="zones">
    <div class="container zones-grid">
      <div class="zones-text slide-left">
        <div class="eyebrow">Zone d'intervention</div>
        <h2 class="section-title">{client.rayonKm} km autour<br>de Perpignan</h2>
        <p class="zones-sub">
          Nous intervenons dans tout le département des Pyrénées-Orientales (66),
          de la Côte Vermeille aux Pyrénées, en passant par les Aspres et le Conflent.
        </p>
        <div class="zones-tags">
          {client.zones.map(z => <span class="zone-tag">{z}</span>)}
        </div>
        <a href="/contact" class="btn btn-primary" style="margin-top:2rem">Vérifier ma zone →</a>
      </div>
      <div class="zones-img slide-right">
        <div class="zones-img-wrap img-zoom">
          <img src={client.heroImage2} alt="Couvreur Pyrénées-Orientales" loading="lazy" />
        </div>
        <div class="zones-badge font-display">
          <span class="zones-badge-num">40 km</span>
          <span>rayon d'intervention</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CTA DEVIS ══ -->
  <section class="cta-devis section">
    <div class="container cta-inner">
      <div class="cta-text reveal">
        <div class="eyebrow">Gratuit & sans engagement</div>
        <h2 class="section-title">Votre devis en 48h</h2>
        <p>Déplacement gratuit sur Perpignan et tout le 66. Diagnostic toiture inclus.</p>
      </div>
      <div class="cta-actions reveal reveal-d1">
        <a href="/contact" class="btn btn-primary btn-lg">Demander un devis →</a>
        <a href={client.telephoneLink} class="btn btn-outline btn-lg">📞 {client.telephone}</a>
      </div>
    </div>
  </section>

  <!-- ══ FOOTER ══ -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-brand-logo">
            <div class="footer-brand-icon">🏠</div>
            <span class="footer-brand-name font-display">{client.nom}</span>
          </div>
          <p>{client.specialite}. Perpignan et tout le 66 depuis 1998.</p>
          {socials.length > 0 && (
            <div class="social-links">
              {socials.map(([k,v]) => (
                <a href={v} target="_blank" rel="noopener" class="social-link social-link-dark" title={k} set:html={socialIcons[k] || k} />
              ))}
            </div>
          )}
        </div>

        <div class="footer-col">
          <h4>Navigation</h4>
          <ul>
            <li><a href="/">Accueil</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/realisations">Réalisations</a></li>
            <li><a href="/tarifs">Tarifs</a></li>
            <li><a href="/a-propos">À Propos</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Prestations</h4>
          <ul>
            {client.services.map(s => <li><a href="/services">{s.titre}</a></li>)}
          </ul>
        </div>

        <div class="footer-col">
          <h4>Contact</h4>
          <ul>
            <li><a href={client.telephoneLink}>{client.telephone}</a></li>
            <li><a href={`mailto:${client.email}`}>{client.email}</a></li>
            <li><a href="#">{client.adresse}</a></li>
            {client.urgence && <li><a href={client.urgenceTelLink} style="color:var(--accent)">⚡ Urgence : {client.urgenceTel}</a></li>}
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} {client.nom} — {client.ville} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">
          Site par <strong>LORN Digital Studio</strong>
        </a>
      </div>
    </div>
  </footer>

</Layout>

<script define:vars={{ web3Key, emailClient: client.email, nomClient: client.nom }}>
  // Urgence bar — décale la navbar
  const ub = document.getElementById('urgenceBar');
  const nb = document.getElementById('navbar');
  if (ub && nb) nb.style.top = ub.offsetHeight + 'px';
</script>

<style>
  /* ══ HERO ══ */
  .hero {
    position:relative; min-height:100vh;
    display:flex; align-items:center;
    padding-top:calc(var(--nav-h) + 40px); padding-bottom:4rem;
    overflow:hidden;
  }
  .hero-bg {
    position:absolute; inset:0; z-index:0;
  }
  .hero-bg img { width:100%; height:100%; object-fit:cover; object-position:center; }

  .hero-overlay {
    position:absolute; inset:0; z-index:1;
    background:linear-gradient(110deg, rgba(12,14,22,0.92) 0%, rgba(12,14,22,0.75) 50%, rgba(12,14,22,0.45) 100%);
  }
  .hero-overlay-diagonal {
    position:absolute; bottom:0; left:0; right:0; z-index:2;
    height:90px;
    background:var(--bg);
    clip-path:polygon(0 60px, 100% 0, 100% 100%, 0 100%);
  }

  .hero-content {
    position:relative; z-index:3;
    display:grid; grid-template-columns:1fr 320px; gap:48px; align-items:center;
  }

  .hero-badges { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:24px; }
  .hero-badge {
    display:inline-flex; align-items:center; gap:8px;
    background:rgba(255,255,255,0.1); backdrop-filter:blur(8px);
    border:1px solid rgba(255,255,255,0.2); color:white;
    padding:6px 14px; border-radius:var(--radius-full);
    font-size:12px; font-weight:600; letter-spacing:0.04em;
  }
  .badge-dot {
    width:7px; height:7px; border-radius:50%;
    background:var(--accent); animation:pulse 2s infinite;
  }
  .hero-badge-urgence { background:rgba(200,121,65,0.25); border-color:var(--accent); }

  @keyframes pulse {
    0%,100% { box-shadow:0 0 0 0 rgba(200,121,65,0.5); }
    50%      { box-shadow:0 0 0 8px rgba(200,121,65,0); }
  }

  .hero-title {
    font-size:clamp(2.6rem,5.5vw,4.8rem); font-weight:800;
    line-height:1.0; letter-spacing:-0.04em; color:white; margin-bottom:24px;
  }
  .hero-title-top, .hero-title-bottom {
    display:block; font-size:0.5em; font-weight:500;
    color:rgba(255,255,255,0.6); letter-spacing:-0.02em;
  }
  .hero-title-main { display:block; color:var(--accent); }

  .hero-sub {
    font-size:1.05rem; line-height:1.7; color:rgba(255,255,255,0.75);
    max-width:520px; margin-bottom:36px;
  }
  .hero-sub strong { color:white; }

  .hero-actions { display:flex; flex-wrap:wrap; gap:14px; margin-bottom:36px; }

  .hero-certs { display:flex; flex-wrap:wrap; gap:10px; }
  .cert-chip {
    background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.16);
    color:rgba(255,255,255,0.7); padding:5px 12px; border-radius:var(--radius-full);
    font-size:11px; font-weight:600;
  }

  .hero-card {
    background:rgba(255,255,255,0.97); border-radius:var(--radius-md);
    overflow:hidden; box-shadow:0 24px 64px rgba(0,0,0,0.3);
  }
  .hero-card-head {
    background:var(--primary); padding:14px 20px;
  }
  .hero-card-label {
    font-size:11px; font-weight:700; letter-spacing:0.16em;
    text-transform:uppercase; color:var(--accent);
  }
  .hero-stats { display:grid; grid-template-columns:1fr 1fr; }
  .hero-stat {
    padding:20px; border-bottom:1px solid var(--border);
    border-right:1px solid var(--border);
  }
  .hero-stat:nth-child(2n) { border-right:none; }
  .hero-stat:nth-child(3), .hero-stat:nth-child(4) { border-bottom:none; }
  .hero-stat-num { font-size:2rem; font-weight:800; color:var(--primary); line-height:1; }
  .hero-stat-label { font-size:12px; color:var(--text-muted); margin-top:4px; }

  .hero-scroll {
    position:absolute; bottom:140px; left:50%; transform:translateX(-50%);
    z-index:3; display:flex; flex-direction:column; align-items:center; gap:8px;
    color:rgba(255,255,255,0.4); font-size:11px; font-weight:600;
    letter-spacing:0.14em; text-transform:uppercase;
  }
  .scroll-line {
    width:1px; height:48px; background:rgba(255,255,255,0.2);
    animation:scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{height:48px;opacity:.3} 50%{height:64px;opacity:.7} }

  /* ══ SERVICES ══ */
  .svc-head { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:3.5rem; gap:2rem; flex-wrap:wrap; }
  .svc-sub { font-size:1.05rem; color:var(--text-muted); max-width:480px; margin-top:12px; line-height:1.7; }
  .svc-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:28px; margin-bottom:24px; }

  .svc-card { background:var(--bg-card); border-radius:var(--radius-md); overflow:hidden; border:1px solid var(--border); }
  .svc-img { position:relative; height:260px; }
  .svc-img img { width:100%; height:100%; object-fit:cover; }
  .svc-num {
    position:absolute; top:16px; left:16px;
