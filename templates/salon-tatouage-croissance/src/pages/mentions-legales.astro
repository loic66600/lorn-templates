---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
---
<Layout title={`Mentions légales — ${client.nom}`} description={`Mentions légales ${client.nom}`} noIndex={true}>
<nav class="navbar" id="navbar"><div class="nav-wrap">
  <a href="/" class="nav-logo"><div class="nav-logo-mark">IC</div><div><div class="nav-logo-name">{client.nom}</div><div class="nav-logo-sub">Studio · Perpignan</div></div></a>
  <ul class="nav-links"><li><a href="/">Accueil</a></li><li><a href="/contact">Contact</a></li></ul>
  <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
</div>
<div class="mob-overlay" id="mobOverlay"></div>
<div class="mob-menu" id="mob-menu"><a href="/">Accueil</a><a href="/contact">Contact</a></div>
</nav>
<section class="legal-wrap"><div class="wrap legal-container">
  <nav class="l-bc"><a href="/">Accueil</a><span>›</span><span>Mentions légales</span></nav>
  <h1 class="display l-title">MENTIONS<br>LÉGALES</h1>
  <p class="l-date">Mis à jour le {new Date().toLocaleDateString('fr-FR',{year:'numeric',month:'long',day:'numeric'})}</p>
  <div class="l-content">
    <div class="lb"><h2 class="display">1. Éditeur</h2><p><strong>{client.responsable}</strong><br/>SIRET : {client.siret}<br/>Adresse : {client.adresse}<br/>Tél : <a href={client.telephoneLink}>{client.telephone}</a><br/>Email : <a href={`mailto:${client.email}`}>{client.email}</a></p></div>
    <div class="lb"><h2 class="display">2. Hébergement</h2><p>{client.hebergeur}</p></div>
    <div class="lb"><h2 class="display">3. Conception</h2><p>Site réalisé par <strong>LORN Digital Studio</strong> — <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener">vitemonsite-artisan.fr</a></p></div>
    <div class="lb"><h2 class="display">4. Propriété intellectuelle</h2><p>L'ensemble du contenu (textes, photos, design) est la propriété de {client.nom}. Les photos tattoo sont des œuvres des artistes résidents. Toute reproduction sans autorisation est interdite.</p></div>
    <div class="lb"><h2 class="display">5. Données personnelles (RGPD)</h2>
      <h3 class="display">Données collectées</h3><p>Via le formulaire : nom, téléphone, email, description du projet. Utilisées uniquement pour répondre à votre demande.</p>
      <h3 class="display">Base légale</h3><p>Consentement (RGPD art. 6.1.a) et intérêt légitime (art. 6.1.f).</p>
      <h3 class="display">Vos droits</h3><p>Droits d'accès, rectification, suppression et opposition : <a href={`mailto:${client.email}`}>{client.email}</a>. Recours possible auprès de la <a href="https://www.cnil.fr" target="_blank" rel="noopener">CNIL</a>.</p>
    </div>
    <div class="lb"><h2 class="display">6. Cookies</h2><p>Cookies techniques uniquement (localStorage pour le consentement cookie). Aucun traceur publicitaire.</p></div>
    <div class="lb"><h2 class="display">7. Droit applicable</h2><p>Droit français — tribunaux de Perpignan compétents.</p></div>
  </div>
  <a href="/" class="btn btn-outline" style="margin-top:2.5rem">← Retour à l'accueil</a>
</div></section>
<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nom}</p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par LORN Digital Studio</a>
</div></div></footer>
</Layout>
<style>
.legal-wrap{padding:calc(var(--nav-h)+4.5rem) 0 5rem;background:var(--bg-body)}
.legal-container{max-width:680px}
.l-bc{display:flex;gap:10px;font-size:10px;color:var(--muted);margin-bottom:18px;letter-spacing:.1em;text-transform:uppercase;align-items:center}
.l-bc a{color:var(--muted)}.l-bc a:hover{color:var(--red)}
.l-title{font-size:clamp(2rem,5vw,4rem);color:#fff;margin-bottom:6px}
.l-date{font-size:11.5px;color:var(--muted);margin-bottom:3rem}
.l-content{display:flex;flex-direction:column}
.lb{padding:1.5rem 0;border-bottom:1px solid rgba(255,255,255,.06)}
.lb:last-child{border-bottom:none}
.lb h2{font-size:.78rem;letter-spacing:.2em;color:var(--red);margin-bottom:.8rem}
.lb h3{font-size:.72rem;letter-spacing:.16em;color:rgba(255,255,255,.35);margin:.8rem 0 .4rem}
.lb p{font-size:.85rem;color:var(--muted);line-height:1.9;margin-bottom:.5rem;font-weight:300}
.lb a{color:var(--red)}.lb strong{color:rgba(255,255,255,.7);font-weight:500}
</style>
