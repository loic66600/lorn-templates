---
import { client } from '../data/client';
interface Props { title?: string; description?: string; noIndex?: boolean; }
const { title = client.titreSEO, description = client.descriptionSEO, noIndex = false } = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LandscapeService",
  "name": client.nom,
  "description": client.descriptionSEO,
  "telephone": client.telephoneLink.replace("tel:", ""),
  "email": client.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": client.adresse.split(",")[0],
    "addressLocality": client.ville,
    "postalCode": client.codePostal,
    "addressCountry": "FR"
  },
  "areaServed": client.zones.map(z => ({ "@type": "City", "name": z })),
  "priceRange": "€€",
  "image": client.heroImage,
  "sameAs": Object.values(client.reseaux).filter(Boolean),
};
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={client.motsCles.join(', ')} />
  <meta name="robots" content={noIndex ? "noindex,nofollow" : "index,follow"} />
  <link rel="canonical" href={client.canonicalUrl + Astro.url.pathname} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={client.ogImage} />
  <meta property="og:url" content={client.canonicalUrl + Astro.url.pathname} />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={client.ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
</head>
<body>
  <slot />

  {client.cookieConsent && (
    <div class="cookie-bar" id="cookieBar">
      <div class="cookie-inner">
        <p>🌿 Ce site utilise des cookies techniques. <a href="/mentions-legales">En savoir plus</a></p>
        <div class="cookie-btns">
          <button id="ckAccept">Accepter</button>
          <button id="ckRefuse" class="ghost">Refuser</button>
        </div>
      </div>
    </div>
  )}

  <style is:global>
    /* ══ RESET ════════════════════════════════════════════════════════ */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; scroll-padding-top:80px; }
    body {
      font-family: 'Outfit', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width:100%; display:block; }
    a { color:inherit; text-decoration:none; }
    ::selection { background: rgba(92,158,74,.18); }

    /* ══ VARIABLES ══════════════════════════════════════════════════ */
    :root {
      /* Couleurs — Palette naturelle méditerranéenne */
      --forest:      #1B2E1B;   /* vert forêt profond */
      --forest-mid:  #263D26;
      --forest-90:   rgba(27,46,27,.92);
      --green:       #5C9E4A;   /* vert naturel */
      --green-light: #74B562;
      --green-pale:  #EBF5E8;
      --gold:        #C9A84C;   /* or automnal */
      --gold-light:  #D9BC6E;
      --gold-glow:   rgba(201,168,76,.2);
      --earth:       #8B6F47;   /* terre */

      --bg:          #F6F4EF;   /* ivoire naturel */
      --bg-alt:      #EDEAE3;
      --bg-card:     #FFFFFF;
      --bg-dark:     #1B2E1B;

      --border:        rgba(27,46,27,.09);
      --border-strong: rgba(27,46,27,.18);

      --text:        #1B2E1B;
      --text-muted:  #5A6B4E;
      --text-light:  rgba(90,107,78,.5);

      --font-serif:  'Playfair Display', Georgia, serif;
      --font-body:   'Outfit', system-ui, sans-serif;

      --r:       5px;
      --r-md:    14px;
      --r-lg:    24px;
      --r-pill:  9999px;
      --shadow:  0 4px 24px rgba(27,46,27,.07);
      --shadow-lg: 0 20px 60px rgba(27,46,27,.14);
      --nav-h:   76px;
      --wrap:    1240px;
    }

    /* ══ LAYOUT ══════════════════════════════════════════════════════ */
    .wrap { max-width:var(--wrap); margin:0 auto; padding:0 clamp(1rem,3vw,2.5rem); }
    .sec     { padding: clamp(5rem,9vw,8rem) 0; }
    .sec-alt { padding: clamp(5rem,9vw,8rem) 0; background: var(--bg-alt); }
    .sec-dark{ padding: clamp(5rem,9vw,8rem) 0; background: var(--bg-dark); }
    .sec-green{ padding: clamp(5rem,9vw,8rem) 0; background: var(--green); }

    /* ══ TYPOGRAPHY ══════════════════════════════════════════════════ */
    .serif { font-family: var(--font-serif); }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: var(--font-body); font-size: 11px; font-weight: 600;
      letter-spacing: .2em; text-transform: uppercase; color: var(--green);
      margin-bottom: 12px;
    }
    .eyebrow::before {
      content: ''; width: 28px; height: 1.5px;
      background: var(--green); border-radius: 2px;
    }
    .eyebrow-gold { color: var(--gold); }
    .eyebrow-gold::before { background: var(--gold); }
    .eyebrow-white { color: rgba(255,255,255,.6); }
    .eyebrow-white::before { background: rgba(255,255,255,.4); }

    .h2 {
      font-family: var(--font-serif);
      font-size: clamp(2rem,3.8vw,3.2rem);
      font-weight: 700; line-height: 1.12; letter-spacing: -.02em;
      color: var(--text);
    }
    .h2-white { color: #fff; }
    .h2-italic { font-style: italic; }
    .lead { font-size: 1rem; color: var(--text-muted); line-height: 1.8; max-width: 520px; }

    /* ══ BOUTONS ══════════════════════════════════════════════════════ */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-body); font-size: 13px; font-weight: 600;
      padding: 13px 26px; border-radius: var(--r); border: 2px solid transparent;
      cursor: pointer; transition: all .22s; white-space: nowrap;
    }
    .btn-forest { background: var(--forest); color: #fff; border-color: var(--forest); }
    .btn-forest:hover { background: var(--forest-mid); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(27,46,27,.25); }
    .btn-green { background: var(--green); color: #fff; border-color: var(--green); }
    .btn-green:hover { background: var(--green-light); border-color: var(--green-light); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(92,158,74,.35); }
    .btn-gold { background: var(--gold); color: #fff; border-color: var(--gold); }
    .btn-gold:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 28px var(--gold-glow); }
    .btn-outline { background: transparent; color: var(--text); border-color: var(--border-strong); }
    .btn-outline:hover { border-color: var(--forest); transform: translateY(-2px); }
    .btn-outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,.3); }
    .btn-outline-white:hover { border-color: #fff; background: rgba(255,255,255,.07); transform: translateY(-2px); }
    .btn-lg { padding: 16px 34px; font-size: 14px; }

    /* ══ SOCIAL ══════════════════════════════════════════════════════ */
    .soc-links { display: flex; gap: 8px; }
    .soc-link {
      display: flex; align-items: center; justify-content: center;
      width: 38px; height: 38px; border-radius: var(--r);
      background: var(--bg-alt); border: 1px solid var(--border);
      color: var(--text-muted); transition: all .2s;
    }
    .soc-link:hover { background: var(--forest); border-color: var(--forest); color: #fff; transform: translateY(-3px); }
    .soc-link svg { width: 16px; height: 16px; }
    .soc-dark { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.1); color: rgba(255,255,255,.4); }
    .soc-dark:hover { background: var(--green); border-color: var(--green); color: #fff; }

    /* ══ TAGS ════════════════════════════════════════════════════════ */
    .tag {
      background: var(--bg-alt); border: 1px solid var(--border);
      padding: 4px 12px; border-radius: var(--r-pill);
      font-size: 11px; font-weight: 500; color: var(--text-muted);
    }
    .tag-green { background: var(--green-pale); border-color: rgba(92,158,74,.3); color: var(--green); }

    /* ══ ROOT GROW ANIMATIONS (signature) ═══════════════════════════ */
    /* Pousse organique depuis le sol — scale + fade depuis le bas */
    .grow {
      opacity: 0;
      transform: translateY(24px) scale(.97);
      transition:
        opacity .7s cubic-bezier(.22,1,.36,1),
        transform .7s cubic-bezier(.22,1,.36,1);
      will-change: transform, opacity;
    }
    .grow.sprouted { opacity: 1; transform: translateY(0) scale(1); }

    /* Tige — slide from left */
    .stem {
      opacity: 0; transform: translateX(-30px);
      transition: opacity .65s cubic-bezier(.22,1,.36,1), transform .65s cubic-bezier(.22,1,.36,1);
    }
    .stem.sprouted { opacity: 1; transform: translateX(0); }

    /* Branch — slide from right */
    .branch {
      opacity: 0; transform: translateX(30px);
      transition: opacity .65s cubic-bezier(.22,1,.36,1), transform .65s cubic-bezier(.22,1,.36,1);
    }
    .branch.sprouted { opacity: 1; transform: translateX(0); }

    /* Délais progressifs */
    .d1 { transition-delay: .07s; }
    .d2 { transition-delay: .14s; }
    .d3 { transition-delay: .21s; }
    .d4 { transition-delay: .28s; }
    .d5 { transition-delay: .35s; }
    .d6 { transition-delay: .42s; }

    /* Hover lift */
    .lift { transition: transform .38s cubic-bezier(.22,1,.36,1), box-shadow .38s; }
    .lift:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }

    /* Image zoom */
    .iz { overflow: hidden; }
    .iz img { transition: transform .65s cubic-bezier(.22,1,.36,1); }
    .iz:hover img { transform: scale(1.06); }

    /* ══ NAVBAR ══════════════════════════════════════════════════════ */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: var(--nav-h); transition: all .3s;
    }
    .navbar.sc {
      background: rgba(246,244,239,.97);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 1px 0 var(--border), 0 4px 20px rgba(27,46,27,.05);
    }
    .navbar.tr { background: transparent; }
    .nav-wrap {
      display: flex; align-items: center; justify-content: space-between;
      height: 100%; padding: 0 clamp(1rem,3vw,2.5rem);
      max-width: var(--wrap); margin: 0 auto;
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; }
    .nav-logo-leaf {
      width: 36px; height: 36px; border-radius: 50% 50% 50% 0;
      background: var(--green); display: flex; align-items: center;
      justify-content: center; font-size: 17px; flex-shrink: 0;
      transform: rotate(-45deg);
    }
    .nav-logo-leaf span { display: block; transform: rotate(45deg); }
    .nav-logo-text { display: flex; flex-direction: column; gap: 0px; }
    .nav-logo-name {
      font-family: var(--font-serif); font-size: 15px; font-weight: 700;
      color: var(--text); line-height: 1; letter-spacing: -.01em;
    }
    .nav-logo-name.wh { color: #fff; }
    .nav-logo-sub {
      font-size: 10px; font-weight: 400; letter-spacing: .12em;
      text-transform: uppercase; color: var(--text-muted); line-height: 1.2;
    }
    .nav-logo-sub.wh { color: rgba(255,255,255,.45); }
    .nav-links { display: flex; align-items: center; gap: 2px; list-style: none; }
    .nav-links > li > a {
      font-family: var(--font-body); font-size: 13px; font-weight: 500;
      color: var(--text-muted); transition: color .2s; position: relative;
      display: block; padding: 6px 10px; border-radius: 6px;
    }
    .nav-links > li > a.wh { color: rgba(255,255,255,.65); }
    .nav-links > li > a::after {
      content: ''; position: absolute; bottom: 2px; left: 10px; right: 10px;
      height: 1.5px; background: var(--green);
      border-radius: 2px; transform: scaleX(0); transition: transform .25s; transform-origin: left;
    }
    .nav-links > li > a:hover, .nav-links > li > a.active { color: var(--text); }
    .nav-links > li > a.wh:hover, .nav-links > li > a.wh.active { color: #fff; }
    .nav-links > li > a:focus-visible {
      outline: 2px solid var(--green);
      outline-offset: 3px;
    }
    .nav-links > li > a.wh:focus-visible {
      outline-color: rgba(255,255,255,.8);
    }
    .nav-links > li > a:active { color: var(--text); }
    .nav-links > li > a.wh:active { color: #fff; }
    .nav-links > li > a:hover::after, .nav-links > li > a.active::after { transform: scaleX(1); }
    .nav-dropdown { position: relative; padding-bottom: 12px; margin-bottom: -12px; }
    .nav-dd-toggle {
      font-family: var(--font-body); font-size: 13px; font-weight: 500;
      color: var(--text-muted); background: none; border: none; cursor: pointer;
      display: flex; align-items: center; gap: 4px; padding: 6px 10px;
      border-radius: 6px; transition: color .2s; line-height: 1;
    }
    .nav-dd-toggle.wh { color: rgba(255,255,255,.65); }
    .nav-dd-toggle:hover, .nav-dropdown:hover .nav-dd-toggle { color: var(--text); }
    .nav-dd-toggle.wh:hover, .nav-dropdown:hover .nav-dd-toggle.wh { color: #fff; }
    .nav-dd-toggle:focus-visible {
      outline: 2px solid var(--green);
      outline-offset: 3px;
    }
    .nav-dd-toggle.wh:focus-visible {
      outline-color: rgba(255,255,255,.8);
    }
    .nav-dd-toggle:active { color: var(--text); }
    .nav-dd-toggle.wh:active { color: #fff; }
    .nav-dd-toggle svg { transition: transform .25s; flex-shrink: 0; }
    .nav-dropdown:hover .nav-dd-toggle svg { transform: rotate(180deg); }
    .nav-dd-menu {
      display: flex; flex-direction: column;
      position: absolute; top: calc(100% + 6px); left: 50%;
      transform: translateX(-50%); background: #fff;
      border: 1px solid rgba(0,0,0,.08); border-radius: 10px;
      box-shadow: 0 16px 48px rgba(0,0,0,.12); min-width: 160px; padding: 6px; z-index: 200;
      visibility: hidden; opacity: 0; pointer-events: none;
      transition: opacity .12s ease, visibility .12s ease;
      transition-delay: .22s;
    }
    .nav-dropdown:hover .nav-dd-menu {
      visibility: visible; opacity: 1; pointer-events: auto; transition-delay: 0s;
    }
    .nav-dd-menu a {
      font-family: var(--font-body); font-size: 13px; font-weight: 500;
      color: var(--text-muted); padding: 9px 12px; border-radius: 6px;
      transition: all .15s; white-space: nowrap; display: block;
    }
    .nav-dd-menu a:hover { background: var(--bg-alt, #f5f5f0); color: var(--text); }
    .nav-cta { display: flex; align-items: center; gap: 10px; }
    .nav-tel { font-family: var(--font-body); font-size: 13px; font-weight: 600; color: var(--text-muted); transition: color .2s; }
    .nav-tel:hover { color: var(--green); }
    .nav-tel.wh { color: rgba(255,255,255,.55); }
    .nav-tel:focus-visible {
      outline: 2px solid var(--green);
      outline-offset: 3px;
    }
    .nav-tel.wh:focus-visible {
      outline-color: rgba(255,255,255,.8);
    }
    .nav-tel:active { color: var(--green); }
    .nav-tel.wh:active { color: #fff; }
    .burger { display: none; flex-direction: column; gap: 5px; padding: 8px; border: none; background: none; cursor: pointer; }
    .burger span { display: block; width: 22px; height: 1.5px; background: var(--text); transition: all .3s; border-radius: 2px; }
    .burger.wh span { background: #fff; }
    .burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .burger.open span:nth-child(2) { opacity: 0; }
    .burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
    .navbar.sc .nav-logo-name.wh { color: var(--text); }
    .navbar.sc .nav-logo-sub.wh { color: var(--text-muted); }
    .navbar.sc .nav-links > li > a.wh { color: var(--text-muted); }
    .navbar.sc .nav-links > li > a.wh:hover,
    .navbar.sc .nav-links > li > a.wh.active,
    .navbar.sc .nav-links > li > a.wh:active { color: var(--text); }
    .navbar.sc .nav-dd-toggle.wh,
    .navbar.sc .nav-dd-toggle.wh:hover,
    .navbar.sc .nav-dropdown:hover .nav-dd-toggle.wh,
    .navbar.sc .nav-dd-toggle.wh:active { color: var(--text); }
    .navbar.sc .nav-tel.wh,
    .navbar.sc .nav-tel.wh:active { color: var(--text-muted); }
    .navbar.sc .burger.wh span { background: var(--text); }
    .mob-menu {
      display: none; position: fixed; top: var(--nav-h); left: 0; right: 0; bottom: 0;
      background: var(--bg); padding: 40px 28px; flex-direction: column; z-index: 999;
    }
    .mob-menu.open { display: flex; }
    .mob-menu a {
      font-family: var(--font-serif); font-size: 2rem; font-weight: 700;
      color: var(--text-muted); padding: 14px 0; border-bottom: 1px solid var(--border);
      transition: color .2s;
    }
    .mob-menu a:hover { color: var(--forest); }
    .mob-cta {
      margin-top: 28px; padding: 15px 24px; background: var(--green);
      color: #fff !important; border-radius: var(--r); font-weight: 600;
      text-align: center; border-bottom: none !important;
    }

    /* ══ FOOTER ══════════════════════════════════════════════════════ */
    .footer { background: var(--forest); color: rgba(255,255,255,.65); padding: 68px 0 30px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .f-logo-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .f-logo-leaf {
      width: 34px; height: 34px; border-radius: 50% 50% 50% 0;
      background: var(--green); display: flex; align-items: center;
      justify-content: center; font-size: 16px; flex-shrink: 0;
      transform: rotate(-45deg);
    }
    .f-logo-leaf span { display: block; transform: rotate(45deg); }
    .f-logo-name { font-family: var(--font-serif); font-size: .95rem; font-weight: 700; color: #fff; }
    .f-brand p { font-size: 13px; line-height: 1.8; color: rgba(255,255,255,.35); margin-bottom: 18px; }
    .f-col h4 {
      font-size: 10px; font-weight: 600; letter-spacing: .18em;
      text-transform: uppercase; color: rgba(255,255,255,.25); margin-bottom: 14px;
    }
    .f-col ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
    .f-col ul li a { font-size: 13px; color: rgba(255,255,255,.45); transition: color .2s; }
    .f-col ul li a:hover { color: var(--green-light); }
    .f-bottom {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 24px; border-top: 1px solid rgba(255,255,255,.07);
      flex-wrap: wrap; gap: 12px;
    }
    .f-bottom p { font-size: 12px; color: rgba(255,255,255,.2); }
    .lorn-badge {
      font-size: 11px; color: rgba(255,255,255,.2);
      border: 1px solid rgba(255,255,255,.08); padding: 5px 12px;
      border-radius: var(--r-pill); transition: all .2s;
    }
    .lorn-badge:hover { color: var(--green-light); border-color: var(--green); }

    /* ══ COOKIE ══════════════════════════════════════════════════════ */
    .cookie-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      background: var(--forest); transition: transform .45s;
    }
    .cookie-bar.hidden { transform: translateY(120%); }
    .cookie-inner {
      max-width: var(--wrap); margin: 0 auto; padding: 14px clamp(1rem,3vw,2.5rem);
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
    }
    .cookie-inner p { font-size: 13px; color: rgba(255,255,255,.6); flex: 1; min-width: 200px; }
    .cookie-inner a { color: var(--green-light); text-decoration: underline; }
    .cookie-btns { display: flex; gap: 8px; }
    .cookie-btns button {
      padding: 8px 20px; border-radius: var(--r-pill); font-family: var(--font-body);
      font-size: 13px; font-weight: 600; cursor: pointer; border: none;
    }
    .cookie-btns button:first-child { background: var(--green); color: #fff; }
    .cookie-btns button.ghost { background: transparent; border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.4); }

    /* ══ PAGE HEADER ══════════════════════════════════════════════════ */
    .ph {
      position: relative; padding: calc(var(--nav-h) + 4rem) 0 5rem;
      background: var(--forest); overflow: hidden;
    }
    .ph::after {
      content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 80px;
      background: var(--bg);
      clip-path: ellipse(55% 80px at 50% 100%);
    }
    .ph-bc { display: flex; gap: 8px; font-size: 12px; color: rgba(255,255,255,.3); margin-bottom: 14px; align-items: center; }
    .ph-bc a { color: rgba(255,255,255,.3); transition: color .2s; }
    .ph-bc a:hover { color: var(--green-light); }
    .ph-title {
      font-family: var(--font-serif); font-size: clamp(2.2rem,4.5vw,3.5rem);
      font-weight: 700; letter-spacing: -.02em; line-height: 1.1; color: #fff;
      margin: 12px 0 16px;
    }
    .ph-title em { font-style: italic; color: var(--green-light); }
    .ph-sub { font-size: .95rem; color: rgba(255,255,255,.5); max-width: 500px; line-height: 1.75; }

    /* ══ SECTION CENTER ══════════════════════════════════════════════ */
    .sc { text-align: center; margin-bottom: 3.5rem; }
    .sc .eyebrow { justify-content: center; }
    .sc .eyebrow::before { display: none; }

    /* ══ RESPONSIVE ═══════════════════════════════════════════════════ */
    @media (max-width:1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
    @media (max-width:768px) {
      .nav-links, .nav-tel { display: none !important; }
      .burger { display: flex !important; }
      .footer-grid { grid-template-columns: 1fr; gap: 24px; }
      .f-bottom { flex-direction: column; align-items: flex-start; }
    }
    @media (prefers-reduced-motion: reduce) {
      .grow, .stem, .branch { opacity: 1 !important; transform: none !important; transition: none !important; }
    }
  </style>

  <script>
    // Root Grow observer
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('sprouted'); });
    }, { threshold: .08, rootMargin: '0px 0px -30px 0px' });
    document.querySelectorAll('.grow, .stem, .branch').forEach(el => obs.observe(el));

    // Navbar transparent -> solid only for index pages that opt into `.tr`
    const nav = document.getElementById('navbar');
    if (nav?.classList.contains('tr')) {
      const updateNav = () => nav.classList.toggle('sc', window.scrollY > 60);
      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();
    }

    // Burger
    const burger = document.getElementById('burger');
    const mob = document.getElementById('mob-menu');
    burger?.addEventListener('click', () => {
      burger.classList.toggle('open');
      mob?.classList.toggle('open');
      document.body.style.overflow = mob?.classList.contains('open') ? 'hidden' : '';
    });
    mob?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      burger?.classList.remove('open'); mob?.classList.remove('open'); document.body.style.overflow = '';
    }));

    // Cookie
    const cb = document.getElementById('cookieBar');
    if (cb && localStorage.getItem('cookies-choice')) cb.classList.add('hidden');
    document.getElementById('ckAccept')?.addEventListener('click', () => {
      localStorage.setItem('cookies-choice', 'accepted'); cb?.classList.add('hidden');
    });
    document.getElementById('ckRefuse')?.addEventListener('click', () => {
      localStorage.setItem('cookies-choice', 'refused'); cb?.classList.add('hidden');
    });

    // Counters
    const cobs = new IntersectionObserver(entries => {
      entries.forEach(el => {
        if (!el.isIntersecting || el.target.classList.contains('done')) return;
        el.target.classList.add('done');
        const tgt = parseFloat((el.target as HTMLElement).dataset.target || '0');
        const sfx = (el.target as HTMLElement).dataset.suffix || '';
        const dur = 1400; const t0 = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - t0) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.target.textContent = (Number.isInteger(tgt) ? Math.round(tgt * eased) : (tgt * eased).toFixed(0)) + sfx;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: .5 });
    document.querySelectorAll('.ctr').forEach(el => cobs.observe(el));
  </script>
</body>
</html>
