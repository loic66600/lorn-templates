---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout
  title={`Services — ${client.nom}`}
  description={`Élagage, création jardins, entretien, abattage, arrosage automatique — ${client.nom} à Perpignan et dans le 66. Arboriste ISA certifié.`}
>

<nav class="navbar sc" id="navbar">
  <div class="nav-wrap">
    <a href={import.meta.env.BASE_URL} class="nav-logo">
      <div class="nav-logo-leaf"><span>🌿</span></div>
      <div class="nav-logo-text">
        <span class="nav-logo-name">{client.nom}</span>
        <span class="nav-logo-sub">{client.metier}</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href={import.meta.env.BASE_URL}>Accueil</a></li>
      <li><a href={`${base}/services`} class="active">Services</a></li>
      <li><a href={`${base}/realisations`}>Réalisations</a></li>
      <li class="nav-dropdown"><button class="nav-dd-toggle">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href={`${base}/tarifs`}>Tarifs</a><a href={`${base}/a-propos`}>À Propos</a></div></li>
      <li><a href={`${base}/contact`}>Contact</a></li>
    </ul>
    <div class="nav-cta">
      <a href={client.telephoneLink} class="nav-tel">{client.telephone}</a>
      <a href={`${base}/contact`} class="btn btn-green">Devis gratuit</a>
    </div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href={import.meta.env.BASE_URL}>Accueil</a><a href={`${base}/services`}>Services</a><a href={`${base}/realisations`}>Réalisations</a>
    <a href={`${base}/tarifs`}>Tarifs</a><a href={`${base}/a-propos`}>À Propos</a><a href={`${base}/contact`}>Contact</a>
    <a href={`${base}/contact`} class="mob-cta">Devis gratuit →</a>
  </div>
</nav>

<div class="ph">
  <div class="wrap">
    <nav class="ph-bc"><a href={import.meta.env.BASE_URL}>Accueil</a><span>›</span><span>Services</span></nav>
    <div class="eyebrow eyebrow-white">Nos prestations</div>
    <h1 class="ph-title">Élagage, création<br><em>& entretien</em></h1>
    <p class="ph-sub">Arboriste certifié ISA — tous travaux de paysagisme et d'arboriculture dans les Pyrénées-Orientales.</p>
  </div>
</div>

<!-- SERVICES ALTERNÉS -->
<section class="sec">
  <div class="wrap">
    {client.services.map((s, i) => (
      <article class={`srow ${i%2===1 ? 'rev' : ''} grow`}>
        <div class="srow-img iz">
          <img src={s.image} alt={s.titre} loading="lazy" />
          <div class="srow-num serif">0{i+1}</div>
        </div>
        <div class="srow-txt">
          <span class="srow-icon">{s.icone}</span>
          <h2 class="serif srow-title">{s.titre}</h2>
          <p class="srow-desc">{s.description}</p>
          <div class="tags-wrap" style="margin-bottom:1.5rem">
            {s.tags.map(t => <span class="tag tag-green">{t}</span>)}
          </div>
          <a href={`${base}/contact`} class="btn btn-forest">Demander un devis →</a>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- ENGAGEMENTS -->
<section class="sec-alt">
  <div class="wrap">
    <div class="sc">
      <div class="eyebrow grow">Nos engagements</div>
      <h2 class="h2 grow d1">Ce qui nous distingue</h2>
    </div>
    <div class="eng-grid">
      {[
        { icon:"🏅", titre:"Arboriste ISA certifié",     desc:"Certification internationale de référence en arboriculture. Diagnostic et soins des arbres selon les meilleurs standards." },
        { icon:"📋", titre:"Devis gratuit sous 48h",     desc:"Visite à domicile, estimation précise, tarif fixe garanti. Aucune surprise en fin de chantier." },
        { icon:"🌿", titre:"Éco-responsable",            desc:"Broyage sur place, espèces locales, produits bio. Votre jardin respecte son environnement naturel." },
        { icon:"🪓", titre:"CACES Nacelle R486",          desc:"Nos arboristes sont habilités au travail en hauteur par nacelle — sécurité maximale sur chantier." },
        { icon:"🛡️", titre:"Assurance décennale",        desc:"Tous nos travaux de création sont couverts. Votre jardin est protégé 10 ans après livraison." },
        { icon:"🌳", titre:"Urgence arboricole 7j/7",    desc:"Arbre tombé, branche menaçante après tempête ? Nous intervenons sous 4h dans tout le 66." },
      ].map((g, i) => (
        <div class={`eng-card lift grow d${i+1}`}>
          <div class="eng-icon">{g.icon}</div>
          <h3 class="serif eng-title">{g.titre}</h3>
          <p class="eng-desc">{g.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="sec">
  <div class="wrap faq-layout">
    <div class="faq-intro stem">
      <div class="eyebrow">Questions fréquentes</div>
      <h2 class="h2 serif">Les bonnes réponses<br>pour votre jardin</h2>
      <p class="lead" style="margin-top:.75rem">Une question sur vos arbres ou votre projet ? Appelez-nous.</p>
      <a href={client.telephoneLink} class="btn btn-forest" style="margin-top:1.5rem">{client.telephone}</a>
    </div>
    <div class="faq-list">
      {client.faq.map((f, i) => (
        <details class="faq-item" open={i===0}>
          <summary class="serif faq-q">{f.question}<span class="faq-plus">+</span></summary>
          <p class="faq-a">{f.reponse}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="sec-dark">
  <div class="wrap cta-dk">
    <div class="grow">
      <h2 class="h2 h2-white serif">Votre projet paysage</h2>
      <p style="color:rgba(255,255,255,.45);margin-top:10px">Diagnostic gratuit · devis 48h · arboriste certifié</p>
    </div>
    <div style="display:flex;gap:14px;flex-wrap:wrap" class="grow d1">
      <a href={`${base}/contact`} class="btn btn-green btn-lg">Devis gratuit →</a>
      <a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a>
    </div>
  </div>
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nom} | <a href={`${base}/mentions-legales`} style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
</div></div></footer>
</Layout>

<style>
.srow { display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:center; padding:4.5rem 0; border-bottom:1px solid var(--border); }
.srow:last-child { border-bottom:none; }
.srow.rev { direction:rtl; }
.srow.rev > * { direction:ltr; }
.srow-img { position:relative; border-radius:var(--r-md); overflow:hidden; height:380px; }
.srow-img img { width:100%; height:100%; object-fit:cover; }
.srow-num { position:absolute; bottom:14px; right:18px; font-size:5rem; font-weight:700; color:rgba(255,255,255,.14); line-height:1; }
.srow-icon { font-size:2rem; display:block; margin-bottom:14px; }
.srow-title { font-size:1.9rem; font-weight:700; letter-spacing:-.02em; margin-bottom:14px; line-height:1.15; }
.srow-desc { font-size:.95rem; color:var(--text-muted); line-height:1.8; margin-bottom:18px; }
.tags-wrap { display:flex; flex-wrap:wrap; gap:7px; }
.eng-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-top:3rem; }
.eng-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r-md); padding:26px; }
.eng-icon { font-size:1.8rem; margin-bottom:12px; }
.eng-title { font-size:1rem; font-weight:700; margin-bottom:8px; }
.eng-desc { font-size:.85rem; color:var(--text-muted); line-height:1.7; }
.faq-layout { display:grid; grid-template-columns:340px 1fr; gap:64px; align-items:start; }
.faq-list { display:flex; flex-direction:column; gap:3px; }
.faq-item { border:1px solid var(--border); border-radius:var(--r); overflow:hidden; margin-bottom:3px; }
.faq-q { display:flex; justify-content:space-between; align-items:center; padding:16px 20px; cursor:pointer; font-size:.95rem; font-weight:700; list-style:none; gap:12px; }
.faq-q::-webkit-details-marker { display:none; }
.faq-q:hover { background:var(--bg-alt); }
.faq-plus { flex-shrink:0; font-size:1.3rem; font-weight:300; color:var(--green); transition:transform .2s; }
details[open] .faq-plus { transform:rotate(45deg); }
.faq-a { padding:0 20px 16px; font-size:.88rem; color:var(--text-muted); line-height:1.8; }
.cta-dk { display:flex; justify-content:space-between; align-items:center; gap:2rem; flex-wrap:wrap; }
@media(max-width:1024px) { .srow { grid-template-columns:1fr; gap:30px; } .srow.rev { direction:ltr; } .srow-img { height:260px; } .eng-grid { grid-template-columns:repeat(2,1fr); } .faq-layout { grid-template-columns:1fr; gap:32px; } }
@media(max-width:768px) { .eng-grid { grid-template-columns:1fr; } .cta-dk { flex-direction:column; } }
</style>
