---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---
<Layout
  title={`Contact & Devis — ${client.nom}`}
  description={`Contactez ${client.nom} pour un devis gratuit de paysagisme ou d'élagage. Réponse sous 48h. Urgence arboricole 7j/7.`}
>

<nav class="navbar sc" id="navbar">
  <div class="nav-wrap">
    <a href="/" class="nav-logo">
      <div class="nav-logo-leaf"><span>🌿</span></div>
      <div class="nav-logo-text"><span class="nav-logo-name">{client.nom}</span><span class="nav-logo-sub">{client.metier}</span></div>
    </a>
    <ul class="nav-links">
      <li><a href="/">Accueil</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/realisations">Réalisations</a></li>
      <li class="nav-dropdown"><button class="nav-dd-toggle">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a></div></li>
      <li><a href="/contact" class="active">Contact</a></li>
    </ul>
    <div class="nav-cta"><a href={client.telephoneLink} class="nav-tel">{client.telephone}</a><a href="/contact" class="btn btn-green">Devis gratuit</a></div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href="/">Accueil</a><a href="/services">Services</a><a href="/realisations">Réalisations</a>
    <a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a><a href="/contact">Contact</a>
    <a href="/contact" class="mob-cta">Devis gratuit →</a>
  </div>
</nav>

<div class="ph">
  <div class="wrap">
    <nav class="ph-bc"><a href="/">Accueil</a><span>›</span><span>Contact</span></nav>
    <div class="eyebrow eyebrow-white">Gratuit & sans engagement</div>
    <h1 class="ph-title">Demandez votre<br><em>devis paysage</em></h1>
    <p class="ph-sub">Visite à domicile gratuite · estimation précise · réponse sous 48h. Urgence arboricole disponible 7j/7.</p>
  </div>
</div>

<section class="sec">
  <div class="wrap contact-grid">

    <!-- COLONNE INFO -->
    <div class="c-info stem">

      <!-- Card urgence -->
      {client.urgence && (
        <div class="urg-card">
          <div class="urg-card-top">
            <span>🌳</span>
            <strong class="serif">Urgence arboricole 7j/7</strong>
          </div>
          <p>Arbre tombé, branche menaçante après la Tramontane ? Appelez notre numéro d'urgence — intervention sous 4h.</p>
          <a href={client.urgenceTelLink} class="btn btn-green" style="width:100%;justify-content:center;margin-top:12px">{client.urgenceTel}</a>
        </div>
      )}

      <!-- Coordonnées -->
      <div class="info-bloc">
        <h3 class="serif ib-h">Coordonnées</h3>
        <div class="info-items">
          <div class="ii"><span class="ii-ico">📞</span><div><small>Téléphone</small><a href={client.telephoneLink}>{client.telephone}</a></div></div>
          <div class="ii"><span class="ii-ico">✉️</span><div><small>Email</small><a href={`mailto:${client.email}`}>{client.email}</a></div></div>
          <div class="ii"><span class="ii-ico">📍</span><div><small>Adresse</small><span>{client.adresse}</span></div></div>
        </div>
      </div>

      <!-- Horaires -->
      <div class="info-bloc">
        <h3 class="serif ib-h">Horaires</h3>
        <div class="horaires">
          {client.horaires.map(h => (
            <div class="h-row">
              <span class="serif h-j">{h.jour}</span>
              <span class={`h-v ${h.horaire==='Fermé' ? 'ferme' : ''}`}>{h.horaire}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Zones -->
      <div class="info-bloc">
        <h3 class="serif ib-h">Zone d'intervention</h3>
        <p style="font-size:.85rem;color:var(--text-muted);line-height:1.65;margin-bottom:10px">{client.departement} — rayon {client.rayonKm} km. Déplacement gratuit.</p>
        <div class="zone-chips">
          {client.zones.slice(0,8).map(z => <span class="tag">{z}</span>)}
          <span class="tag tag-green">+{client.zones.length-8} communes</span>
        </div>
      </div>
    </div>

    <!-- FORMULAIRE -->
    <div class="f-wrap branch">
      <div class="f-card" id="contactForm">
        <h2 class="serif f-title">Décrivez votre projet</h2>
        <p class="f-sub">Plus votre description est précise, plus notre devis sera rapide.</p>
        <div class="fields">
          <div class="f-row">
            <div class="fg"><label for="fNom">Prénom & Nom *</label><input type="text" id="fNom" placeholder="Jean Dupont" required /></div>
            <div class="fg"><label for="fTel">Téléphone *</label><input type="tel" id="fTel" placeholder="06 00 00 00 00" required /></div>
          </div>
          <div class="fg"><label for="fEmail">Email</label><input type="email" id="fEmail" placeholder="jean@exemple.fr" /></div>
          <div class="fg"><label for="fVille">Commune du chantier *</label><input type="text" id="fVille" placeholder="Ex : Perpignan, Canet, Thuir…" required /></div>
          <div class="f-row">
            <div class="fg">
              <label for="fPresta">Type de travaux *</label>
              <select id="fPresta" required>
                <option value="">Choisir…</option>
                {client.services.map(s => <option value={s.titre}>{s.icone} {s.titre}</option>)}
                <option value="Urgence arboricole">🌳 Urgence arboricole</option>
                <option value="Autre / Je ne sais pas">Autre / Je ne sais pas</option>
              </select>
            </div>
            <div class="fg">
              <label for="fSurface">Surface approximative</label>
              <select id="fSurface">
                <option value="">Choisir…</option>
                <option>Moins de 100 m²</option>
                <option>100 – 300 m²</option>
                <option>300 – 1 000 m²</option>
                <option>Plus de 1 000 m²</option>
                <option>Domaine / Copropriété</option>
              </select>
            </div>
          </div>
          <div class="fg">
            <label for="fMsg">Description du projet</label>
            <textarea id="fMsg" rows="4" placeholder="Décrivez vos végétaux (espèce, hauteur), l'accès au jardin, vos souhaits pour la réalisation…"></textarea>
          </div>
          <button type="button" class="btn btn-forest btn-lg f-submit" id="submitBtn" style="width:100%;justify-content:center">
            Envoyer ma demande →
          </button>
        </div>
      </div>
      <div class="f-ok" id="formOk" style="display:none">
        <div class="ok-icon">🌿</div>
        <h3 class="serif">Demande reçue !</h3>
        <p>Nous vous contactons sous 48h pour organiser la visite gratuite.</p>
        <p style="margin-top:8px;font-size:.88rem;color:var(--text-muted)">Besoin urgent ? <a href={client.telephoneLink}>{client.telephone}</a></p>
      </div>
    </div>
  </div>
</section>

<!-- CARTE -->
{client.googleMapsEmbed && (
  <div class="map-wrap">
    <iframe src={client.googleMapsEmbed} width="100%" height="380" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Localisation Verde Paysage" />
  </div>
)}

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nom} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
</div></div></footer>
</Layout>

<script define:vars={{ web3Key, emailClient: client.email, nomClient: client.nom }}>
  const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const fc  = document.getElementById('contactForm') as HTMLElement | null;
  const ok  = document.getElementById('formOk') as HTMLElement | null;

  btn?.addEventListener('click', async () => {
    const nom    = (document.getElementById('fNom') as HTMLInputElement)?.value || '';
    const tel    = (document.getElementById('fTel') as HTMLInputElement)?.value || '';
    const email  = (document.getElementById('fEmail') as HTMLInputElement)?.value || '';
    const ville  = (document.getElementById('fVille') as HTMLInputElement)?.value || '';
    const presta = (document.getElementById('fPresta') as HTMLSelectElement)?.value || '';
    const surf   = (document.getElementById('fSurface') as HTMLSelectElement)?.value || '';
    const msg    = (document.getElementById('fMsg') as HTMLTextAreaElement)?.value || '';

    if (!nom || !tel || !ville || !presta) { alert('Remplissez les champs obligatoires (*).'); return; }
    btn.disabled = true; btn.textContent = 'Envoi en cours…';

    if (web3Key) {
      try {
        const r = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_key: web3Key,
            subject: `Devis paysage — ${presta} — ${nom} (${ville})`,
            from_name: nom, telephone: tel, email, commune: ville,
            prestation: presta, surface: surf, message: msg,
          }),
        });
        const d = await r.json();
        if (d.success && fc && ok) { fc.style.display = 'none'; ok.style.display = 'flex'; return; }
      } catch (e) {}
    }
    // Fallback mailto
    window.location.href = 'mailto:' + emailClient
      + '?subject=' + encodeURIComponent('Devis — ' + presta + ' — ' + ville)
      + '&body='    + encodeURIComponent('Nom: ' + nom + '\nTél: ' + tel + '\nCommune: ' + ville + '\nPrestation: ' + presta + '\nSurface: ' + surf + '\n\n' + msg);
  });
</script>

<style>
.contact-grid { display:grid; grid-template-columns:360px 1fr; gap:56px; align-items:start; }
.urg-card { background:var(--forest); border-radius:var(--r-md); padding:18px; margin-bottom:16px; }
.urg-card-top { display:flex; align-items:center; gap:10px; color:var(--green-light); font-size:1.1rem; margin-bottom:8px; }
.urg-card p { font-size:.85rem; color:rgba(255,255,255,.55); line-height:1.65; }
.info-bloc { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r-md); padding:20px; margin-bottom:14px; }
.ib-h { font-size:.78rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--text-muted); margin-bottom:14px; }
.info-items { display:flex; flex-direction:column; gap:12px; }
.ii { display:flex; align-items:flex-start; gap:10px; }
.ii-ico { font-size:1rem; margin-top:3px; flex-shrink:0; }
.ii small { display:block; font-size:10px; color:var(--text-muted); text-transform:uppercase; letter-spacing:.07em; margin-bottom:2px; }
.ii a, .ii span { font-size:.88rem; font-weight:600; color:var(--text); }
.ii a:hover { color:var(--green); }
.horaires { display:flex; flex-direction:column; gap:1px; }
.h-row { display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border); font-size:.84rem; }
.h-row:last-child { border-bottom:none; }
.h-j { font-weight:700; }
.h-v { color:var(--text-muted); }
.h-v.ferme { color:var(--text-light); }
.zone-chips { display:flex; flex-wrap:wrap; gap:6px; }
.f-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r-md); padding:34px; }
.f-title { font-size:1.5rem; font-weight:700; margin-bottom:6px; letter-spacing:-.02em; }
.f-sub { font-size:.88rem; color:var(--text-muted); margin-bottom:26px; }
.fields { display:flex; flex-direction:column; gap:14px; }
.f-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.fg { display:flex; flex-direction:column; gap:5px; }
.fg label { font-size:12px; font-weight:600; color:var(--text); letter-spacing:.04em; }
.fg input, .fg select, .fg textarea { padding:11px 14px; border:1.5px solid var(--border-strong); border-radius:var(--r); font-family:var(--font-body); font-size:.88rem; color:var(--text); background:var(--bg); transition:border-color .2s; }
.fg input:focus, .fg select:focus, .fg textarea:focus { outline:none; border-color:var(--green); }
.fg textarea { resize:vertical; min-height:110px; }
.f-ok { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r-md); padding:52px; flex-direction:column; align-items:center; text-align:center; gap:12px; }
.ok-icon { font-size:3.5rem; }
.f-ok h3 { font-size:1.5rem; font-weight:700; }
.f-ok p { color:var(--text-muted); line-height:1.7; }
.f-ok a { color:var(--green); font-weight:700; }
.map-wrap { height:380px; }
.map-wrap iframe { display:block; }
@media(max-width:1024px) { .contact-grid { grid-template-columns:1fr; } .c-info { order:2; } .f-wrap { order:1; } }
@media(max-width:640px) { .f-row { grid-template-columns:1fr; } .f-card { padding:20px; } }
</style>
