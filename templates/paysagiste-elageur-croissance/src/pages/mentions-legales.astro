---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout
  title={`Mentions légales — ${client.nom}`}
  description={`Mentions légales et politique de confidentialité de ${client.nom}.`}
  noIndex={true}
>

<nav class="navbar sc" id="navbar">
  <div class="nav-wrap">
    <a href={import.meta.env.BASE_URL} class="nav-logo">
      <div class="nav-logo-leaf"><span>🌿</span></div>
      <div class="nav-logo-text"><span class="nav-logo-name">{client.nom}</span><span class="nav-logo-sub">{client.metier}</span></div>
    </a>
    <ul class="nav-links"><li><a href={import.meta.env.BASE_URL}>Accueil</a></li><li><a href={`${base}/services`}>Services</a></li><li><a href={`${base}/contact`}>Contact</a></li></ul>
    <div class="nav-cta"><a href={client.telephoneLink} class="nav-tel">{client.telephone}</a></div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu"><a href={import.meta.env.BASE_URL}>Accueil</a><a href={`${base}/services`}>Services</a><a href={`${base}/contact`}>Contact</a></div>
</nav>

<section class="legal-wrap">
  <div class="wrap legal-container">
    <nav class="l-bc"><a href={import.meta.env.BASE_URL}>Accueil</a><span>›</span><span>Mentions légales</span></nav>
    <h1 class="serif l-title">Mentions légales</h1>
    <p class="l-date">Dernière mise à jour : {new Date().toLocaleDateString('fr-FR', { year:'numeric', month:'long', day:'numeric' })}</p>

    <div class="l-blocks">

      <div class="lb">
        <h2>1. Éditeur du site</h2>
        <p><strong>{client.responsable}</strong><br/>
        Entreprise individuelle · SIRET : {client.siret}<br/>
        Adresse : {client.adresse}<br/>
        Téléphone : <a href={client.telephoneLink}>{client.telephone}</a><br/>
        Email : <a href={`mailto:${client.email}`}>{client.email}</a></p>
        <p>Activité principale : {client.specialite}</p>
      </div>

      <div class="lb">
        <h2>2. Hébergement</h2>
        <p>{client.hebergeur} — <a href="https://www.netlify.com" target="_blank" rel="noopener">www.netlify.com</a></p>
      </div>

      <div class="lb">
        <h2>3. Conception & développement</h2>
        <p>Ce site a été conçu et développé par <strong>LORN Digital Studio</strong>.<br/>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener">vitemonsite-artisan.fr</a></p>
      </div>

      <div class="lb">
        <h2>4. Propriété intellectuelle</h2>
        <p>L'ensemble du contenu de ce site (textes, photographies, design, structure) est la propriété de {client.nom} ou de ses partenaires. Toute reproduction, représentation ou diffusion sans autorisation écrite préalable est interdite (art. L.335-2 CPI).</p>
        <p>Les photographies proviennent de Unsplash.com (licence Unsplash, usage commercial autorisé).</p>
      </div>

      <div class="lb">
        <h2>5. Protection des données personnelles (RGPD)</h2>
        <h3>Données collectées</h3>
        <p>Via le formulaire de contact : nom, téléphone, email, commune d'intervention, type de travaux, surface, message descriptif. Ces données sont utilisées exclusivement pour répondre à votre demande de devis et organiser la visite.</p>
        <h3>Base légale du traitement</h3>
        <p>Consentement de la personne concernée (art. 6.1.a RGPD) et intérêt légitime de {client.nom} (art. 6.1.f RGPD).</p>
        <h3>Durée de conservation</h3>
        <p>3 ans à compter de votre dernière interaction (recommandation CNIL pour la prospection commerciale).</p>
        <h3>Vos droits</h3>
        <p>Conformément au RGPD, vous disposez des droits d'accès, de rectification, de suppression, de limitation, de portabilité et d'opposition. Pour les exercer, écrivez à : <a href={`mailto:${client.email}`}>{client.email}</a>. En cas de litige, vous pouvez contacter la <a href="https://www.cnil.fr" target="_blank" rel="noopener">CNIL</a>.</p>
        <h3>Sous-traitant de données — Formulaire</h3>
        <p>Les données saisies dans le formulaire de contact sont transmises via <strong>Web3Forms</strong> (web3forms.com), service conforme RGPD. Aucune donnée n'est vendue, revendue ou partagée avec des tiers à des fins commerciales.</p>
      </div>

      <div class="lb">
        <h2>6. Cookies</h2>
        <p>Ce site utilise uniquement des cookies techniques strictement nécessaires au bon fonctionnement (mémorisation de votre choix de consentement cookies). Aucun cookie publicitaire, traceur analytique tiers (Google Analytics, Facebook Pixel, etc.) n'est utilisé.</p>
      </div>

      <div class="lb">
        <h2>7. Liens hypertextes</h2>
        <p>{client.nom} ne peut être tenu responsable du contenu des sites tiers vers lesquels des liens sont proposés. La création de liens vers ce site est soumise à autorisation préalable.</p>
      </div>

      <div class="lb">
        <h2>8. Droit applicable & juridiction compétente</h2>
        <p>Les présentes mentions légales sont soumises au droit français. En cas de litige, les tribunaux compétents sont ceux du ressort du domicile du défendeur, sauf disposition contraire.</p>
      </div>

    </div>

    <a href={import.meta.env.BASE_URL} class="btn btn-outline" style="margin-top:2.5rem">← Retour à l'accueil</a>
  </div>
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nom}</p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
</div></div></footer>
</Layout>

<style>
.legal-wrap { padding: calc(var(--nav-h) + 4.5rem) 0 5rem; }
.legal-container { max-width: 720px; }
.l-bc { display:flex; gap:8px; font-size:12px; color:var(--text-muted); margin-bottom:20px; align-items:center; }
.l-bc a { color:var(--text-muted); transition:color .2s; }
.l-bc a:hover { color:var(--green); }
.l-title { font-size:2.6rem; font-weight:700; letter-spacing:-.03em; margin-bottom:6px; line-height:1.1; }
.l-date { font-size:13px; color:var(--text-muted); margin-bottom:3.5rem; }
.l-blocks { display:flex; flex-direction:column; }
.lb { padding:1.75rem 0; border-bottom:1px solid var(--border); }
.lb:last-child { border-bottom:none; }
.lb h2 { font-family:var(--font-serif); font-size:1.05rem; font-weight:700; margin-bottom:.9rem; color:var(--text); }
.lb h3 { font-family:var(--font-serif); font-size:.9rem; font-weight:700; margin:.9rem 0 .45rem; color:var(--text); }
.lb p { font-size:.88rem; color:var(--text-muted); line-height:1.85; margin-bottom:.6rem; }
.lb p:last-child { margin-bottom:0; }
.lb a { color:var(--green); text-decoration:underline; text-underline-offset:3px; }
.lb strong { color:var(--text); font-weight:600; }
</style>
