---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout
  title={`Réalisations — ${client.nom}`}
  description={`Galerie de jardins créés et entretenus par ${client.nom} : créations, élagage, abattage, arrosage automatique. Perpignan et Pyrénées-Orientales.`}
>

<nav class="navbar sc" id="navbar">
  <div class="nav-wrap">
    <a href={import.meta.env.BASE_URL} class="nav-logo">
      <div class="nav-logo-leaf"><span>🌿</span></div>
      <div class="nav-logo-text"><span class="nav-logo-name">{client.nom}</span><span class="nav-logo-sub">{client.metier}</span></div>
    </a>
    <ul class="nav-links">
      <li><a href={import.meta.env.BASE_URL}>Accueil</a></li>
      <li><a href={`${base}/services`}>Services</a></li>
      <li><a href={`${base}/realisations`} class="active">Réalisations</a></li>
      <li class="nav-dropdown"><button class="nav-dd-toggle">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href={`${base}/tarifs`}>Tarifs</a><a href={`${base}/a-propos`}>À Propos</a></div></li>
      <li><a href={`${base}/contact`}>Contact</a></li>
    </ul>
    <div class="nav-cta"><a href={client.telephoneLink} class="nav-tel">{client.telephone}</a><a href={`${base}/contact`} class="btn btn-green">Devis gratuit</a></div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href={import.meta.env.BASE_URL}>Accueil</a><a href={`${base}/services`}>Services</a><a href={`${base}/realisations`}>Réalisations</a>
    <a href={`${base}/tarifs`}>Tarifs</a><a href={`${base}/a-propos`}>À Propos</a><a href={`${base}/contact`}>Contact</a>
    <a href={`${base}/contact`} class="mob-cta">Devis gratuit →</a>
  </div>
</nav>

<div class="ph">
  <div class="wrap">
    <nav class="ph-bc"><a href={import.meta.env.BASE_URL}>Accueil</a><span>›</span><span>Réalisations</span></nav>
    <div class="eyebrow eyebrow-white">Nos chantiers</div>
    <h1 class="ph-title">{client.stats[1].chiffre}+ jardins<br><em>dans le 66</em></h1>
    <p class="ph-sub">Une sélection de réalisations récentes en Pyrénées-Orientales.</p>
  </div>
</div>

<section class="sec">
  <div class="wrap">
    <!-- Filtres -->
    <div class="filters grow">
      {client.realisationsCategories.map(cat => (
        <button class={`fbtn ${cat.id==='all' ? 'active' : ''}`} data-filter={cat.id}>{cat.label}</button>
      ))}
    </div>

    <!-- Grille -->
    <div class="real-grid" id="realGrid">
      {client.realisations.map((r, i) => (
        <article class={`rc lift grow d${(i%3)+1}`} data-cat={r.categorie}>
          <div class="rc-img iz">
            <img src={r.image} alt={r.titre} loading="lazy" />
            <div class="rc-badges">
              <span class="rc-cat-badge">{r.categorie}</span>
              <span class="rc-surface">{r.surface}</span>
            </div>
          </div>
          <div class="rc-body">
            <div class="rc-meta serif"><span>📍 {r.lieu}</span><span>· {r.annee}</span></div>
            <h3 class="serif rc-title">{r.titre}</h3>
            <p>{r.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="sec-dark">
  <div class="wrap cta-dk">
    <div class="grow">
      <div class="eyebrow eyebrow-gold">Votre jardin</div>
      <h2 class="h2 h2-white serif">Le prochain chef-d'œuvre,<br><em>c'est le vôtre ?</em></h2>
    </div>
    <div style="display:flex;gap:14px;flex-wrap:wrap" class="grow d1">
      <a href={`${base}/contact`} class="btn btn-green btn-lg">Devis gratuit →</a>
      <a href={client.telephoneLink} class="btn btn-outline-white btn-lg">{client.telephone}</a>
    </div>
  </div>
</section>

<footer class="footer"><div class="wrap"><div class="f-bottom" style="border-top:none;padding-top:0">
  <p>© {new Date().getFullYear()} {client.nom} | <a href={`${base}/mentions-legales`} style="color:inherit">Mentions légales</a></p>
  <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">Site par <strong>LORN Digital Studio</strong></a>
</div></div></footer>
</Layout>

<script>
  document.querySelectorAll('.fbtn').forEach(btn => btn.addEventListener('click', () => {
    document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = (btn as HTMLElement).dataset.filter || 'all';
    document.querySelectorAll('[data-cat]').forEach(c => {
      (c as HTMLElement).style.display = f === 'all' || (c as HTMLElement).dataset.cat === f ? '' : 'none';
    });
  }));
</script>

<style>
.filters { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:2.5rem; }
.fbtn { padding:8px 18px; border-radius:var(--r-pill); font-family:var(--font-body); font-size:12px; font-weight:600; border:1.5px solid var(--border-strong); background:transparent; color:var(--text-muted); cursor:pointer; transition:all .2s; }
.fbtn:hover,.fbtn.active { background:var(--forest); border-color:var(--forest); color:#fff; }
.real-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; }
.rc { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r-md); overflow:hidden; }
.rc-img { position:relative; height:240px; }
.rc-img img { width:100%; height:100%; object-fit:cover; }
.rc-badges { position:absolute; top:12px; left:12px; right:12px; display:flex; justify-content:space-between; }
.rc-cat-badge { background:var(--green); color:#fff; padding:4px 11px; border-radius:var(--r-pill); font-family:var(--font-serif); font-size:10px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; }
.rc-surface { background:rgba(201,168,76,.92); color:#fff; padding:4px 10px; border-radius:var(--r-pill); font-size:11px; font-weight:700; }
.rc-body { padding:18px; }
.rc-meta { display:flex; gap:7px; font-size:11px; color:var(--text-muted); margin-bottom:8px; }
.rc-title { font-size:.95rem; font-weight:700; margin-bottom:6px; }
.rc-body p { font-size:.82rem; color:var(--text-muted); line-height:1.65; }
.cta-dk { display:flex; justify-content:space-between; align-items:center; gap:2rem; flex-wrap:wrap; }
@media(max-width:1024px) { .real-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:640px)  { .real-grid { grid-template-columns:1fr; } .cta-dk { flex-direction:column; } }
</style>
