---
import Layout from '../layouts/Layout.astro';
import { client } from '../data/client';

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
const socials = Object.entries(client.reseaux).filter(([_,v]) => v);
const socialIcons: Record<string,string> = {
  facebook: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>',
  instagram:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>',
  linkedin: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>',
  youtube:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>',
  tiktok:  '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52V6.83a4.84 4.84 0 01-1-.14z"/></svg>',
  twitter: '<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
};

const featuredServices = client.services.filter(s => s.featured);
const extraServices    = client.services.filter(s => !s.featured);
---

<Layout>

  <!-- ═══ NAVBAR ═══ -->
  <nav class="navbar tr" id="navbar">
    <div class="nav-wrap">
      <a href="/" class="nav-logo">
        <div class="nav-logo-leaf"><span>🌿</span></div>
        <div class="nav-logo-text">
          <span class="nav-logo-name wh">{client.nom}</span>
          <span class="nav-logo-sub wh">{client.metier}</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="active wh">Accueil</a></li>
        <li><a href="/services" class="wh">Services</a></li>
        <li><a href="/realisations" class="wh">Réalisations</a></li>
        <li class="nav-dropdown"><button class="nav-dd-toggle wh">Plus <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="nav-dd-menu"><a href="/tarifs">Tarifs</a><a href="/a-propos">À Propos</a></div></li>
        <li><a href="/contact" class="wh">Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href={client.telephoneLink} class="nav-tel wh">{client.telephone}</a>
        <a href="/contact" class="btn btn-green">Devis gratuit</a>
      </div>
      <button class="burger wh" id="burger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mob-menu" id="mob-menu">
      <a href="/">Accueil</a>
      <a href="/services">Services</a>
      <a href="/realisations">Réalisations</a>
      <a href="/tarifs">Tarifs</a>
      <a href="/a-propos">À Propos</a>
      <a href="/contact">Contact</a>
      <a href="/contact" class="mob-cta">Devis gratuit →</a>
    </div>
  </nav>

  <!-- ═══ HERO — PLEIN ÉCRAN ═══ -->
  <section class="hero">
    <!-- Photo de fond -->
    <div class="hero-bg">
      <img src={client.heroImage} alt={client.heroImageAlt} loading="eager" />
    </div>
    <!-- Overlay gradient sombre bas vers transparent -->
    <div class="hero-overlay"></div>
    <!-- Contenu -->
    <div class="wrap hero-content">
      <!-- Badge éco -->
      <div class="hero-eco grow">
        <span class="eco-dot">🌱</span>
        <span>{client.eco.badge}</span>
        <span class="eco-sep">·</span>
        <span>{client.slogan}</span>
      </div>

      <h1 class="hero-h1 serif grow d1">
        Votre jardin,<br>
        <em>une œuvre vivante.</em>
      </h1>

      <p class="hero-sub grow d2">
        Paysagiste élagueur à Perpignan depuis 2005 — création de jardins méditerranéens,
        élagage, entretien et arboriculture dans tout le 66.
      </p>

      <div class="hero-actions grow d3">
        <a href="/contact" class="btn btn-green btn-lg">Devis gratuit →</a>
        <a href="/realisations" class="btn btn-outline-white btn-lg">Voir nos jardins</a>
      </div>

      <!-- Stats -->
      <div class="hero-stats grow d4">
        {client.stats.map(s => (
          <div class="hs">
            <div class="hs-num serif">
              <span class="ctr" data-target={s.chiffre} data-suffix={s.suffix}>0</span>
            </div>
            <div class="hs-lbl">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Vague organique bas de page -->
    <div class="hero-wave">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,60 C180,100 360,20 540,60 C720,100 900,20 1080,55 C1260,90 1380,30 1440,50 L1440,100 L0,100 Z" fill="#F6F4EF"/>
      </svg>
    </div>

    <!-- Carte urgence flottante -->
    {client.urgence && (
      <a href={client.urgenceTelLink} class="hero-urgence grow d5">
        <span class="urg-icon">🌳</span>
        <div>
          <strong class="serif">Arbre tombé ?</strong>
          <span>Urgence 7j/7 — {client.urgenceTel}</span>
        </div>
      </a>
    )}
  </section>

  <!-- ═══ SAISONS ═══ -->
  <section class="sec-saisons">
    <div class="wrap">
      <div class="sc grow">
        <div class="eyebrow">Toute l'année</div>
        <h2 class="h2 grow d1">Nous intervenons en toutes saisons</h2>
      </div>
      <div class="saisons-grid">
        {client.saisons.map((s, i) => (
          <div class={`saison-card lift grow d${i+1}`}>
            <div class="saison-icon">{s.icon}</div>
            <h3 class="serif saison-title">{s.saison}</h3>
            <p class="saison-travaux">{s.travaux}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES VEDETTES ═══ -->
  <section class="sec-alt" id="services">
    <div class="wrap">
      <div class="svc-head">
        <div>
          <div class="eyebrow grow">Nos prestations</div>
          <h2 class="h2 grow d1">Paysagisme, élagage<br><em class="serif" style="font-style:italic">& entretien</em></h2>
          <p class="lead grow d2" style="margin-top:.75rem">Tous vos travaux d'espaces verts réalisés par une équipe certifiée — arboristes ISA, permis nacelle, assurance décennale.</p>
        </div>
        <a href="/services" class="btn btn-outline grow d1">Tous nos services →</a>
      </div>

      <!-- 3 services featured en grille -->
      <div class="svc-grid">
        {featuredServices.map((s, i) => (
          <article class={`svc-card lift grow d${i+1}`}>
            <div class="svc-img iz">
              <img src={s.image} alt={s.titre} loading="lazy" />
              <div class="svc-num serif">0{i+1}</div>
            </div>
            <div class="svc-body">
              <span class="svc-icon">{s.icone}</span>
              <h3 class="serif svc-title">{s.titre}</h3>
              <p class="svc-desc">{s.description}</p>
              <div class="tags-wrap">
                {s.tags.map(t => <span class="tag tag-green">{t}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Services complémentaires -->
      <div class="extra-services">
        {extraServices.map((s, i) => (
          <a href="/services" class={`extra-card lift grow d${i+1}`}>
            <span class="extra-icon">{s.icone}</span>
            <div class="extra-body">
              <strong class="serif">{s.titre}</strong>
              <p>{s.tags.join(' · ')}</p>
            </div>
            <span class="extra-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ECO BANDE ═══ -->
  <section class="eco-band">
    <div class="wrap eco-band-inner">
      <div class="stem eco-text">
        <span class="eco-big">🌿</span>
        <div>
          <h3 class="serif eco-titre">Paysagisme éco-responsable</h3>
          <p>Un jardin beau ne doit pas coûter à la planète.</p>
        </div>
      </div>
      <div class="eco-commits branch">
        {client.eco.engagements.map(e => (
          <div class="eco-commit">
            <span class="eco-check">✓</span>
            <span>{e}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PROCESSUS ═══ -->
  <section class="sec" id="processus">
    <div class="wrap">
      <div class="sc">
        <div class="eyebrow grow">Comment ça marche</div>
        <h2 class="h2 grow d1">Simple, transparent,<br><em class="serif" style="font-style:italic">sans surprise</em></h2>
      </div>
      <div class="proc-grid">
        {client.processus.map((p, i) => (
          <div class={`proc-card grow d${i+1}`}>
            <div class="proc-line"></div>
            <div class="proc-dot"></div>
            <div class="proc-num serif">{p.num}</div>
            <h3 class="serif proc-title">{p.titre}</h3>
            <p class="proc-desc">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ RÉALISATIONS APERÇU ═══ -->
  <section class="sec-alt" id="realisations">
    <div class="wrap">
      <div class="real-head">
        <div>
          <div class="eyebrow grow">Nos chantiers</div>
          <h2 class="h2 grow d1">Quelques<br><em class="serif" style="font-style:italic">réalisations récentes</em></h2>
        </div>
        <a href="/realisations" class="btn btn-outline grow">Voir toute la galerie →</a>
      </div>
      <div class="real-mosaic">
        {client.realisations.slice(0,4).map((r, i) => (
          <article class={`real-card lift grow d${i%2===0 ? 1 : 2}`} data-size={i===0 ? 'big' : 'small'}>
            <div class="real-img iz">
              <img src={r.image} alt={r.titre} loading="lazy" />
              <div class="real-overlay">
                <span class="real-cat">{r.categorie}</span>
              </div>
            </div>
            <div class="real-body">
              <div class="real-meta serif">
                <span>📍 {r.lieu}</span>
                <span>· {r.surface}</span>
                <span>· {r.annee}</span>
              </div>
              <h3 class="serif real-title">{r.titre}</h3>
              <p>{r.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TÉMOIGNAGES ═══ -->
  <section class="sec-dark" id="temoignages">
    <div class="wrap">
      <div class="sc">
        <div class="eyebrow eyebrow-gold">Ils nous font confiance</div>
        <h2 class="h2 h2-white grow d1">
          Des jardins qui font<br>
          <em class="serif" style="font-style:italic;color:var(--green-light)">parler d'eux</em>
        </h2>
        <div class="note-glob grow d2">
          <span class="note-num serif">5,0</span>
          <div class="note-stars">★★★★★</div>
          <span class="note-count">· {client.temoignages.length * 55}+ avis vérifiés</span>
        </div>
      </div>
      <div class="test-grid">
        {client.temoignages.map((t, i) => (
          <article class={`test-card grow d${i+1}`}>
            <div class="test-stars">{"★".repeat(t.note)}</div>
            <blockquote class="serif test-quote">"{t.texte}"</blockquote>
            <div class="test-footer">
              <div class="test-avatar serif">{t.nom.charAt(0)}</div>
              <div>
                <div class="test-nom serif">{t.nom}</div>
                <div class="test-type">{t.type} · {t.ville}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ZONES ═══ -->
  <section class="sec zones-sec" id="zones">
    <div class="wrap zones-grid">
      <div class="zones-text stem">
        <div class="eyebrow">Zone d'intervention</div>
        <h2 class="h2">{client.rayonKm} km autour<br>de Perpignan</h2>
        <p class="lead" style="margin-top:.75rem">
          De la côte à la plaine, des Corbières aux Aspres — nous intervenons dans tout
          le département des Pyrénées-Orientales. Déplacement gratuit pour le diagnostic.
        </p>
        <div class="zones-tags">
          {client.zones.map(z => <span class="tag">{z}</span>)}
        </div>
        <a href="/contact" class="btn btn-forest" style="margin-top:2rem">Vérifier ma commune →</a>
      </div>
      <div class="zones-img branch">
        <div class="zi-wrap iz">
          <img src={client.heroImage2} alt="Paysagiste Pyrénées-Orientales" loading="lazy" />
        </div>
        <div class="zi-badge serif">
          <span class="zi-badge-num">{client.stats[1].chiffre}+</span>
          <span>jardins réalisés</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA DEVIS ═══ -->
  <section class="cta-band">
    <div class="wrap cta-inner">
      <div class="cta-text stem">
        <div class="eyebrow eyebrow-white">Gratuit & sans engagement</div>
        <h2 class="h2 h2-white serif">Votre devis<br>sous 48h</h2>
        <p style="color:rgba(255,255,255,.55);margin-top:.75rem;line-height:1.75">Visite à domicile offerte — diagnostic arboricole inclus.</p>
      </div>
      <div class="cta-actions branch">
        <a href="/contact" class="btn btn-gold btn-lg">Demander un devis →</a>
        <a href={client.telephoneLink} class="btn btn-outline-white btn-lg">📞 {client.telephone}</a>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="wrap">
      <div class="footer-grid">
        <div class="f-brand">
          <div class="f-logo-row">
            <div class="f-logo-leaf"><span>🌿</span></div>
            <span class="f-logo-name serif">{client.nom}</span>
          </div>
          <p>{client.specialite}.<br/>{client.ville} et tout le 66 depuis 2005.</p>
          {socials.length > 0 && (
            <div class="soc-links">
              {socials.map(([k,v]) => (
                <a href={v} target="_blank" rel="noopener" class="soc-link soc-dark" title={k} set:html={socialIcons[k] || k} />
              ))}
            </div>
          )}
        </div>
        <div class="f-col">
          <h4>Navigation</h4>
          <ul>
            <li><a href="/">Accueil</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/realisations">Réalisations</a></li>
            <li><a href="/tarifs">Tarifs</a></li>
            <li><a href="/a-propos">À Propos</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="f-col">
          <h4>Prestations</h4>
          <ul>
            {client.services.map(s => <li><a href="/services">{s.titre}</a></li>)}
          </ul>
        </div>
        <div class="f-col">
          <h4>Contact</h4>
          <ul>
            <li><a href={client.telephoneLink}>{client.telephone}</a></li>
            <li><a href={`mailto:${client.email}`}>{client.email}</a></li>
            <li><span style="color:rgba(255,255,255,.3);font-size:12px">{client.adresse}</span></li>
            {client.urgence && (
              <li><a href={client.urgenceTelLink} style="color:var(--green-light)">🌳 Urgence : {client.urgenceTel}</a></li>
            )}
          </ul>
        </div>
      </div>
      <div class="f-bottom">
        <p>© {new Date().getFullYear()} {client.nom} — {client.ville} | <a href="/mentions-legales" style="color:inherit">Mentions légales</a></p>
        <a href="https://vitemonsite-artisan.fr" target="_blank" rel="noopener" class="lorn-badge">
          Site par <strong>LORN Digital Studio</strong>
        </a>
      </div>
    </div>
  </footer>

</Layout>

<style>
/* ═══ HERO ═══ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
}
.hero-bg img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 30%;
}
.hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(
    to top,
    rgba(27,46,27,.95) 0%,
    rgba(27,46,27,.65) 35%,
    rgba(27,46,27,.25) 70%,
    rgba(27,46,27,.1) 100%
  );
}
.hero-content {
  position: relative; z-index: 2;
  padding-top: calc(var(--nav-h) + 3rem);
  padding-bottom: 8rem;
}
.hero-eco {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(92,158,74,.2); border: 1px solid rgba(92,158,74,.4);
  backdrop-filter: blur(8px);
  color: rgba(255,255,255,.85); padding: 7px 16px;
  border-radius: var(--r-pill); font-size: 12px; font-weight: 500;
  margin-bottom: 28px;
}
.eco-dot { font-size: 14px; }
.eco-sep { opacity: .4; }
.hero-h1 {
  font-size: clamp(3rem, 7vw, 6rem);
  font-weight: 700; line-height: 1.0;
  letter-spacing: -.03em; color: #fff;
  margin-bottom: 24px;
}
.hero-h1 em { font-style: italic; color: var(--green-light); }
.hero-sub {
  font-size: 1.05rem; line-height: 1.8;
  color: rgba(255,255,255,.65); max-width: 520px;
  margin-bottom: 36px;
}
.hero-actions {
  display: flex; flex-wrap: wrap; gap: 14px;
  margin-bottom: 48px;
}
.hero-stats {
  display: flex; gap: 40px; flex-wrap: wrap;
  padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,.12);
}
.hs-num {
  font-size: 2rem; font-weight: 700;
  color: var(--green-light); line-height: 1;
}
.hs-lbl {
  font-size: 12px; color: rgba(255,255,255,.45);
  margin-top: 4px;
}
.hero-wave {
  position: absolute; bottom: -1px; left: 0; right: 0;
  z-index: 3; line-height: 0;
}
.hero-wave svg { width: 100%; height: 80px; display: block; }
.hero-urgence {
  position: absolute; bottom: 100px; right: 2rem;
  z-index: 4; display: flex; align-items: center; gap: 14px;
  background: rgba(27,46,27,.88); backdrop-filter: blur(12px);
  border: 1px solid rgba(92,158,74,.3);
  border-radius: var(--r-md); padding: 14px 20px; color: #fff;
  transition: border-color .2s, transform .2s;
}
.hero-urgence:hover { border-color: var(--green); transform: translateY(-3px); }
.urg-icon { font-size: 1.8rem; flex-shrink: 0; }
.hero-urgence strong { display: block; font-size: 1rem; color: var(--green-light); }
.hero-urgence span { font-size: 12px; color: rgba(255,255,255,.5); }

/* ═══ SAISONS ═══ */
.sec-saisons {
  padding: clamp(4rem,7vw,6rem) 0;
  background: var(--bg);
}
.saisons-grid {
  display: grid; grid-template-columns: repeat(4,1fr); gap: 20px;
  margin-top: 3rem;
}
.saison-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 28px 24px;
  border-top: 3px solid transparent;
  transition: border-color .25s, transform .38s, box-shadow .38s;
}
.saison-card:hover { border-top-color: var(--green); }
.saison-icon { font-size: 2.2rem; margin-bottom: 14px; }
.saison-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 10px; }
.saison-travaux { font-size: .85rem; color: var(--text-muted); line-height: 1.7; }

/* ═══ SERVICES ═══ */
.svc-head {
  display: flex; justify-content: space-between;
  align-items: flex-end; gap: 2rem; margin-bottom: 3rem; flex-wrap: wrap;
}
.svc-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 24px;
  margin-bottom: 20px;
}
.svc-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--r-md); overflow: hidden;
}
.svc-img { position: relative; height: 260px; }
.svc-img img { width: 100%; height: 100%; object-fit: cover; }
.svc-num {
  position: absolute; top: 14px; left: 16px;
  font-size: 3.5rem; font-weight: 700;
  color: rgba(255,255,255,.18); line-height: 1;
}
.svc-body { padding: 24px; }
.svc-icon { font-size: 1.5rem; display: block; margin-bottom: 10px; }
.svc-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 10px; letter-spacing: -.01em; }
